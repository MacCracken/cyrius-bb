# --- error.cyr ---

# error.cyr — unified error type with errno mapping
# Ported from rust-old/src/error.rs
#
# In Cyrius, errors are integer codes. The SysError "enum" becomes
# integer constants, and error messages are string pointers.
#
# Error representation: a Result (tagged union from lib/tagged.cyr)
# where Err payload is a pointer to an error struct:
#   { kind: i64, errno: i64, message: *str }
#
# Convention: all agnosys functions return Result values.
# Ok(value) on success, Err(err_ptr) on failure.

# ================================================================
# Error kind constants (maps to Rust SysError variants)
# ================================================================

enum SysErrorKind {
    ERR_SYSCALL_FAILED = 1;
    ERR_INVALID_ARGUMENT = 2;
    ERR_PERMISSION_DENIED = 3;
    ERR_WOULD_BLOCK = 4;
    ERR_MODULE_NOT_LOADED = 5;
    ERR_NOT_SUPPORTED = 6;
    ERR_UNKNOWN = 7;
    ERR_IO = 8;
}

# ================================================================
# Errno constants (Linux x86_64)
# ================================================================

enum Errno {
    EPERM = 1;
    ENOENT = 2;
    ESRCH = 3;
    EINTR = 4;
    EIO = 5;
    ENXIO = 6;
    EBADF = 9;
    EAGAIN = 11;
    ENOMEM = 12;
    EACCES = 13;
    EFAULT = 14;
    EBUSY = 16;
    EEXIST = 17;
    ENODEV = 19;
    ENOTDIR = 20;
    EISDIR = 21;
    EINVAL = 22;
    EMFILE = 24;
    ENOSPC = 28;
    EPIPE = 32;
    ERANGE = 34;
    ENOSYS = 38;
    ENOTEMPTY = 39;
    ENODATA = 61;
    EOVERFLOW = 75;
    EOPNOTSUPP = 95;
    EADDRINUSE = 98;
    ECONNREFUSED = 111;
    ETIMEDOUT = 110;
}

# ================================================================
# Error struct: { kind, errno, message_ptr }
# Layout: kind at +0, errno at +8, message at +16. Total: 24 bytes.
# ================================================================

# ================================================================
# Error representation — dual encoding
# ================================================================
#
# Packed error: kind << 16 | errno (no message, no heap, value < 0x100000)
# Heap error:   pointer to { kind, errno, message_ptr } (24 bytes, value >= 0x100000)
#
# syserr_kind/errno/message dispatch on the value automatically.

# Pack kind + errno into a single integer (zero allocation)
fn syserr_pack(kind, errno) {
    return kind << 16 | errno;
}

# Create a new error with message (heap-allocated, cold path)
fn syserr_new(kind, errno, message) {
    var e = alloc(24);
    store64(e, kind);
    store64(e + 8, errno);
    store64(e + 16, message);
    return e;
}

# Get error kind (works for both packed and heap errors)
fn syserr_kind(e) {
    if (e < 0x100000) { return e >> 16; }
    return load64(e);
}

# Get errno value (works for both packed and heap errors)
fn syserr_errno(e) {
    if (e < 0x100000) { return e & 0xFFFF; }
    return load64(e + 8);
}

# Get error message pointer (0 for packed errors)
fn syserr_message(e) {
    if (e < 0x100000) { return 0; }
    return load64(e + 16);
}

# ================================================================
# Error constructors — packed (fast, no alloc)
# ================================================================

fn err_syscall_failed_nr(errno) {
    return Err(syserr_pack(ERR_SYSCALL_FAILED, errno));
}

fn err_permission_denied_nr(errno) {
    return Err(syserr_pack(ERR_PERMISSION_DENIED, errno));
}

fn err_would_block() {
    return Err(syserr_pack(ERR_WOULD_BLOCK, EAGAIN));
}

fn err_invalid_argument_nr() {
    return Err(syserr_pack(ERR_INVALID_ARGUMENT, EINVAL));
}

fn err_not_supported_nr() {
    return Err(syserr_pack(ERR_NOT_SUPPORTED, ENOSYS));
}

# ================================================================
# Error constructors — with message (heap, cold path)
# ================================================================

fn err_syscall_failed(errno, message) {
    return Err(syserr_new(ERR_SYSCALL_FAILED, errno, message));
}

fn err_invalid_argument(message) {
    return Err(syserr_new(ERR_INVALID_ARGUMENT, EINVAL, message));
}

fn err_permission_denied(operation) {
    return Err(syserr_new(ERR_PERMISSION_DENIED, EPERM, operation));
}

fn err_module_not_loaded(module) {
    return Err(syserr_new(ERR_MODULE_NOT_LOADED, ENODEV, module));
}

fn err_not_supported(feature) {
    return Err(syserr_new(ERR_NOT_SUPPORTED, ENOSYS, feature));
}

fn err_unknown(message) {
    return Err(syserr_new(ERR_UNKNOWN, 0, message));
}

fn err_io(errno, message) {
    return Err(syserr_new(ERR_IO, errno, message));
}

# ================================================================
# Errno-based error creation — packed (zero alloc, hot path)
# ================================================================

fn err_from_errno(errno) {
    if (errno == EPERM) { return err_permission_denied_nr(EPERM); }
    if (errno == EACCES) { return err_permission_denied_nr(EACCES); }
    if (errno == EAGAIN) { return err_would_block(); }
    if (errno == EINVAL) { return err_invalid_argument_nr(); }
    if (errno == ENOSYS) { return err_not_supported_nr(); }
    return err_syscall_failed_nr(errno);
}

fn err_from_syscall_ret(ret) {
    var errno = 0 - ret;
    return err_from_errno(errno);
}

# ================================================================
# Error printing
# ================================================================

fn syserr_print(e) {
    var kind = syserr_kind(e);
    var msg = syserr_message(e);
    var msglen = 0;
    if (msg != 0) { msglen = strlen(msg); }

    if (kind == ERR_SYSCALL_FAILED) {
        syscall(1, 2, "syscall failed (errno ", 22);
        var ebuf[24];
        var elen = fmt_int_buf(syserr_errno(e), &ebuf);
        syscall(1, 2, &ebuf, elen);
        syscall(1, 2, "): ", 3);
        syscall(1, 2, msg, msglen);
    }
    elif (kind == ERR_INVALID_ARGUMENT) {
        syscall(1, 2, "invalid argument: ", 18);
        syscall(1, 2, msg, msglen);
    }
    elif (kind == ERR_PERMISSION_DENIED) {
        syscall(1, 2, "permission denied: ", 19);
        syscall(1, 2, msg, msglen);
    }
    elif (kind == ERR_WOULD_BLOCK) {
        syscall(1, 2, "resource temporarily unavailable", 32);
    }
    elif (kind == ERR_MODULE_NOT_LOADED) {
        syscall(1, 2, "kernel module not loaded: ", 25);
        syscall(1, 2, msg, msglen);
    }
    elif (kind == ERR_NOT_SUPPORTED) {
        syscall(1, 2, "feature not supported: ", 23);
        syscall(1, 2, msg, msglen);
    }
    elif (kind == ERR_IO) {
        syscall(1, 2, "io error (errno ", 16);
        var ibuf[24];
        var ilen = fmt_int_buf(syserr_errno(e), &ibuf);
        syscall(1, 2, &ibuf, ilen);
        syscall(1, 2, "): ", 3);
        syscall(1, 2, msg, msglen);
    }
    else {
        syscall(1, 2, "unknown error: ", 15);
        syscall(1, 2, msg, msglen);
    }
    syscall(1, 2, "\n", 1);
    return 0;
}

# Print error from a Result if it's Err, then return the error code.
# Returns 0 if the Result is Ok.
fn result_print_err(res) {
    if (is_ok(res) == 1) { return 0; }
    var e = payload(res);
    syserr_print(e);
    return syserr_errno(e);
}

# ================================================================
# Result helpers for agnosys convention
# ================================================================

# Propagate error: if res is Err, return it immediately.
# Use at top of functions: var val = try_unwrap(res); if (val == 0) { ... }
# Note: Cyrius has no ? operator, so error propagation is manual.
# Pattern:
#   var res = some_call();
#   if (is_err_result(res) == 1) { return res; }
#   var val = payload(res);

# Check if a syscall return value indicates error (negative = errno)
fn is_syscall_err(ret) {
    return ret < 0;
}

# Wrap a raw syscall return: Ok(ret) if >= 0, Err(from_errno) if < 0
fn wrap_syscall(ret) {
    if (ret < 0) { return err_from_syscall_ret(ret); }
    return Ok(ret);
}

# --- syscall.cyr ---

# syscall.cyr — high-level syscall wrappers
# Ported from rust-old/src/syscall.rs
#
# Thin wrappers around raw Linux syscalls with Result-based error handling.
# These are the primitives that higher-level modules build on.
#
# Requires: lib/syscalls.cyr, src/error.cyr

#define LINUX

# ================================================================
# Additional syscall numbers not in lib/syscalls.cyr
# ================================================================

enum SysNrExt {
    SYS_GETTID = 186;
    SYS_SYSINFO = 99;
    SYS_UNAME_NR = 63;
    SYS_PRCTL = 157;
}

# ================================================================
# Checked syscall — wraps raw syscall with Result error handling
# ================================================================

# Execute a syscall and return Result: Ok(ret) or Err(syserr).
# name is a string label for diagnostics (not used in codegen).
fn agnosys_checked_syscall(ret) {
    if (ret < 0) {
        return err_from_syscall_ret(ret);
    }
    return Ok(ret);
}

# ================================================================
# Process identity
# ================================================================

# Get the current process ID.
fn agnosys_getpid() {
    return syscall(SYS_GETPID);
}

# Get the current thread ID.
fn agnosys_gettid() {
    return syscall(SYS_GETTID);
}

# Get the current user ID.
fn agnosys_getuid() {
    return syscall(SYS_GETUID);
}

# Get the current effective user ID.
fn agnosys_geteuid() {
    return syscall(SYS_GETEUID);
}

# Check if the current process has root privileges.
fn agnosys_is_root() {
    if (agnosys_geteuid() == 0) { return 1; }
    return 0;
}

# ================================================================
# sysinfo — system information snapshot
# ================================================================

# sysinfo struct layout (from Linux <sys/sysinfo.h>):
# Offset  Field           Size
#   0     uptime          8 (long)
#   8     loads[3]       24 (3 * unsigned long)
#  32     totalram        8 (unsigned long)
#  40     freeram         8 (unsigned long)
#  48     sharedram       8 (unsigned long)
#  56     bufferram       8 (unsigned long)
#  64     totalswap       8 (unsigned long)
#  72     freeswap        8 (unsigned long)
#  80     procs           2 (unsigned short)
#  82     pad             2
#  84     totalhigh       8 (unsigned long) — actually offset 88 on x86_64
#  ...
# 104     mem_unit        4 (unsigned int)
# Total struct size: 112 bytes

enum SysInfoOffset {
    SI_UPTIME = 0;
    SI_TOTALRAM = 32;
    SI_FREERAM = 40;
    SI_PROCS = 80;
    SI_MEM_UNIT = 104;
}

enum SysInfoConst {
    SYSINFO_SIZE = 120;
}

# Query sysinfo(2) into a caller-provided buffer.
# out must point to at least 120 bytes.
# Returns Result: Ok(out) or Err(syserr). Zero heap allocation on success.
fn query_sysinfo(out) {
    var ret = syscall(SYS_SYSINFO, out);
    if (ret < 0) {
        return err_from_syscall_ret(ret);
    }
    return Ok(out);
}

# Get uptime in seconds from a sysinfo pointer.
fn sysinfo_uptime(info) {
    return load64(info + SI_UPTIME);
}

# Get total RAM in bytes from a sysinfo pointer.
# Uses saturating multiplication to prevent overflow.
fn sysinfo_total_memory(info) {
    var ram = load64(info + SI_TOTALRAM);
    var unit = load32(info + SI_MEM_UNIT);
    # Saturating multiply: if either is 0 or result would overflow, cap it
    if (unit == 0) { return ram; }
    if (unit == 1) { return ram; }
    if (ram > 0x7FFFFFFFFFFFFFFF / unit) { return 0x7FFFFFFFFFFFFFFF; }
    return ram * unit;
}

# Get free RAM in bytes from a sysinfo pointer.
fn sysinfo_free_memory(info) {
    var ram = load64(info + SI_FREERAM);
    var unit = load32(info + SI_MEM_UNIT);
    if (unit == 0) { return ram; }
    if (unit == 1) { return ram; }
    if (ram > 0x7FFFFFFFFFFFFFFF / unit) { return 0x7FFFFFFFFFFFFFFF; }
    return ram * unit;
}

# Get number of running processes from a sysinfo pointer.
fn sysinfo_procs(info) {
    return load16(info + SI_PROCS);
}

# ================================================================
# Convenience wrappers (each makes its own sysinfo call)
# ================================================================

# Get system uptime in seconds. Returns Result.
fn agnosys_uptime() {
    var buf[120];
    var res = query_sysinfo(&buf);
    if (is_err_result(res) == 1) { return res; }
    return Ok(sysinfo_uptime(&buf));
}

# Get total system memory in bytes. Returns Result.
fn agnosys_total_memory() {
    var buf[120];
    var res = query_sysinfo(&buf);
    if (is_err_result(res) == 1) { return res; }
    return Ok(sysinfo_total_memory(&buf));
}

# Get free system memory in bytes. Returns Result.
fn agnosys_free_memory() {
    var buf[120];
    var res = query_sysinfo(&buf);
    if (is_err_result(res) == 1) { return res; }
    return Ok(sysinfo_free_memory(&buf));
}

# ================================================================
# Hostname
# ================================================================

# utsname struct layout:
# Each field is 65 bytes (including null). Total: 6 * 65 = 390 bytes.
# Field order: sysname, nodename, release, version, machine, domainname
# nodename is at offset 65.

enum UtsOffset {
    UTS_SYSNAME = 0;
    UTS_NODENAME = 65;
    UTS_RELEASE = 130;
    UTS_VERSION = 195;
    UTS_MACHINE = 260;
}

enum UtsConst {
    UTS_SIZE = 390;
}

# Query uname(2) into a caller-provided buffer.
# out must point to at least 390 bytes.
# Returns Result: Ok(out) or Err. All uts fields accessible via offsets.
fn agnosys_uname(out) {
    var ret = syscall(SYS_UNAME_NR, out);
    if (ret < 0) {
        return err_from_syscall_ret(ret);
    }
    return Ok(out);
}

# Get hostname from a utsname buffer.
fn uname_hostname(uts) {
    return uts + UTS_NODENAME;
}

# Get kernel release from a utsname buffer.
fn uname_release(uts) {
    return uts + UTS_RELEASE;
}

# Get machine arch from a utsname buffer.
fn uname_machine(uts) {
    return uts + UTS_MACHINE;
}

# --- logging.cyr ---

# logging.cyr — simple structured logging to stderr
# New module (no Rust source)
#
# Thin wrapper providing log level control via the AGNOSYS_LOG env var
# and formatted output to stderr (fd 2).
#
# Requires: src/error.cyr, lib/syscalls.cyr

# ================================================================
# Log level constants
# ================================================================

enum LogLevel {
    LOG_TRACE = 0;
    LOG_DEBUG = 1;
    LOG_INFO = 2;
    LOG_WARN = 3;
    LOG_ERROR = 4;
    LOG_OFF = 5;
}

# ================================================================
# Global log level (module-level state)
# ================================================================

# The current log level. Default: LOG_INFO.
# Initialized from AGNOSYS_LOG env var on first use.
# We store this in a small heap-allocated cell so it persists.
# 0 = not initialized, positive = level + 1 (to distinguish from 0/TRACE)

var _log_level_cell = 0;

fn log_init_from_env() {
    if (_log_level_cell != 0) { return 0; }
    _log_level_cell = alloc(8);
    store64(_log_level_cell, LOG_INFO + 1);  # default: INFO

    # Try reading AGNOSYS_LOG env var
    # We'll check /proc/self/environ for the variable
    var fd = sys_open("/proc/self/environ", 0, 0);
    if (fd < 0) { return 0; }
    defer { sys_close(fd); }

    var buf = alloc(4096);
    var nread = sys_read(fd, buf, 4096);

    if (nread <= 0) { return 0; }

    # environ is null-delimited key=value pairs
    var pos = 0;
    var target = "AGNOSYS_LOG=";
    var tlen = strlen(target);

    while (pos < nread) {
        # Check if this entry starts with AGNOSYS_LOG=
        var found = 1;
        var i = 0;
        while (i < tlen) {
            if (pos + i >= nread) { found = 0; break; }
            if (load8(buf + pos + i) != load8(target + i)) { found = 0; break; }
            i = i + 1;
        }

        if (found == 1) {
            # Found it. Extract value (until null byte).
            var vstart = pos + tlen;
            var vend = vstart;
            while (vend < nread) {
                if (load8(buf + vend) == 0) { break; }
                vend = vend + 1;
            }
            var vlen = vend - vstart;
            if (vlen > 0) {
                var val = buf + vstart;
                # Parse level string
                # tr(ace)
                if (vlen == 5) {
                    if (load8(val) == 116 && load8(val + 1) == 114) {
                        store64(_log_level_cell, LOG_TRACE + 1);
                    }
                }
                # de(bug)
                if (vlen == 5) {
                    if (load8(val) == 100 && load8(val + 1) == 101) {
                        store64(_log_level_cell, LOG_DEBUG + 1);
                    }
                }
                # in(fo) / wa(rn)
                if (vlen == 4) {
                    if (load8(val) == 105 && load8(val + 1) == 110) {
                        store64(_log_level_cell, LOG_INFO + 1);
                    }
                    if (load8(val) == 119 && load8(val + 1) == 97) {
                        store64(_log_level_cell, LOG_WARN + 1);
                    }
                }
                # er(ror)
                if (vlen == 5) {
                    if (load8(val) == 101 && load8(val + 1) == 114) {
                        store64(_log_level_cell, LOG_ERROR + 1);
                    }
                }
                # of(f)
                if (vlen == 3) {
                    if (load8(val) == 111 && load8(val + 1) == 102) {
                        store64(_log_level_cell, LOG_OFF + 1);
                    }
                }
            }
            return 0;
        }

        # Skip to next null byte
        while (pos < nread) {
            if (load8(buf + pos) == 0) { pos = pos + 1; break; }
            pos = pos + 1;
        }
    }

    return 0;
}

fn log_get_level() {
    log_init_from_env();
    return load64(_log_level_cell) - 1;
}

fn log_set_level(level) {
    if (_log_level_cell == 0) {
        _log_level_cell = alloc(8);
    }
    store64(_log_level_cell, level + 1);
    return 0;
}

# ================================================================
# Log level prefix strings
# ================================================================

fn log_level_prefix(level) {
    if (level == LOG_TRACE) { return "[TRACE] "; }
    if (level == LOG_DEBUG) { return "[DEBUG] "; }
    if (level == LOG_INFO)  { return "[INFO]  "; }
    if (level == LOG_WARN)  { return "[WARN]  "; }
    if (level == LOG_ERROR) { return "[ERROR] "; }
    return "[?????] ";
}

# ================================================================
# Core logging function
# ================================================================

# Log a message at the given level to stderr (fd 2).
# Does nothing if the current level is above the message level.
fn log_msg(level, message) {
    var current = log_get_level();
    if (level < current) { return 0; }

    var prefix = log_level_prefix(level);
    var plen = strlen(prefix);
    var mlen = strlen(message);

    # Write prefix
    syscall(1, 2, prefix, plen);
    # Write message
    syscall(1, 2, message, mlen);
    # Write newline
    syscall(1, 2, "\n", 1);

    return 0;
}

# ================================================================
# Convenience functions
# ================================================================

fn log_trace(message) { return log_msg(LOG_TRACE, message); }
fn log_debug(message) { return log_msg(LOG_DEBUG, message); }
fn log_info(message)  { return log_msg(LOG_INFO, message); }
fn log_warn(message)  { return log_msg(LOG_WARN, message); }
fn log_error(message) { return log_msg(LOG_ERROR, message); }

# Log a message with a key=value context pair.
# Outputs: [LEVEL] message key=value
fn log_msg_kv(level, message, key, value) {
    var current = log_get_level();
    if (level < current) { return 0; }

    var prefix = log_level_prefix(level);
    var plen = strlen(prefix);
    var mlen = strlen(message);
    var klen = strlen(key);
    var vlen = strlen(value);

    syscall(1, 2, prefix, plen);
    syscall(1, 2, message, mlen);
    syscall(1, 2, " ", 1);
    syscall(1, 2, key, klen);
    syscall(1, 2, "=", 1);
    syscall(1, 2, value, vlen);
    syscall(1, 2, "\n", 1);

    return 0;
}

# --- security.cyr ---

# security.cyr — Landlock, seccomp BPF, namespace creation
# Ported from rust-old/src/security.rs
#
# Provides Landlock filesystem sandboxing, seccomp-BPF syscall filtering,
# and Linux namespace creation via raw syscalls.

#define LINUX

# ================================================================
# Landlock constants (kernel 5.13+, x86_64)
# ================================================================

enum LandlockConst {
    SYS_LANDLOCK_CREATE_RULESET = 444;
    SYS_LANDLOCK_ADD_RULE = 445;
    SYS_LANDLOCK_RESTRICT_SELF = 446;
    LANDLOCK_ACCESS_FS_READ_FILE = 4;
    LANDLOCK_ACCESS_FS_READ_DIR = 8;
    LANDLOCK_ACCESS_FS_WRITE_FILE = 2;
    LANDLOCK_RULE_PATH_BENEATH = 1;
    SYS_PRCTL = 157;
}

# Filesystem access levels
enum FsAccess {
    FS_NO_ACCESS = 0;
    FS_READ_ONLY = 1;
    FS_READ_WRITE = 2;
}

# Filesystem rule: { path_ptr, access }
# path_ptr is a null-terminated C string pointer
fn security_fs_rule_new(path, access) {
    var r = alloc(16);
    store64(r, path);
    store64(r + 8, access);
    return r;
}

fn security_fs_rule_path(r) { return load64(r); }
fn security_fs_rule_access(r) { return load64(r + 8); }

fn security_fs_rule_read_only(path) { return security_fs_rule_new(path, FS_READ_ONLY); }
fn security_fs_rule_read_write(path) { return security_fs_rule_new(path, FS_READ_WRITE); }

# ================================================================
# Apply Landlock filesystem restrictions
# ================================================================

# rules: vec of fs_rule pointers, count: number of rules
# Returns Result: Ok(0) on success, Err on failure.
fn security_apply_landlock(rules, count) {
    if (count == 0) { return Ok(0); }

    var handled_access = LANDLOCK_ACCESS_FS_READ_FILE
    | LANDLOCK_ACCESS_FS_READ_DIR | LANDLOCK_ACCESS_FS_WRITE_FILE;

    # LandlockRulesetAttr: { handled_access_fs: u64 } = 8 bytes
    var attr[1];
    store64(&attr, handled_access);

    var ruleset_fd = syscall(SYS_LANDLOCK_CREATE_RULESET, &attr, 8, 0);
    if (ruleset_fd < 0) {
        var errno = 0 - ruleset_fd;
        if (errno == ENOSYS) { return Ok(0); }
        if (errno == EOPNOTSUPP) { return Ok(0); }
        return err_syscall_failed(errno, "landlock_create_ruleset failed");
    }
    defer { syscall(SYS_CLOSE, ruleset_fd); }

    var idx = 0;
    while (idx < count) {
        var rule = vec_get(rules, idx);
        var access = security_fs_rule_access(rule);

        var allowed_access = 0;
        if (access == FS_READ_ONLY) {
            allowed_access = LANDLOCK_ACCESS_FS_READ_FILE | LANDLOCK_ACCESS_FS_READ_DIR;
        }
        elif (access == FS_READ_WRITE) {
            allowed_access = LANDLOCK_ACCESS_FS_READ_FILE
            | LANDLOCK_ACCESS_FS_READ_DIR | LANDLOCK_ACCESS_FS_WRITE_FILE;
        }

        if (allowed_access != 0) {
            var path = security_fs_rule_path(rule);
            # O_PATH = 0x200000, O_CLOEXEC = 0x80000
            var path_fd = syscall(SYS_OPEN, path, 0x280000, 0);
            if (path_fd < 0) {
                return err_syscall_failed(0 - path_fd, "landlock open path failed");
            }

            # LandlockPathBeneathAttr: { allowed_access: u64, parent_fd: i32 }
            # Layout: 8 bytes access + 4 bytes fd = 12 bytes (pad to 16)
            var beneath[16];
            store64(&beneath, allowed_access);
            store32(&beneath + 8, path_fd);

            var ret = syscall(SYS_LANDLOCK_ADD_RULE,
            ruleset_fd, LANDLOCK_RULE_PATH_BENEATH, &beneath, 0);
            syscall(SYS_CLOSE, path_fd);

            if (ret < 0) {
                return err_syscall_failed(0 - ret, "landlock_add_rule failed");
            }
        }
        idx = idx + 1;
    }

    # Set no_new_privs (required by Landlock)
    var ret = syscall(SYS_PRCTL, 38, 1, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "PR_SET_NO_NEW_PRIVS failed");
    }

    ret = syscall(SYS_LANDLOCK_RESTRICT_SELF, ruleset_fd, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "landlock_restrict_self failed");
    }

    return Ok(0);
}

# ================================================================
# Seccomp BPF
# ================================================================

# BPF instruction constants
enum BpfConst {
    BPF_LD_W_ABS = 0x20;
    BPF_JMP_JEQ_K = 0x15;
    BPF_RET_K = 0x06;
    SECCOMP_RET_ALLOW = 0x7FFF0000;
    SECCOMP_RET_KILL_PROCESS = 0x80000000;
    SECCOMP_RET_TRAP = 0x00030000;
    BPF_MAXINSNS = 4096;
    PR_SET_NO_NEW_PRIVS = 38;
    PR_SET_SECCOMP = 22;
    SECCOMP_MODE_FILTER = 2;
}

# Write a BPF sock_filter instruction (8 bytes) to buf at offset.
# Layout: u16 code, u8 jt, u8 jf, u32 k (little-endian)
fn security_bpf_write_insn(buf, offset, code, jt, jf, k) {
    store16(buf + offset, code);
    store8(buf + offset + 2, jt);
    store8(buf + offset + 3, jf);
    store32(buf + offset + 4, k);
    return 0;
}

# Load a seccomp-BPF filter into the calling process.
# filter: pointer to BPF bytecode, filter_len: total bytes.
# Returns Result.
fn security_load_seccomp(filter, filter_len) {
    if (filter_len == 0) {
        return err_invalid_argument("empty seccomp filter");
    }
    if (filter_len % 8 != 0) {
        return err_invalid_argument("filter size not multiple of 8");
    }
    var num_insns = filter_len / 8;
    if (num_insns > BPF_MAXINSNS) {
        return err_invalid_argument("seccomp filter too large");
    }

    # Set no_new_privs
    var ret = syscall(SYS_PRCTL, PR_SET_NO_NEW_PRIVS, 1, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "PR_SET_NO_NEW_PRIVS failed");
    }

    # sock_fprog: { u16 len, pad[6], u64 filter_ptr }
    # On x86_64: { u16 len (2 bytes), 6 pad, ptr (8 bytes) } = 16 bytes
    var prog[16];
    store16(&prog, num_insns);
    store64(&prog + 8, filter);

    ret = syscall(SYS_PRCTL, PR_SET_SECCOMP, SECCOMP_MODE_FILTER, &prog, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "PR_SET_SECCOMP failed");
    }

    return Ok(0);
}

# Create a basic seccomp filter allowing safe syscalls.
# Returns Result: Ok(filter_ptr) where payload is {ptr, len}.
# The caller must use the returned pointer and length with security_load_seccomp.
fn security_create_basic_seccomp_filter() {
    # Pre-computed BPF filter: 23 instructions x 8 bytes = 184 bytes.
    # Layout per insn: u16 code, u8 jt, u8 jf, u32 k (little-endian).
    # 20 allowlisted syscalls: read(0), write(1), close(3), fstat(5),
    # mmap(9), mprotect(10), munmap(11), brk(12), rt_sigreturn(15),
    # exit(60), sigaltstack(131), arch_prctl(158), gettid(186),
    # futex(202), set_tid_address(218), exit_group(231),
    # set_robust_list(273), getrandom(318), clock_gettime(228), rseq(334).
    var filter_size = 184;
    var filter = alloc(filter_size);

    # Insn 0: BPF_LD_W_ABS, k=0 (load syscall nr)
    security_bpf_write_insn(filter, 0, 0x20, 0, 0, 0);
    # Insns 1-20: JEQ for each syscall, jt = skip to ALLOW
    security_bpf_write_insn(filter, 8,   0x15, 20, 0, 0);     # read
    security_bpf_write_insn(filter, 16,  0x15, 19, 0, 1);     # write
    security_bpf_write_insn(filter, 24,  0x15, 18, 0, 3);     # close
    security_bpf_write_insn(filter, 32,  0x15, 17, 0, 5);     # fstat
    security_bpf_write_insn(filter, 40,  0x15, 16, 0, 9);     # mmap
    security_bpf_write_insn(filter, 48,  0x15, 15, 0, 10);    # mprotect
    security_bpf_write_insn(filter, 56,  0x15, 14, 0, 11);    # munmap
    security_bpf_write_insn(filter, 64,  0x15, 13, 0, 12);    # brk
    security_bpf_write_insn(filter, 72,  0x15, 12, 0, 15);    # rt_sigreturn
    security_bpf_write_insn(filter, 80,  0x15, 11, 0, 60);    # exit
    security_bpf_write_insn(filter, 88,  0x15, 10, 0, 131);   # sigaltstack
    security_bpf_write_insn(filter, 96,  0x15, 9,  0, 158);   # arch_prctl
    security_bpf_write_insn(filter, 104, 0x15, 8,  0, 186);   # gettid
    security_bpf_write_insn(filter, 112, 0x15, 7,  0, 202);   # futex
    security_bpf_write_insn(filter, 120, 0x15, 6,  0, 218);   # set_tid_address
    security_bpf_write_insn(filter, 128, 0x15, 5,  0, 231);   # exit_group
    security_bpf_write_insn(filter, 136, 0x15, 4,  0, 273);   # set_robust_list
    security_bpf_write_insn(filter, 144, 0x15, 3,  0, 318);   # getrandom
    security_bpf_write_insn(filter, 152, 0x15, 2,  0, 228);   # clock_gettime
    security_bpf_write_insn(filter, 160, 0x15, 1,  0, 334);   # rseq
    # Insn 21: default KILL
    security_bpf_write_insn(filter, 168, 0x06, 0, 0, 0x80000000);
    # Insn 22: ALLOW
    security_bpf_write_insn(filter, 176, 0x06, 0, 0, 0x7FFF0000);

    var info = alloc(16);
    store64(info, filter);
    store64(info + 8, filter_size);
    return Ok(info);
}

# Get filter pointer from security_create_basic_seccomp_filter result
fn security_seccomp_filter_ptr(info) { return load64(info); }
fn security_seccomp_filter_len(info) { return load64(info + 8); }

# ================================================================
# Namespace creation
# ================================================================

enum CloneFlag {
    CLONE_NEWNET = 0x40000000;
    CLONE_NEWNS = 0x00020000;
    CLONE_NEWPID = 0x20000000;
    CLONE_NEWUSER = 0x10000000;
}

enum NsFlag {
    NS_NETWORK = 1;
    NS_MOUNT = 2;
    NS_PID = 4;
    NS_USER = 8;
}

enum SysNrNs {
    SYS_UNSHARE = 272;
}

# Create new namespace(s) with specified flags.
# flags: bitwise OR of NS_NETWORK, NS_MOUNT, NS_PID, NS_USER
# Returns Result.
fn security_create_namespace(flags) {
    var sflags = 0;
    if ((flags & NS_NETWORK) != 0) { sflags = sflags | CLONE_NEWNET; }
    if ((flags & NS_MOUNT) != 0) { sflags = sflags | CLONE_NEWNS; }
    if ((flags & NS_PID) != 0) { sflags = sflags | CLONE_NEWPID; }
    if ((flags & NS_USER) != 0) { sflags = sflags | CLONE_NEWUSER; }

    var ret = syscall(SYS_UNSHARE, sflags);
    if (ret < 0) {
        var errno = 0 - ret;
        if (errno == EPERM) { return err_permission_denied("security_create_namespace"); }
        if (errno == EINVAL) { return err_invalid_argument("security_create_namespace: invalid flags"); }
        return err_syscall_failed(errno, "unshare failed");
    }

    return Ok(0);
}

# ================================================================
# Syscall name to number mapping (hashmap, O(1) lookup)
# ================================================================

var _syscall_map = 0;

fn security_syscall_map_reset() { _syscall_map = 0; return 0; }

fn _syscall_map_init() {
    if (_syscall_map != 0) { return 0; }
    _syscall_map = map_new();
    map_set(_syscall_map, "read", 0);
    map_set(_syscall_map, "write", 1);
    map_set(_syscall_map, "open", 2);
    map_set(_syscall_map, "close", 3);
    map_set(_syscall_map, "stat", 4);
    map_set(_syscall_map, "fstat", 5);
    map_set(_syscall_map, "lseek", 8);
    map_set(_syscall_map, "mmap", 9);
    map_set(_syscall_map, "mprotect", 10);
    map_set(_syscall_map, "munmap", 11);
    map_set(_syscall_map, "brk", 12);
    map_set(_syscall_map, "rt_sigreturn", 15);
    map_set(_syscall_map, "ioctl", 16);
    map_set(_syscall_map, "access", 21);
    map_set(_syscall_map, "pipe", 22);
    map_set(_syscall_map, "dup", 32);
    map_set(_syscall_map, "dup2", 33);
    map_set(_syscall_map, "getpid", 39);
    map_set(_syscall_map, "socket", 41);
    map_set(_syscall_map, "connect", 42);
    map_set(_syscall_map, "accept", 43);
    map_set(_syscall_map, "sendto", 44);
    map_set(_syscall_map, "recvfrom", 45);
    map_set(_syscall_map, "bind", 49);
    map_set(_syscall_map, "listen", 50);
    map_set(_syscall_map, "fork", 57);
    map_set(_syscall_map, "execve", 59);
    map_set(_syscall_map, "exit", 60);
    map_set(_syscall_map, "wait4", 61);
    map_set(_syscall_map, "kill", 62);
    map_set(_syscall_map, "fcntl", 72);
    map_set(_syscall_map, "fsync", 74);
    map_set(_syscall_map, "getcwd", 79);
    map_set(_syscall_map, "chdir", 80);
    map_set(_syscall_map, "mkdir", 83);
    map_set(_syscall_map, "rmdir", 84);
    map_set(_syscall_map, "unlink", 87);
    map_set(_syscall_map, "chmod", 90);
    map_set(_syscall_map, "getuid", 102);
    map_set(_syscall_map, "getgid", 104);
    map_set(_syscall_map, "geteuid", 107);
    map_set(_syscall_map, "getegid", 108);
    map_set(_syscall_map, "getppid", 110);
    map_set(_syscall_map, "setsid", 112);
    map_set(_syscall_map, "prctl", 157);
    map_set(_syscall_map, "mount", 165);
    map_set(_syscall_map, "umount2", 166);
    map_set(_syscall_map, "gettid", 186);
    map_set(_syscall_map, "futex", 202);
    map_set(_syscall_map, "getdents64", 217);
    map_set(_syscall_map, "set_tid_address", 218);
    map_set(_syscall_map, "clock_gettime", 228);
    map_set(_syscall_map, "exit_group", 231);
    map_set(_syscall_map, "openat", 257);
    map_set(_syscall_map, "set_robust_list", 273);
    map_set(_syscall_map, "pipe2", 293);
    map_set(_syscall_map, "epoll_create1", 291);
    map_set(_syscall_map, "getrandom", 318);
    map_set(_syscall_map, "rseq", 334);
    return 0;
}

# Map a syscall name to its x86_64 number. Returns -1 if not found.
fn security_syscall_name_to_nr(name) {
    _syscall_map_init();
    if (map_has(_syscall_map, name) == 1) {
        return map_get(_syscall_map, name);
    }
    return 0 - 1;
}

# --- mac.cyr ---

# mac.cyr — Mandatory Access Control (MAC) interface
# Ported from rust-old/src/mac.rs
#
# Auto-detects the active Linux Security Module (SELinux or AppArmor)
# and provides security context / profile management.
#
# Reads /sys/kernel/security/lsm for LSM detection. SELinux mode from
# /sys/fs/selinux/enforce. AppArmor profiles via /proc/self/attr/current.
#
# Requires: lib/syscalls.cyr, lib/string.cyr, lib/str.cyr, src/error.cyr

#define LINUX

# ================================================================
# MAC system constants
# ================================================================

enum MacSystem {
    MAC_NONE = 0;
    MAC_SELINUX = 1;
    MAC_APPARMOR = 2;
}

# ================================================================
# SELinux mode constants
# ================================================================

enum SELinuxMode {
    SELINUX_ENFORCING = 1;
    SELINUX_PERMISSIVE = 2;
    SELINUX_DISABLED = 3;
}

# ================================================================
# AppArmor profile state constants
# ================================================================

enum AppArmorState {
    AA_ENFORCE = 1;
    AA_COMPLAIN = 2;
    AA_UNCONFINED = 3;
}

# ================================================================
# File read helper — read a small file into a Str
# Returns Result: Ok(str_ptr) or Err(syserr)
# ================================================================

fn mac_read_file(path) {
    var fd = sys_open(path, O_RDONLY, 0);
    if (fd < 0) {
        return err_io(0 - fd, path);
    }
    defer { sys_close(fd); }
    # Read up to 4096 bytes (plenty for sysfs/procfs files)
    var buf = alloc(4097);
    memset(buf, 0, 4097);
    var n = sys_read(fd, buf, 4096);
    if (n < 0) {
        return err_io(0 - n, path);
    }
    # Null-terminate
    store8(buf + n, 0);
    # Create Str from buffer
    var s = str_new(buf, n);
    return Ok(s);
}

# ================================================================
# File write helper — write a C string to a file
# Returns Result: Ok(0) or Err(syserr)
# ================================================================

fn mac_write_file(path, data, data_len) {
    var fd = sys_open(path, O_WRONLY, 0);
    if (fd < 0) {
        var errno = 0 - fd;
        if (errno == EPERM) { return err_permission_denied(path); }
        if (errno == EACCES) { return err_permission_denied(path); }
        return err_io(errno, path);
    }
    defer { sys_close(fd); }
    var n = sys_write(fd, data, data_len);
    if (n < 0) {
        var werrno = 0 - n;
        if (werrno == EPERM) { return err_permission_denied(path); }
        if (werrno == EACCES) { return err_permission_denied(path); }
        return err_io(werrno, path);
    }
    return Ok(0);
}

# ================================================================
# File existence check — returns 1 if file exists, 0 otherwise
# ================================================================

fn mac_file_exists(path) {
    # F_OK = 0
    return sys_access(path, 0) == 0;
}

# ================================================================
# Detect which MAC system is active on this kernel
# Reads /sys/kernel/security/lsm — returns MAC_SELINUX, MAC_APPARMOR,
# or MAC_NONE.
# ================================================================

fn mac_detect_system() {
    var res = mac_read_file("/sys/kernel/security/lsm");
    if (is_err_result(res) == 1) {
        # Cannot read LSM file — no MAC detection available
        return MAC_NONE;
    }
    var contents = payload(res);

    # Check SELinux first (higher priority if both are listed)
    if (str_contains(contents, str_from("selinux")) == 1) {
        return MAC_SELINUX;
    }
    # Also check uppercase variant
    if (str_contains(contents, str_from("SELinux")) == 1) {
        return MAC_SELINUX;
    }

    if (str_contains(contents, str_from("apparmor")) == 1) {
        return MAC_APPARMOR;
    }
    if (str_contains(contents, str_from("AppArmor")) == 1) {
        return MAC_APPARMOR;
    }

    return MAC_NONE;
}

# ================================================================
# SELinux mode query
# Reads /sys/fs/selinux/enforce.
# Returns Result: Ok(mode) where mode is SELINUX_ENFORCING,
# SELINUX_PERMISSIVE, or SELINUX_DISABLED.
# ================================================================

fn mac_get_selinux_mode() {
    var enforce_path = "/sys/fs/selinux/enforce";

    if (mac_file_exists(enforce_path) == 0) {
        return Ok(SELINUX_DISABLED);
    }

    var res = mac_read_file(enforce_path);
    if (is_err_result(res) == 1) { return res; }

    var contents = payload(res);
    var trimmed = str_trim(contents);
    var data = str_data(trimmed);
    var tlen = str_len(trimmed);

    # "1" = enforcing, "0" = permissive
    if (tlen >= 1) {
        var ch = load8(data);
        if (ch == 49) { return Ok(SELINUX_ENFORCING); }
        if (ch == 48) { return Ok(SELINUX_PERMISSIVE); }
    }

    return Ok(SELINUX_DISABLED);
}

# ================================================================
# Set SELinux enforcement mode
# Writes to /sys/fs/selinux/enforce. Requires CAP_MAC_ADMIN.
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_set_selinux_mode(mode) {
    var enforce_path = "/sys/fs/selinux/enforce";

    if (mac_file_exists(enforce_path) == 0) {
        return err_not_supported("selinux");
    }

    if (mode == SELINUX_DISABLED) {
        return err_invalid_argument("cannot disable SELinux at runtime; use kernel boot parameter");
    }

    if (mode == SELINUX_ENFORCING) {
        return mac_write_file(enforce_path, "1", 1);
    }
    if (mode == SELINUX_PERMISSIVE) {
        return mac_write_file(enforce_path, "0", 1);
    }

    return err_invalid_argument("invalid SELinux mode");
}

# ================================================================
# Get the current SELinux security context of this process
# Reads /proc/self/attr/current.
# Returns Result: Ok(str_ptr) or Err.
# ================================================================

fn mac_get_selinux_context() {
    var path = "/proc/self/attr/current";

    if (mac_file_exists(path) == 0) {
        return err_not_supported("selinux");
    }

    var res = mac_read_file(path);
    if (is_err_result(res) == 1) { return res; }

    var raw = payload(res);
    # Trim trailing nulls and whitespace
    var trimmed = str_trim(raw);
    return Ok(trimmed);
}

# ================================================================
# Set the SELinux security context for this process
# context: null-terminated C string (user:role:type:level)
# on_exec: if 1, apply on next exec (writes /proc/self/attr/exec)
#          if 0, apply immediately (writes /proc/self/attr/current)
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_set_selinux_context(context, on_exec) {
    if (strlen(context) == 0) {
        return err_invalid_argument("SELinux context cannot be empty");
    }

    # Validate format: must have at least 3 colons (user:role:type:level)
    var ctx_len = strlen(context);
    var colon_count = 0;
    var vi = 0;
    while (vi < ctx_len) {
        if (load8(context + vi) == 58) {
            colon_count = colon_count + 1;
        }
        vi = vi + 1;
    }
    if (colon_count < 3) {
        return err_invalid_argument(
        "invalid SELinux context format (expected user:role:type:level)");
    }

    var path = "/proc/self/attr/current";
    if (on_exec == 1) {
        path = "/proc/self/attr/exec";
    }

    if (mac_file_exists(path) == 0) {
        return err_not_supported("selinux");
    }

    return mac_write_file(path, context, ctx_len);
}

# ================================================================
# Get the current AppArmor mode/profile of this process
# Reads /proc/self/attr/current.
# Returns Result: Ok(state) where state is AA_ENFORCE, AA_COMPLAIN,
# or AA_UNCONFINED.
# ================================================================

fn mac_get_apparmor_mode() {
    var path = "/proc/self/attr/current";

    if (mac_file_exists(path) == 0) {
        return err_not_supported("apparmor");
    }

    var res = mac_read_file(path);
    if (is_err_result(res) == 1) { return res; }

    var raw = payload(res);
    var trimmed = str_trim(raw);

    # AppArmor format: "profile_name (mode)" or "unconfined"
    if (str_contains(trimmed, str_from("unconfined")) == 1) {
        return Ok(AA_UNCONFINED);
    }
    if (str_contains(trimmed, str_from("enforce")) == 1) {
        return Ok(AA_ENFORCE);
    }
    if (str_contains(trimmed, str_from("complain")) == 1) {
        return Ok(AA_COMPLAIN);
    }

    # Default: if we got a non-empty profile, assume enforce mode
    if (str_len(trimmed) > 0) {
        return Ok(AA_ENFORCE);
    }

    return Ok(AA_UNCONFINED);
}

# ================================================================
# Change the AppArmor profile of the current process
# Writes "changeprofile <name>" to /proc/self/attr/current.
# profile_name: null-terminated C string.
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_apparmor_change_profile(profile_name) {
    var name_len = strlen(profile_name);

    if (name_len == 0) {
        return err_invalid_argument("AppArmor profile name cannot be empty");
    }

    # Validate: no slashes or nulls in profile name
    var ci = 0;
    while (ci < name_len) {
        var ch = load8(profile_name + ci);
        if (ch == 47) {
            return err_invalid_argument("invalid AppArmor profile name: contains /");
        }
        if (ch == 0) {
            return err_invalid_argument("invalid AppArmor profile name: contains null");
        }
        ci = ci + 1;
    }

    var attr_path = "/proc/self/attr/current";
    if (mac_file_exists(attr_path) == 0) {
        return err_not_supported("apparmor");
    }

    # Build "changeprofile <name>" command
    var prefix = "changeprofile ";
    var prefix_len = strlen(prefix);
    var cmd_len = prefix_len + name_len;
    var cmd = alloc(cmd_len + 1);
    memcpy(cmd, prefix, prefix_len);
    memcpy(cmd + prefix_len, profile_name, name_len);
    store8(cmd + cmd_len, 0);

    return mac_write_file(attr_path, cmd, cmd_len);
}

# ================================================================
# Agent MAC profile struct
# Layout: { agent_type_ptr, selinux_ctx_ptr, apparmor_profile_ptr }
# Each field is a pointer to a null-terminated C string (or 0 for none).
# Offsets: agent_type=0, selinux_ctx=8, apparmor_profile=16. Size: 24 bytes.
# ================================================================

fn mac_profile_new(agent_type) {
    var p = alloc(24);
    store64(p, agent_type);
    store64(p + 8, 0);
    store64(p + 16, 0);
    return p;
}

fn mac_profile_agent_type(p) { return load64(p); }
fn mac_profile_selinux_ctx(p) { return load64(p + 8); }
fn mac_profile_apparmor_name(p) { return load64(p + 16); }

fn mac_profile_set_selinux_ctx(p, ctx) { store64(p + 8, ctx); return 0; }
fn mac_profile_set_apparmor_name(p, name) { store64(p + 16, name); return 0; }

# ================================================================
# Create a default agent MAC profile from an agent type string
# Generates standard SELinux context and AppArmor profile name.
# agent_type: null-terminated C string (e.g. "user", "service", "system")
# ================================================================

fn mac_default_profile(agent_type) {
    var p = mac_profile_new(agent_type);
    var tlen = strlen(agent_type);

    # Build SELinux context: "system_u:system_r:agnos_agent_<type>_t:s0"
    # Max: 29 + 32 (type) + 5 = 66 bytes
    var ctx_prefix = "system_u:system_r:agnos_agent_";
    var ctx_suffix = "_t:s0";
    var cplen = 29;
    var cslen = 5;
    var ctx_buf[128];
    memcpy(&ctx_buf, ctx_prefix, cplen);
    memcpy(&ctx_buf + cplen, agent_type, tlen);
    memcpy(&ctx_buf + cplen + tlen, ctx_suffix, cslen);
    store8(&ctx_buf + cplen + tlen + cslen, 0);
    # Copy to heap (caller may hold pointer beyond alloc_reset)
    var ctx_total = cplen + tlen + cslen;
    var ctx = alloc(ctx_total + 1);
    memcpy(ctx, &ctx_buf, ctx_total + 1);
    mac_profile_set_selinux_ctx(p, ctx);

    # Build AppArmor profile: "agnos-agent-<type>"
    var aa_prefix = "agnos-agent-";
    var aplen = 12;
    var aa_buf[64];
    memcpy(&aa_buf, aa_prefix, aplen);
    memcpy(&aa_buf + aplen, agent_type, tlen);
    store8(&aa_buf + aplen + tlen, 0);
    var aa_total = aplen + tlen;
    var aa = alloc(aa_total + 1);
    memcpy(aa, &aa_buf, aa_total + 1);
    mac_profile_set_apparmor_name(p, aa);

    return p;
}

# ================================================================
# Validate an agent MAC profile for a given MAC system
# Returns Result: Ok(0) on valid, Err on invalid.
# ================================================================

fn mac_profile_validate(profile, mac_system) {
    var agent_type = mac_profile_agent_type(profile);
    if (agent_type == 0) {
        return err_invalid_argument("agent type cannot be empty");
    }
    if (strlen(agent_type) == 0) {
        return err_invalid_argument("agent type cannot be empty");
    }

    if (mac_system == MAC_SELINUX) {
        var ctx = mac_profile_selinux_ctx(profile);
        if (ctx == 0) {
            return err_invalid_argument("SELinux context required but not set");
        }
        var ctx_len = strlen(ctx);
        if (ctx_len == 0) {
            return err_invalid_argument("SELinux context required but not set");
        }
        # Count colons — must have at least 3 (user:role:type:level)
        var colon_count = 0;
        var vi = 0;
        while (vi < ctx_len) {
            if (load8(ctx + vi) == 58) { colon_count = colon_count + 1; }
            vi = vi + 1;
        }
        if (colon_count < 3) {
            return err_invalid_argument("invalid SELinux context format");
        }
    }

    if (mac_system == MAC_APPARMOR) {
        var aa_name = mac_profile_apparmor_name(profile);
        if (aa_name == 0) {
            return err_invalid_argument("AppArmor profile name required but not set");
        }
        var aa_len = strlen(aa_name);
        if (aa_len == 0) {
            return err_invalid_argument("AppArmor profile name required but not set");
        }
        # No slashes or nulls allowed
        var ai = 0;
        while (ai < aa_len) {
            if (load8(aa_name + ai) == 47) {
                return err_invalid_argument("invalid AppArmor profile name");
            }
            ai = ai + 1;
        }
    }

    return Ok(0);
}

# ================================================================
# Apply agent MAC profile based on detected MAC system
# Detects the active MAC system, finds the matching profile,
# validates it, and applies it.
# agent_type: C string of agent type to match
# profiles: vec of mac_profile pointers
# profile_count: number of profiles
# Returns Result: Ok(0) or Err.
# ================================================================

fn mac_apply_agent_profile(agent_type, profiles, profile_count) {
    var mac_system = mac_detect_system();

    if (mac_system == MAC_NONE) {
        # No MAC system active — nothing to do
        return Ok(0);
    }

    # Find matching profile
    var found = 0;
    var idx = 0;
    while (idx < profile_count) {
        var p = vec_get(profiles, idx);
        var ptype = mac_profile_agent_type(p);
        if (streq(ptype, agent_type) == 1) {
            found = p;
            break;
        }
        idx = idx + 1;
    }

    if (found == 0) {
        return err_invalid_argument("no MAC profile found for agent type");
    }

    # Validate the profile
    var vres = mac_profile_validate(found, mac_system);
    if (is_err_result(vres) == 1) { return vres; }

    if (mac_system == MAC_SELINUX) {
        var ctx = mac_profile_selinux_ctx(found);
        # Apply on next exec
        return mac_set_selinux_context(ctx, 1);
    }

    if (mac_system == MAC_APPARMOR) {
        var aa_name = mac_profile_apparmor_name(found);
        return mac_apparmor_change_profile(aa_name);
    }

    return err_unknown("cannot apply MAC profile: unknown MAC system");
}

# --- audit.cyr ---

# audit.cyr — Linux Audit Subsystem interface
# Ported from rust-old/src/audit.rs
#
# Provides netlink audit socket management, event sending, status queries,
# rule add/delete, and AGNOS /proc audit reading.
#
# Requires CAP_AUDIT_CONTROL for configuration and CAP_AUDIT_WRITE for events.
#
# Requires: lib/syscalls.cyr, lib/string.cyr, lib/str.cyr,
#           lib/net.cyr, src/error.cyr

#define LINUX

# ================================================================
# Netlink / audit constants
# ================================================================

enum AuditConst {
    AF_NETLINK = 16;
    SOCK_RAW = 3;
    SOCK_CLOEXEC = 524288;
    NETLINK_AUDIT = 9;
    NLMSG_HDRLEN = 16;
    NLM_F_REQUEST = 1;
    AUDIT_GET = 1000;
    AUDIT_SET = 1001;
    AUDIT_USER = 1005;
    AUDIT_ADD_RULE = 1011;
    AUDIT_DEL_RULE = 1012;
    SYS_AGNOS_AUDIT_LOG = 520;
    AUDIT_MAX_MSG_LEN = 8192;
    AUDIT_MAX_KEY_LEN = 256;
    AUDIT_STATUS_ENABLED = 1;
    EPROTONOSUPPORT = 93;
}

# Syscall numbers for socket operations
enum SysNrAudit {
    SYS_SOCKET_NR = 41;
    SYS_BIND_NR = 49;
    SYS_SENDTO_NR = 44;
    SYS_RECVFROM_NR = 45;
}

# ================================================================
# Audit rule type constants
# ================================================================

enum AuditRuleType {
    AUDIT_RULE_FILE_WATCH = 1;
    AUDIT_RULE_SYSCALL_WATCH = 2;
}

# ================================================================
# Audit config struct
# Layout: { use_netlink, use_agnos_proc, proc_path_ptr }
# Offsets: use_netlink=0, use_agnos_proc=8, proc_path=16. Size: 24 bytes.
# ================================================================

fn audit_config_new() {
    var c = alloc(24);
    store64(c, 1);   # use_netlink = true
    store64(c + 8, 0);  # use_agnos_proc = false
    store64(c + 16, "/proc/agnos/audit");
    return c;
}

fn audit_config_use_netlink(c) { return load64(c); }
fn audit_config_use_proc(c) { return load64(c + 8); }
fn audit_config_proc_path(c) { return load64(c + 16); }

fn audit_config_set_netlink(c, val) { store64(c, val); return 0; }
fn audit_config_set_proc(c, val) { store64(c + 8, val); return 0; }
fn audit_config_set_proc_path(c, path) { store64(c + 16, path); return 0; }

# ================================================================
# Audit handle struct
# Layout: { fd, config_ptr }
# Offsets: fd=0, config=8. Size: 16 bytes.
# ================================================================

fn audit_handle_new(fd, config) {
    var h = alloc(16);
    store64(h, fd);
    store64(h + 8, config);
    return h;
}

fn audit_handle_fd(h) { return load64(h); }
fn audit_handle_config(h) { return load64(h + 8); }

# ================================================================
# Audit status struct
# Layout: { enabled, failure_action, pid, backlog_limit, lost, backlog }
# All i64. Offsets: 0, 8, 16, 24, 32, 40. Size: 48 bytes.
# ================================================================

fn audit_status_new() {
    var s = alloc(48);
    store64(s, 0);       # enabled = 0
    store64(s + 8, 1);   # failure_action = 1 (printk)
    store64(s + 16, 0);  # pid = 0
    store64(s + 24, 8192); # backlog_limit = 8192
    store64(s + 32, 0);  # lost = 0
    store64(s + 40, 0);  # backlog = 0
    return s;
}

fn audit_status_enabled(s) { return load64(s); }
fn audit_status_failure_action(s) { return load64(s + 8); }
fn audit_status_pid(s) { return load64(s + 16); }
fn audit_status_backlog_limit(s) { return load64(s + 24); }
fn audit_status_lost(s) { return load64(s + 32); }
fn audit_status_backlog(s) { return load64(s + 40); }

# ================================================================
# Audit rule struct
# Layout: { rule_type, path_ptr, syscall_nr, key_ptr }
# Offsets: rule_type=0, path=8, syscall_nr=16, key=24. Size: 32 bytes.
# ================================================================

fn audit_rule_new(rule_type, path, syscall_nr, key) {
    var r = alloc(32);
    store64(r, rule_type);
    store64(r + 8, path);
    store64(r + 16, syscall_nr);
    store64(r + 24, key);
    return r;
}

fn audit_rule_type(r) { return load64(r); }
fn audit_rule_path(r) { return load64(r + 8); }
fn audit_rule_syscall(r) { return load64(r + 16); }
fn audit_rule_key(r) { return load64(r + 24); }

# Create a file watch rule
fn audit_rule_file_watch(path, key) {
    return audit_rule_new(AUDIT_RULE_FILE_WATCH, path, 0, key);
}

# Create a syscall watch rule
fn audit_rule_syscall_watch(syscall_nr, key) {
    return audit_rule_new(AUDIT_RULE_SYSCALL_WATCH, 0, syscall_nr, key);
}

# ================================================================
# Rule validation
# Returns Result: Ok(0) if valid, Err if not.
# ================================================================

fn audit_rule_validate(rule) {
    var key = audit_rule_key(rule);
    if (key == 0) {
        return err_invalid_argument("audit rule key cannot be empty");
    }
    var key_len = strlen(key);
    if (key_len == 0) {
        return err_invalid_argument("audit rule key cannot be empty");
    }
    if (key_len > AUDIT_MAX_KEY_LEN) {
        return err_invalid_argument("audit rule key too long (max 256)");
    }

    var rtype = audit_rule_type(rule);
    if (rtype == AUDIT_RULE_FILE_WATCH) {
        var path = audit_rule_path(rule);
        if (path == 0) {
            return err_invalid_argument("FileWatch rule requires a path");
        }
        var path_len = strlen(path);
        if (path_len == 0) {
            return err_invalid_argument("FileWatch path cannot be empty");
        }
        # Path must be absolute (start with '/')
        if (load8(path) != 47) {
            return err_invalid_argument("FileWatch path must be absolute");
        }
        # Reject path traversal via ".." components
        var pi = 0;
        while (pi < path_len - 1) {
            if (load8(path + pi) == 46 && load8(path + pi + 1) == 46) {
                return err_invalid_argument("audit path contains ..");
            }
            pi = pi + 1;
        }
    }
    elif (rtype == AUDIT_RULE_SYSCALL_WATCH) {
        # syscall_nr is stored directly, 0 is a valid syscall (read)
        # so we just accept it
    }
    else {
        return err_invalid_argument("unknown audit rule type");
    }

    return Ok(0);
}

# ================================================================
# sockaddr_nl struct helper
# Layout: { nl_family(u16), nl_pad(u16), nl_pid(u32), nl_groups(u32) }
# Total: 12 bytes
# ================================================================

fn audit_sockaddr_nl(pid) {
    var sa = alloc(12);
    memset(sa, 0, 12);
    store16(sa, AF_NETLINK);  # nl_family
    store32(sa + 4, pid);     # nl_pid
    store32(sa + 8, 0);       # nl_groups
    return sa;
}

# ================================================================
# Build a netlink message header + payload
# Returns pointer to the buffer, stores total length at out_len_ptr.
# nlmsghdr: { u32 len, u16 type, u16 flags, u32 seq, u32 pid }
# ================================================================

fn audit_build_nlmsg(msg_type, payload_ptr, payload_len) {
    var total_len = NLMSG_HDRLEN + payload_len;
    var buf = alloc(total_len);
    memset(buf, 0, total_len);

    # nlmsghdr.nlmsg_len (u32)
    store32(buf, total_len);
    # nlmsghdr.nlmsg_type (u16)
    store16(buf + 4, msg_type);
    # nlmsghdr.nlmsg_flags (u16) = NLM_F_REQUEST
    store16(buf + 6, NLM_F_REQUEST);
    # nlmsghdr.nlmsg_seq (u32) = 1
    store32(buf + 8, 1);
    # nlmsghdr.nlmsg_pid (u32) = our pid
    store32(buf + 12, sys_getpid());

    # Copy payload
    if (payload_len > 0) {
        memcpy(buf + NLMSG_HDRLEN, payload_ptr, payload_len);
    }

    return buf;
}

# Get total length of a built nlmsg (read from the header)
fn audit_nlmsg_len(buf) {
    return load32(buf);
}

# ================================================================
# Open an audit connection
# config: pointer to audit_config struct
# Returns Result: Ok(handle_ptr) or Err.
# ================================================================

fn audit_open(config) {
    var fd = 0 - 1;

    if (audit_config_use_netlink(config) == 1) {
        # socket(AF_NETLINK, SOCK_RAW | SOCK_CLOEXEC, NETLINK_AUDIT)
        var sock_flags = SOCK_RAW | SOCK_CLOEXEC;
        fd = syscall(SYS_SOCKET_NR, AF_NETLINK, sock_flags, NETLINK_AUDIT);
        if (fd < 0) {
            var errno = 0 - fd;
            if (errno == EPERM) {
                return err_permission_denied("open_audit netlink socket");
            }
            if (errno == EACCES) {
                return err_permission_denied("open_audit netlink socket");
            }
            if (errno == EPROTONOSUPPORT) {
                return err_not_supported("NETLINK_AUDIT");
            }
            return err_syscall_failed(errno, "socket(NETLINK_AUDIT) failed");
        }

        # Bind the socket
        var sa = audit_sockaddr_nl(sys_getpid());
        var ret = syscall(SYS_BIND_NR, fd, sa, 12);
        if (ret < 0) {
            sys_close(fd);
            return err_syscall_failed(0 - ret, "bind(NETLINK_AUDIT) failed");
        }
    }

    # Verify proc path if configured
    if (audit_config_use_proc(config) == 1) {
        var proc_path = audit_config_proc_path(config);
        if (sys_access(proc_path, 0) != 0) {
            # Proc path does not exist — warn but continue
            # (non-fatal, just means proc reads will fail)
        }
    }

    var handle = audit_handle_new(fd, config);
    return Ok(handle);
}

# ================================================================
# Close an audit handle
# Closes the netlink socket if open.
# ================================================================

fn audit_close(handle) {
    var fd = audit_handle_fd(handle);
    if (fd >= 0) {
        syscall(SYS_CLOSE, fd);
    }
    return 0;
}

# ================================================================
# Send raw netlink message on audit socket
# Returns Result: Ok(bytes_sent) or Err.
# ================================================================

fn audit_send_raw(handle, buf, buf_len) {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # sendto(fd, buf, len, 0, NULL, 0)
    var ret = syscall(SYS_SENDTO_NR, fd, buf, buf_len, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "send(audit) failed");
    }
    return Ok(ret);
}

# ================================================================
# Receive raw netlink message from audit socket
# buf: receive buffer, buf_len: buffer capacity
# Returns Result: Ok(bytes_received) or Err.
# ================================================================

fn audit_recv_raw(handle, buf, buf_len) {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # recvfrom(fd, buf, len, 0, NULL, NULL)
    var ret = syscall(SYS_RECVFROM_NR, fd, buf, buf_len, 0, 0, 0);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "recv(audit) failed");
    }
    return Ok(ret);
}

# ================================================================
# Send an audit user event
# event_type: C string (e.g. "AGENT_START")
# message: C string payload
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_send_event(handle, event_type, message) {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    if (strlen(event_type) == 0) {
        return err_invalid_argument("event type cannot be empty");
    }

    var msg_len = strlen(message);
    if (msg_len > AUDIT_MAX_MSG_LEN) {
        return err_invalid_argument("audit message too large (max 8192)");
    }

    # Build payload: "op=<event_type> <message>"
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "op=");
    str_builder_add_cstr(sb, event_type);
    str_builder_add_cstr(sb, " ");
    str_builder_add_cstr(sb, message);
    var payload = str_builder_build(sb);

    var payload_data = str_data(payload);
    var payload_len = str_len(payload);

    # Build netlink message with AUDIT_USER type
    var nlmsg = audit_build_nlmsg(AUDIT_USER, payload_data, payload_len);
    var total_len = audit_nlmsg_len(nlmsg);

    var res = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(res) == 1) { return res; }

    return Ok(0);
}

# ================================================================
# Get audit subsystem status (AUDIT_GET)
# Returns Result: Ok(audit_status_ptr) or Err.
# ================================================================

fn audit_get_status(handle) {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # Send AUDIT_GET request (no payload)
    var nlmsg = audit_build_nlmsg(AUDIT_GET, 0, 0);
    var total_len = audit_nlmsg_len(nlmsg);

    var sres = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(sres) == 1) { return sres; }

    # Receive response
    var recv_buf = alloc(4096);
    memset(recv_buf, 0, 4096);

    var rres = audit_recv_raw(handle, recv_buf, 4096);
    if (is_err_result(rres) == 1) { return rres; }

    var nbytes = payload(rres);
    # Minimum: nlmsghdr (16) + at least 24 bytes of audit_status
    if (nbytes < NLMSG_HDRLEN + 24) {
        return err_unknown("AUDIT_GET response too short");
    }

    # Parse audit_status from payload after nlmsghdr
    # struct audit_status layout (first fields, all u32):
    #   offset 0:  mask
    #   offset 4:  enabled
    #   offset 8:  failure
    #   offset 12: pid
    #   offset 16: rate_limit
    #   offset 20: backlog_limit
    #   offset 24: lost
    #   offset 28: backlog
    var pld = recv_buf + NLMSG_HDRLEN;

    var status = audit_status_new();
    store64(status, load32(pld + 4));       # enabled
    store64(status + 8, load32(pld + 8));   # failure_action
    store64(status + 16, load32(pld + 12)); # pid
    store64(status + 24, load32(pld + 20)); # backlog_limit
    store64(status + 32, load32(pld + 24)); # lost
    store64(status + 40, load32(pld + 28)); # backlog

    return Ok(status);
}

# ================================================================
# Enable or disable the audit subsystem (AUDIT_SET)
# enabled: 1 to enable, 0 to disable
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_set_enabled(handle, enabled) {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # Build audit_status payload
    # We set mask=AUDIT_STATUS_ENABLED (1) and enabled field
    var pld_len = 32;
    var pld = alloc(pld_len);
    memset(pld, 0, pld_len);
    store32(pld, AUDIT_STATUS_ENABLED);  # mask
    store32(pld + 4, enabled);           # enabled

    var nlmsg = audit_build_nlmsg(AUDIT_SET, pld, pld_len);
    var total_len = audit_nlmsg_len(nlmsg);

    var res = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(res) == 1) { return res; }

    return Ok(0);
}

# ================================================================
# Send an audit rule message (add or delete)
# msg_type: AUDIT_ADD_RULE or AUDIT_DEL_RULE
# rule: pointer to audit rule struct
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_send_rule_msg(handle, rule, msg_type) {
    var fd = audit_handle_fd(handle);
    if (fd < 0) {
        return err_invalid_argument("audit handle has no netlink socket");
    }

    # Build rule text payload
    var sb = str_builder_new();
    var rtype = audit_rule_type(rule);

    if (rtype == AUDIT_RULE_FILE_WATCH) {
        str_builder_add_cstr(sb, "watch=");
        var path = audit_rule_path(rule);
        if (path != 0) {
            str_builder_add_cstr(sb, path);
        }
        str_builder_add_cstr(sb, " key=");
        str_builder_add_cstr(sb, audit_rule_key(rule));
    }
    elif (rtype == AUDIT_RULE_SYSCALL_WATCH) {
        str_builder_add_cstr(sb, "syscall=");
        str_builder_add_int(sb, audit_rule_syscall(rule));
        str_builder_add_cstr(sb, " key=");
        str_builder_add_cstr(sb, audit_rule_key(rule));
    }

    var rule_text = str_builder_build(sb);
    var rule_data = str_data(rule_text);
    var rule_len = str_len(rule_text);

    var nlmsg = audit_build_nlmsg(msg_type, rule_data, rule_len);
    var total_len = audit_nlmsg_len(nlmsg);

    var res = audit_send_raw(handle, nlmsg, total_len);
    if (is_err_result(res) == 1) { return res; }

    return Ok(0);
}

# ================================================================
# Add an audit rule
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_add_rule(handle, rule) {
    var vres = audit_rule_validate(rule);
    if (is_err_result(vres) == 1) { return vres; }

    return audit_send_rule_msg(handle, rule, AUDIT_ADD_RULE);
}

# ================================================================
# Delete an audit rule
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_delete_rule(handle, rule) {
    var vres = audit_rule_validate(rule);
    if (is_err_result(vres) == 1) { return vres; }

    return audit_send_rule_msg(handle, rule, AUDIT_DEL_RULE);
}

# ================================================================
# Read audit events from /proc/agnos/audit
# Reads the file line-by-line and returns a vec of raw line Str pointers.
# (Full JSON parsing is beyond Cyrius scope — consumers parse the Strs.)
# proc_path: C string path to the proc file
# Returns Result: Ok(vec_of_strs) or Err.
# ================================================================

fn audit_read_proc_events(proc_path) {
    # Check if file exists
    if (sys_access(proc_path, 0) != 0) {
        # File does not exist — return empty vec
        return Ok(vec_new());
    }

    var fd = sys_open(proc_path, O_RDONLY, 0);
    if (fd < 0) {
        return err_io(0 - fd, proc_path);
    }
    defer { sys_close(fd); }

    # Read entire file (up to 64KB)
    var buf_size = 65536;
    var buf = alloc(buf_size + 1);
    memset(buf, 0, buf_size + 1);
    var total_read = 0;

    while (total_read < buf_size) {
        var n = sys_read(fd, buf + total_read, buf_size - total_read);
        if (n <= 0) { break; }
        total_read = total_read + n;
    }

    if (total_read == 0) {
        return Ok(vec_new());
    }

    # Null-terminate
    store8(buf + total_read, 0);

    # Split into lines (by newline = 10)
    var contents = str_new(buf, total_read);
    var lines = str_split(contents, 10);
    var entries = vec_new();

    var line_count = vec_len(lines);
    var li = 0;
    while (li < line_count) {
        var line = vec_get(lines, li);
        var trimmed = str_trim(line);
        if (str_len(trimmed) > 0) {
            vec_push(entries, trimmed);
        }
        li = li + 1;
    }

    return Ok(entries);
}

# ================================================================
# Log via AGNOS custom syscall (SYS_AGNOS_AUDIT_LOG = 520)
# action: C string (max 256 bytes)
# data: C string (max 4096 bytes)
# result_code: integer result code (0 = success)
# Returns Result: Ok(0) or Err.
# ================================================================

fn audit_agnos_log(action, data, result_code) {
    var action_len = strlen(action);
    if (action_len == 0) {
        return err_invalid_argument("audit action cannot be empty");
    }
    if (action_len > 256) {
        return err_invalid_argument("audit action too long (max 256)");
    }

    var data_len = strlen(data);
    if (data_len > 4096) {
        return err_invalid_argument("audit data too long (max 4096)");
    }

    var ret = syscall(SYS_AGNOS_AUDIT_LOG, action, data, result_code);
    if (ret < 0) {
        var errno = 0 - ret;
        if (errno == ENOSYS) {
            return err_not_supported("SYS_AGNOS_AUDIT_LOG");
        }
        if (errno == EPERM) {
            return err_permission_denied("agnos_audit_log");
        }
        return err_syscall_failed(errno, "SYS_AGNOS_AUDIT_LOG failed");
    }

    return Ok(0);
}

# --- pam.cyr ---

# pam.cyr — PAM inspection and user/session management
# Ported from rust-old/src/pam.rs
#
# Provides PAM service enumeration, config parsing, passwd parsing,
# who output parsing, and username validation.
#
# Requires: lib/string.cyr, lib/str.cyr, lib/vec.cyr, lib/fs.cyr,
#           lib/process.cyr, lib/syscalls.cyr, src/error.cyr
#
# All structs are bags of i64 fields accessed via store64/load64.
# Strings are Str (fat pointer: data + length) from lib/str.cyr.

#define LINUX

# ================================================================
# PAM service constants
# ================================================================

enum PamServiceId {
    PAM_SVC_LOGIN = 0;
    PAM_SVC_SUDO = 1;
    PAM_SVC_SSHD = 2;
    PAM_SVC_AGNOS_AGENT = 3;
    PAM_SVC_CUSTOM = 4;
}

# Get the config filename for a PAM service ID.
# Returns a C string pointer.
fn pam_service_name(svc_id) {
    if (svc_id == PAM_SVC_LOGIN) { return "login"; }
    if (svc_id == PAM_SVC_SUDO) { return "sudo"; }
    if (svc_id == PAM_SVC_SSHD) { return "sshd"; }
    if (svc_id == PAM_SVC_AGNOS_AGENT) { return "agnos-agent"; }
    return "unknown";
}

# ================================================================
# PAM rule type constants
# ================================================================

enum PamRuleTypeId {
    PAM_TYPE_AUTH = 0;
    PAM_TYPE_ACCOUNT = 1;
    PAM_TYPE_SESSION = 2;
    PAM_TYPE_PASSWORD = 3;
}

fn pam_rule_type_name(t) {
    if (t == PAM_TYPE_AUTH) { return "auth"; }
    if (t == PAM_TYPE_ACCOUNT) { return "account"; }
    if (t == PAM_TYPE_SESSION) { return "session"; }
    if (t == PAM_TYPE_PASSWORD) { return "password"; }
    return "unknown";
}

# Parse rule type from Str. Returns type id or -1 on error.
fn pam_parse_rule_type(s) {
    if (str_eq(s, str_from("auth")) == 1) { return PAM_TYPE_AUTH; }
    if (str_eq(s, str_from("account")) == 1) { return PAM_TYPE_ACCOUNT; }
    if (str_eq(s, str_from("session")) == 1) { return PAM_TYPE_SESSION; }
    if (str_eq(s, str_from("password")) == 1) { return PAM_TYPE_PASSWORD; }
    return 0 - 1;
}

# ================================================================
# PAM control flag constants
# ================================================================

enum PamControlId {
    PAM_CTL_REQUIRED = 0;
    PAM_CTL_REQUISITE = 1;
    PAM_CTL_SUFFICIENT = 2;
    PAM_CTL_OPTIONAL = 3;
    PAM_CTL_INCLUDE = 4;
}

fn pam_control_name(c) {
    if (c == PAM_CTL_REQUIRED) { return "required"; }
    if (c == PAM_CTL_REQUISITE) { return "requisite"; }
    if (c == PAM_CTL_SUFFICIENT) { return "sufficient"; }
    if (c == PAM_CTL_OPTIONAL) { return "optional"; }
    if (c == PAM_CTL_INCLUDE) { return "include"; }
    return "unknown";
}

# Parse control flag from Str. Returns control id or -1 on error.
fn pam_parse_control(s) {
    if (str_eq(s, str_from("required")) == 1) { return PAM_CTL_REQUIRED; }
    if (str_eq(s, str_from("requisite")) == 1) { return PAM_CTL_REQUISITE; }
    if (str_eq(s, str_from("sufficient")) == 1) { return PAM_CTL_SUFFICIENT; }
    if (str_eq(s, str_from("optional")) == 1) { return PAM_CTL_OPTIONAL; }
    if (str_eq(s, str_from("include")) == 1) { return PAM_CTL_INCLUDE; }
    return 0 - 1;
}

# ================================================================
# PamRule struct: { rule_type, control, module (Str), args (vec of Str) }
# Layout: +0 rule_type, +8 control, +16 module, +24 args. Total: 32 bytes.
# ================================================================

fn pam_rule_new(rule_type, control, module, args) {
    var r = alloc(32);
    store64(r, rule_type);
    store64(r + 8, control);
    store64(r + 16, module);
    store64(r + 24, args);
    return r;
}

fn pam_rule_type(r) { return load64(r); }
fn pam_rule_control(r) { return load64(r + 8); }
fn pam_rule_module(r) { return load64(r + 16); }
fn pam_rule_args(r) { return load64(r + 24); }

# ================================================================
# UserInfo struct: { username (Str), uid, gid, home_dir (Str),
    #                    shell (Str), groups (vec of Str), is_system_user }
# Layout: +0 username, +8 uid, +16 gid, +24 home_dir,
#         +32 shell, +40 groups, +48 is_system_user. Total: 56 bytes.
# ================================================================

fn pam_user_alloc() {
    var u = alloc(56);
    memset(u, 0, 56);
    return u;
}

fn pam_user_set(u, username, uid, gid, home_dir, shell) {
    store64(u, username);
    store64(u + 8, uid);
    store64(u + 16, gid);
    store64(u + 24, home_dir);
    store64(u + 32, shell);
    return u;
}

fn pam_user_set_groups(u, groups, is_system) {
    store64(u + 40, groups);
    store64(u + 48, is_system);
    return u;
}

fn pam_user_username(u) { return load64(u); }
fn pam_user_uid(u) { return load64(u + 8); }
fn pam_user_gid(u) { return load64(u + 16); }
fn pam_user_home(u) { return load64(u + 24); }
fn pam_user_shell(u) { return load64(u + 32); }
fn pam_user_groups(u) { return load64(u + 40); }
fn pam_user_is_system(u) { return load64(u + 48); }

# ================================================================
# SessionInfo struct: { session_id (Str), user (Str), login_time (Str),
    #                       tty (Str or 0), remote_host (Str or 0), pid }
# Layout: +0 session_id, +8 user, +16 login_time, +24 tty,
#         +32 remote_host, +40 pid. Total: 48 bytes.
# ================================================================

fn pam_session_new(session_id, user, login_time, tty, remote_host, pid) {
    var s = alloc(48);
    store64(s, session_id);
    store64(s + 8, user);
    store64(s + 16, login_time);
    store64(s + 24, tty);
    store64(s + 32, remote_host);
    store64(s + 40, pid);
    return s;
}

fn pam_session_id(s) { return load64(s); }
fn pam_session_user(s) { return load64(s + 8); }
fn pam_session_login_time(s) { return load64(s + 16); }
fn pam_session_tty(s) { return load64(s + 24); }
fn pam_session_remote_host(s) { return load64(s + 32); }
fn pam_session_pid(s) { return load64(s + 40); }

# ================================================================
# Username validation
# ================================================================

# Validate a UNIX username.
# Rules: max 32 chars, must start with lowercase letter or underscore,
# may contain lowercase letters, digits, hyphens, underscores.
# Returns Result: Ok(0) on valid, Err on invalid.
fn pam_validate_username(name) {
    var nlen = strlen(name);
    if (nlen == 0) {
        return err_invalid_argument("username cannot be empty");
    }
    if (nlen > 32) {
        return err_invalid_argument("username too long (max 32 chars)");
    }

    # First character must be lowercase letter or underscore
    var first = load8(name);
    var first_ok = 0;
    if (first >= 97) { if (first <= 122) { first_ok = 1; } }  # a-z
    if (first == 95) { first_ok = 1; }  # _
    if (first_ok == 0) {
        return err_invalid_argument("username must start with lowercase letter or underscore");
    }

    # Remaining characters: a-z, 0-9, -, _
    var i = 0;
    while (i < nlen) {
        var ch = load8(name + i);
        var ch_ok = 0;
        if (ch >= 97) { if (ch <= 122) { ch_ok = 1; } }  # a-z
        if (ch >= 48) { if (ch <= 57) { ch_ok = 1; } }    # 0-9
        if (ch == 45) { ch_ok = 1; }   # -
        if (ch == 95) { ch_ok = 1; }   # _
        if (ch_ok == 0) {
            return err_invalid_argument("username contains invalid character");
        }
        i = i + 1;
    }

    return Ok(0);
}

# ================================================================
# Parse a single /etc/passwd line into a UserInfo struct
# ================================================================

# Format: username:x:uid:gid:gecos:home:shell
# Returns Result: Ok(user_info_ptr) or Err.
fn pam_parse_passwd_line(line) {
    # Split by ':'
    var fields = str_split(line, 58);  # 58 = ':'
    if (vec_len(fields) < 7) {
        return err_invalid_argument("malformed passwd line (expected 7 fields)");
    }

    var username = vec_get(fields, 0);
    # fields[1] = password placeholder (x)
    var uid_str = vec_get(fields, 2);
    var gid_str = vec_get(fields, 3);
    # fields[4] = gecos
    var home_dir = vec_get(fields, 5);
    var shell = vec_get(fields, 6);

    var uid = str_to_int(uid_str);
    var gid = str_to_int(gid_str);

    # Validate uid/gid are numeric (str_to_int returns 0 for invalid,
    # but "0" is valid for root — check that string actually looks numeric)
    if (str_len(uid_str) == 0) {
        return err_invalid_argument("invalid UID in passwd line");
    }
    if (str_len(gid_str) == 0) {
        return err_invalid_argument("invalid GID in passwd line");
    }

    # Heuristic: UIDs below 1000 are system users
    var is_system = 0;
    if (uid < 1000) { is_system = 1; }

    var groups = vec_new();
    var user = pam_user_alloc();
    pam_user_set(user, username, uid, gid, home_dir, shell);
    pam_user_set_groups(user, groups, is_system);
    return Ok(user);
}

# ================================================================
# Parse who output into a vec of SessionInfo
# ================================================================

# Typical who output lines:
#   alice    pts/0        2026-03-06 10:30 (192.168.1.5)
#   bob      tty1         2026-03-06 09:15
# Returns vec of session info pointers.
fn pam_parse_who_output(output) {
    var sessions = vec_new();
    var lines = str_split(output, 10);  # 10 = '\n'
    var idx = 0;

    while (idx < vec_len(lines)) {
        var line = str_trim(vec_get(lines, idx));
        if (str_len(line) == 0) {
            idx = idx + 1;
            continue;
        }

        # Split by whitespace (space = 32)
        # who output is whitespace-delimited; we need at least 3 fields
        var parts = pam_split_whitespace(line);
        if (vec_len(parts) < 3) {
            idx = idx + 1;
            continue;
        }

        var user = vec_get(parts, 0);
        var tty = vec_get(parts, 1);

        # Date + time may be in columns 2+3
        var login_time = vec_get(parts, 2);
        if (vec_len(parts) >= 4) {
            var sb = str_builder_new();
            str_builder_add(sb, vec_get(parts, 2));
            str_builder_add_cstr(sb, " ");
            str_builder_add(sb, vec_get(parts, 3));
            login_time = str_builder_build(sb);
        }

        # Remote host is in parens at the end, e.g. "(192.168.1.5)"
        var remote_host = 0;
        var last_part = vec_get(parts, vec_len(parts) - 1);
        if (str_len(last_part) > 2) {
            var ld = str_data(last_part);
            var ll = str_len(last_part);
            if (load8(ld) == 40) {  # '('
                if (load8(ld + ll - 1) == 41) {  # ')'
                    remote_host = str_sub(last_part, 1, ll - 2);
                }
            }
        }

        # session_id = "who-<idx>"
        var sid_sb = str_builder_new();
        str_builder_add_cstr(sid_sb, "who-");
        str_builder_add_int(sid_sb, idx);
        var session_id = str_builder_build(sid_sb);

        var session = pam_session_new(session_id, user, login_time, tty, remote_host, 0);
        vec_push(sessions, session);

        idx = idx + 1;
    }

    return sessions;
}

# Split a Str by whitespace (space/tab), skipping consecutive whitespace.
# Returns vec of Str.
fn pam_split_whitespace(s) {
    var parts = vec_new();
    var slen = str_len(s);
    var sd = str_data(s);
    var start = 0;
    var in_word = 0;
    var i = 0;

    while (i < slen) {
        var ch = load8(sd + i);
        var is_ws = 0;
        if (ch == 32) { is_ws = 1; }   # space
        if (ch == 9) { is_ws = 1; }    # tab

        if (is_ws == 1) {
            if (in_word == 1) {
                vec_push(parts, str_new(sd + start, i - start));
                in_word = 0;
            }
        }
        else {
            if (in_word == 0) {
                start = i;
                in_word = 1;
            }
        }
        i = i + 1;
    }

    # Trailing word
    if (in_word == 1) {
        vec_push(parts, str_new(sd + start, slen - start));
    }

    return parts;
}

# ================================================================
# Parse PAM config file content
# ================================================================

# Parse PAM config text into a vec of PamRule pointers.
# Each non-blank, non-comment line: type control module [args...]
# Returns Result: Ok(vec_of_rules) or Err.
fn pam_parse_config(content) {
    var rules = vec_new();
    var lines = str_split(content, 10);  # 10 = '\n'
    var idx = 0;

    while (idx < vec_len(lines)) {
        var line = str_trim(vec_get(lines, idx));
        if (str_len(line) == 0) {
            idx = idx + 1;
            continue;
        }

        # Skip comments (lines starting with #)
        if (load8(str_data(line)) == 35) {  # '#'
            idx = idx + 1;
            continue;
        }

        var parts = pam_split_whitespace(line);
        if (vec_len(parts) < 3) {
            return err_invalid_argument("malformed PAM rule (need type, control, module)");
        }

        var rule_type = pam_parse_rule_type(vec_get(parts, 0));
        if (rule_type < 0) {
            return err_invalid_argument("unknown PAM rule type");
        }

        var control = pam_parse_control(vec_get(parts, 1));
        if (control < 0) {
            return err_invalid_argument("unknown PAM control flag");
        }

        var module = vec_get(parts, 2);

        # Collect remaining parts as args
        var args = vec_new();
        var ai = 3;
        while (ai < vec_len(parts)) {
            vec_push(args, vec_get(parts, ai));
            ai = ai + 1;
        }

        var rule = pam_rule_new(rule_type, control, module, args);
        vec_push(rules, rule);

        idx = idx + 1;
    }

    return Ok(rules);
}

# ================================================================
# List PAM services (read /etc/pam.d/ directory)
# ================================================================

# Returns Result: Ok(vec_of_Str) — filenames in /etc/pam.d/.
fn pam_list_services() {
    var pam_dir = str_from("/etc/pam.d");
    var entries = dir_list(pam_dir);
    return Ok(entries);
}

# ================================================================
# Read and parse a PAM service config file
# ================================================================

# Read /etc/pam.d/<service_name> and parse it.
# service_name: C string (e.g. "sshd", "sudo").
# Returns Result: Ok(vec_of_rules) or Err.
fn pam_read_service_config(service_name) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "/etc/pam.d/");
    str_builder_add_cstr(sb, service_name);
    var path = str_builder_build(sb);

    # Read the file content
    var fd = sys_open(str_data(path), O_RDONLY, 0);
    if (fd < 0) {
        return err_syscall_failed(0 - fd, "failed to open PAM config file");
    }
    defer { sys_close(fd); }

    var buf = alloc(8192);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = sys_read(fd, buf + total, 8192 - total);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= 8192) { rgo = 0; }
        }
    }

    # Null-terminate and wrap as Str
    store8(buf + total, 0);
    var content = str_new(buf, total);

    return pam_parse_config(content);
}

# ================================================================
# List users from /etc/passwd
# ================================================================

# Read /etc/passwd and return vec of UserInfo pointers.
# Returns Result: Ok(vec) or Err.
fn pam_list_users() {
    var fd = sys_open("/etc/passwd", O_RDONLY, 0);
    if (fd < 0) {
        return err_syscall_failed(0 - fd, "failed to open /etc/passwd");
    }
    defer { sys_close(fd); }

    var buf = alloc(65536);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = sys_read(fd, buf + total, 65536 - total);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= 65536) { rgo = 0; }
        }
    }

    store8(buf + total, 0);
    var content = str_new(buf, total);
    var lines = str_split(content, 10);  # '\n'
    var users = vec_new();

    var idx = 0;
    while (idx < vec_len(lines)) {
        var line = str_trim(vec_get(lines, idx));
        if (str_len(line) == 0) {
            idx = idx + 1;
            continue;
        }
        # Skip comments
        if (load8(str_data(line)) == 35) {
            idx = idx + 1;
            continue;
        }
        var res = pam_parse_passwd_line(line);
        if (is_ok(res) == 1) {
            vec_push(users, payload(res));
        }
        # Skip malformed lines silently
        idx = idx + 1;
    }

    return Ok(users);
}

# ================================================================
# List active sessions via who command
# ================================================================

# Run `who` and parse output into vec of SessionInfo.
# Returns Result: Ok(vec) or Err.
fn pam_list_sessions() {
    var buf = alloc(16384);
    var res = run_capture("/usr/bin/who", 0, 0, buf, 16384);
    if (is_err_result(res) == 1) {
        return err_unknown("failed to run who command");
    }
    var nbytes = payload(res);
    store8(buf + nbytes, 0);
    var output = str_new(buf, nbytes);
    var sessions = pam_parse_who_output(output);
    return Ok(sessions);
}

# ================================================================
# Render PAM rule to string
# ================================================================

# Render a single PamRule to a config-file line (Str).
fn pam_render_rule(rule) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, pam_rule_type_name(pam_rule_type(rule)));
    str_builder_add_cstr(sb, "\t");
    str_builder_add_cstr(sb, pam_control_name(pam_rule_control(rule)));
    str_builder_add_cstr(sb, "\t");
    str_builder_add(sb, pam_rule_module(rule));

    var args = pam_rule_args(rule);
    var ai = 0;
    while (ai < vec_len(args)) {
        str_builder_add_cstr(sb, "\t");
        str_builder_add(sb, vec_get(args, ai));
        ai = ai + 1;
    }

    return str_builder_build(sb);
}

# Render a full PAM config from a vec of PamRule pointers.
# Returns Str.
fn pam_render_config(rules) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "# Generated by AGNOS PAM manager\n");

    var idx = 0;
    while (idx < vec_len(rules)) {
        str_builder_add(sb, pam_render_rule(vec_get(rules, idx)));
        str_builder_add_cstr(sb, "\n");
        idx = idx + 1;
    }

    return str_builder_build(sb);
}

# ================================================================
# Validate a PAM rule
# ================================================================

# Check module path is reasonable and args have no shell metacharacters.
# Returns Result: Ok(0) on valid, Err on invalid.
fn pam_validate_rule(rule) {
    var module = pam_rule_module(rule);
    if (str_len(module) == 0) {
        return err_invalid_argument("PAM module path cannot be empty");
    }

    # Module must not contain ".."
    if (str_contains(module, str_from("..")) == 1) {
        return err_invalid_argument("PAM module path must not contain '..'");
    }

    # Reject shell metacharacters in module name
    # Dangerous chars: | ; & $ ` > < ! { }
    var md = str_data(module);
    var mlen = str_len(module);
    var mi = 0;
    while (mi < mlen) {
        var ch = load8(md + mi);
        if (ch == 124) {
            return err_invalid_argument("PAM module: dangerous char '|'");
        }
        if (ch == 59) {
            return err_invalid_argument("PAM module: dangerous char ';'");
        }
        if (ch == 38) {
            return err_invalid_argument("PAM module: dangerous char '&'");
        }
        if (ch == 36) {
            return err_invalid_argument("PAM module: dangerous char '$'");
        }
        if (ch == 96) {
            return err_invalid_argument("PAM module: dangerous char '`'");
        }
        if (ch == 62) {
            return err_invalid_argument("PAM module: dangerous char '>'");
        }
        if (ch == 60) {
            return err_invalid_argument("PAM module: dangerous char '<'");
        }
        if (ch == 33) {
            return err_invalid_argument("PAM module: dangerous char '!'");
        }
        if (ch == 123) {
            return err_invalid_argument("PAM module: dangerous char '{'");
        }
        if (ch == 125) {
            return err_invalid_argument("PAM module: dangerous char '}'");
        }
        mi = mi + 1;
    }

    # Same check for each argument
    var args = pam_rule_args(rule);
    var ai = 0;
    while (ai < vec_len(args)) {
        var arg = vec_get(args, ai);
        var ad = str_data(arg);
        var alen = str_len(arg);
        var aj = 0;
        while (aj < alen) {
            var ach = load8(ad + aj);
            if (ach == 124) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 59) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 38) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 36) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 96) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 62) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 60) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 33) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 123) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            if (ach == 125) {
                return err_invalid_argument("PAM arg: dangerous char");
            }
            aj = aj + 1;
        }
        ai = ai + 1;
    }

    return Ok(0);
}

# ================================================================
# Get user info by username
# ================================================================

# Lookup a user in /etc/passwd by name.
# Returns Result: Ok(user_info_ptr) or Err.
fn pam_get_user_info(username) {
    var res = pam_validate_username(username);
    if (is_err_result(res) == 1) { return res; }

    var fd = sys_open("/etc/passwd", O_RDONLY, 0);
    if (fd < 0) {
        return err_syscall_failed(0 - fd, "failed to open /etc/passwd");
    }
    defer { sys_close(fd); }

    var buf = alloc(65536);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = sys_read(fd, buf + total, 65536 - total);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= 65536) { rgo = 0; }
        }
    }

    store8(buf + total, 0);
    var content = str_new(buf, total);
    var lines = str_split(content, 10);
    var name_str = str_from(username);

    var idx = 0;
    while (idx < vec_len(lines)) {
        var line = vec_get(lines, idx);
        if (str_len(line) == 0) {
            idx = idx + 1;
            continue;
        }

        # Check if line starts with username:
        var fields = str_split(line, 58);  # ':'
        if (vec_len(fields) >= 1) {
            if (str_eq(vec_get(fields, 0), name_str) == 1) {
                return pam_parse_passwd_line(line);
            }
        }
        idx = idx + 1;
    }

    return err_invalid_argument("user not found");
}

# --- journald.cyr ---

# journald.cyr — systemd journal integration
# Ported from rust-old/src/journald.rs
#
# Send structured log messages to journald via AF_UNIX datagram socket,
# and query the journal via journalctl subprocess.
#
# Requires: lib/string.cyr, lib/str.cyr, lib/vec.cyr, lib/process.cyr,
#           lib/syscalls.cyr, src/error.cyr
#
# All structs are bags of i64 fields accessed via store64/load64.
# Strings are Str (fat pointer: data + length) from lib/str.cyr.

# ================================================================
# Constants
# ================================================================

enum JournalConst {
    # AF_UNIX = 1, SOCK_DGRAM = 2
    AF_UNIX = 1;
    # sendto syscall
    SYS_SENDTO = 44;
    # sockaddr_un: { family(2), path(108) } = 110 bytes
    SOCKADDR_UN_SIZE = 110;
    # Journal socket path length (including null)
    JOURNAL_SOCKET_PATH_LEN = 33;
}

# Syslog priority levels
enum JournalPriority {
    JOURNAL_EMERG = 0;
    JOURNAL_ALERT = 1;
    JOURNAL_CRIT = 2;
    JOURNAL_ERR = 3;
    JOURNAL_WARNING = 4;
    JOURNAL_NOTICE = 5;
    JOURNAL_INFO = 6;
    JOURNAL_DEBUG = 7;
}

# ================================================================
# JournalEntry struct
# { timestamp, unit (Str), priority, message (Str), pid, fields (vec) }
# Layout: +0 timestamp, +8 unit, +16 priority, +24 message,
#         +32 pid, +40 fields_keys (vec), +48 fields_vals (vec).
# Total: 56 bytes.
# ================================================================

fn journald_entry_new(timestamp, unit, priority, message, pid) {
    var e = alloc(56);
    store64(e, timestamp);
    store64(e + 8, unit);
    store64(e + 16, priority);
    store64(e + 24, message);
    store64(e + 32, pid);
    store64(e + 40, vec_new());   # fields keys
    store64(e + 48, vec_new());   # fields values
    return e;
}

fn journald_entry_timestamp(e) { return load64(e); }
fn journald_entry_unit(e) { return load64(e + 8); }
fn journald_entry_priority(e) { return load64(e + 16); }
fn journald_entry_message(e) { return load64(e + 24); }
fn journald_entry_pid(e) { return load64(e + 32); }
fn journald_entry_field_keys(e) { return load64(e + 40); }
fn journald_entry_field_vals(e) { return load64(e + 48); }

# Add an extra field (key-value pair) to a journal entry
fn journald_entry_add_field(e, key, val) {
    vec_push(load64(e + 40), key);
    vec_push(load64(e + 48), val);
    return 0;
}

# ================================================================
# JournalFilter struct
# { unit (Str or 0), since (Str or 0), until (Str or 0),
    #   priority (-1 = unset), grep (Str or 0), lines (-1 = unset),
    #   boot (Str or 0) }
# Layout: +0 unit, +8 since, +16 until, +24 priority,
#         +32 grep, +40 lines, +48 boot. Total: 56 bytes.
# ================================================================

fn journald_filter_new() {
    var f = alloc(56);
    store64(f, 0);          # unit
    store64(f + 8, 0);      # since
    store64(f + 16, 0);     # until
    store64(f + 24, 0 - 1); # priority (unset)
    store64(f + 32, 0);     # grep
    store64(f + 40, 0 - 1); # lines (unset)
    store64(f + 48, 0);     # boot
    return f;
}

fn journald_filter_set_unit(f, unit) { store64(f, unit); return 0; }
fn journald_filter_set_since(f, since) { store64(f + 8, since); return 0; }
fn journald_filter_set_until(f, until) { store64(f + 16, until); return 0; }
fn journald_filter_set_priority(f, prio) { store64(f + 24, prio); return 0; }
fn journald_filter_set_grep(f, grep) { store64(f + 32, grep); return 0; }
fn journald_filter_set_lines(f, lines) { store64(f + 40, lines); return 0; }
fn journald_filter_set_boot(f, boot) { store64(f + 48, boot); return 0; }

fn journald_filter_unit(f) { return load64(f); }
fn journald_filter_since(f) { return load64(f + 8); }
fn journald_filter_until(f) { return load64(f + 16); }
fn journald_filter_priority(f) { return load64(f + 24); }
fn journald_filter_grep(f) { return load64(f + 32); }
fn journald_filter_lines(f) { return load64(f + 40); }
fn journald_filter_boot(f) { return load64(f + 48); }

# ================================================================
# Build journalctl argument string
# ================================================================

# Build the argument list for a journalctl invocation from a filter.
# Returns a Str with all arguments space-separated (for run_capture).
# Note: since run_capture uses _exec3 with only 2 extra args, we build
# a single combined argument string and use /bin/sh -c for complex queries.
fn journald_build_args(filter) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "journalctl --output=json --no-pager");

    var unit = load64(filter);
    if (unit != 0) {
        str_builder_add_cstr(sb, " --unit=");
        str_builder_add(sb, unit);
    }

    var since = load64(filter + 8);
    if (since != 0) {
        str_builder_add_cstr(sb, " --since=");
        str_builder_add(sb, since);
    }

    var until = load64(filter + 16);
    if (until != 0) {
        str_builder_add_cstr(sb, " --until=");
        str_builder_add(sb, until);
    }

    var prio = load64(filter + 24);
    if (prio >= 0) {
        str_builder_add_cstr(sb, " --priority=");
        str_builder_add_int(sb, prio);
    }

    var grep = load64(filter + 32);
    if (grep != 0) {
        str_builder_add_cstr(sb, " --grep=");
        str_builder_add(sb, grep);
    }

    var lines = load64(filter + 40);
    if (lines >= 0) {
        str_builder_add_cstr(sb, " --lines=");
        str_builder_add_int(sb, lines);
    }

    var boot = load64(filter + 48);
    if (boot != 0) {
        str_builder_add_cstr(sb, " --boot=");
        str_builder_add(sb, boot);
    }

    return str_builder_build(sb);
}

# ================================================================
# Send structured log message to journald via unix socket
# ================================================================

# Build a sockaddr_un pointing to /run/systemd/journal/socket.
# Returns pointer to the struct (110 bytes).
fn journald_make_sockaddr() {
    var sa = alloc(SOCKADDR_UN_SIZE);
    memset(sa, 0, SOCKADDR_UN_SIZE);
    store16(sa, AF_UNIX);  # sa_family = AF_UNIX
    # Copy socket path starting at offset 2
    var path = "/run/systemd/journal/socket";
    var plen = strlen(path);
    memcpy(sa + 2, path, plen);
    return sa;
}

# Send a structured log message to the journald socket.
# message: C string — the log message text.
# priority: integer 0-7 (JOURNAL_EMERG through JOURNAL_DEBUG).
# identifier: C string — syslog identifier (e.g. "agnosys").
#
# The journal native protocol uses newline-separated KEY=VALUE pairs
# sent as a single datagram to /run/systemd/journal/socket.
#
# Returns Result: Ok(0) on success, Err on failure.
fn journald_send(message, priority, identifier) {
    if (message == 0) {
        return err_invalid_argument("journal message cannot be null");
    }
    if (priority < 0) {
        return err_invalid_argument("journal priority must be 0-7");
    }
    if (priority > 7) {
        return err_invalid_argument("journal priority must be 0-7");
    }

    # Build the datagram payload: KEY=VALUE\n pairs
    var sb = str_builder_new();

    # PRIORITY=<n>
    str_builder_add_cstr(sb, "PRIORITY=");
    str_builder_add_int(sb, priority);
    str_builder_add_cstr(sb, "\n");

    # MESSAGE=<text>
    str_builder_add_cstr(sb, "MESSAGE=");
    str_builder_add_cstr(sb, message);
    str_builder_add_cstr(sb, "\n");

    # SYSLOG_IDENTIFIER=<id>
    if (identifier != 0) {
        str_builder_add_cstr(sb, "SYSLOG_IDENTIFIER=");
        str_builder_add_cstr(sb, identifier);
        str_builder_add_cstr(sb, "\n");
    }

    var payload = str_builder_build(sb);

    # Create AF_UNIX SOCK_DGRAM socket
    var SYS_SOCKET = 41;
    var fd = syscall(SYS_SOCKET, AF_UNIX, 2, 0);  # SOCK_DGRAM = 2
    if (fd < 0) {
        return err_syscall_failed(0 - fd, "failed to create unix socket");
    }
    defer { sys_close(fd); }

    # Build sockaddr_un
    var sa = journald_make_sockaddr();

    # sendto(fd, buf, len, flags, dest_addr, addrlen)
    var ret = syscall(SYS_SENDTO, fd, str_data(payload), str_len(payload), 0, sa, SOCKADDR_UN_SIZE);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "sendto journal socket failed");
    }

    return Ok(0);
}

# Send a structured log with extra key-value fields.
# fields_keys: vec of C string pointers (field names).
# fields_vals: vec of C string pointers (field values).
# Returns Result: Ok(0) or Err.
fn journald_send_fields(message, priority, identifier, fields_keys, fields_vals) {
    if (message == 0) {
        return err_invalid_argument("journal message cannot be null");
    }
    if (priority < 0) {
        return err_invalid_argument("journal priority must be 0-7");
    }
    if (priority > 7) {
        return err_invalid_argument("journal priority must be 0-7");
    }

    var sb = str_builder_new();

    str_builder_add_cstr(sb, "PRIORITY=");
    str_builder_add_int(sb, priority);
    str_builder_add_cstr(sb, "\n");

    str_builder_add_cstr(sb, "MESSAGE=");
    str_builder_add_cstr(sb, message);
    str_builder_add_cstr(sb, "\n");

    if (identifier != 0) {
        str_builder_add_cstr(sb, "SYSLOG_IDENTIFIER=");
        str_builder_add_cstr(sb, identifier);
        str_builder_add_cstr(sb, "\n");
    }

    # Append extra fields (skip keys containing newline to prevent injection)
    var nfields = vec_len(fields_keys);
    var fi = 0;
    while (fi < nfields) {
        var fkey = vec_get(fields_keys, fi);
        var fkey_len = strlen(fkey);
        var fkey_valid = 1;
        var fki = 0;
        while (fki < fkey_len) {
            if (load8(fkey + fki) == 10) {
                fkey_valid = 0;
                fki = fkey_len;  # break
            }
            fki = fki + 1;
        }
        if (fkey_valid == 1) {
            str_builder_add_cstr(sb, fkey);
            str_builder_add_cstr(sb, "=");
            str_builder_add_cstr(sb, vec_get(fields_vals, fi));
            str_builder_add_cstr(sb, "\n");
        }
        fi = fi + 1;
    }

    var payload = str_builder_build(sb);

    var SYS_SOCKET = 41;
    var fd = syscall(SYS_SOCKET, AF_UNIX, 2, 0);
    if (fd < 0) {
        return err_syscall_failed(0 - fd, "failed to create unix socket");
    }
    defer { sys_close(fd); }

    var sa = journald_make_sockaddr();
    var ret = syscall(SYS_SENDTO, fd, str_data(payload), str_len(payload), 0, sa, SOCKADDR_UN_SIZE);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "sendto journal socket failed");
    }

    return Ok(0);
}

# ================================================================
# Parse a single JSON line from journalctl --output=json
# ================================================================

# Minimal JSON field extraction: find a key in a JSON object string
# and extract the string value. Returns Str or 0 if not found.
# This is a lightweight parser — handles flat JSON objects only.
fn journald_json_get_str(json, key) {
    # Search for "key" in the JSON
    var jlen = str_len(json);
    var jd = str_data(json);
    var klen = strlen(key);

    var pos = 0;
    while (pos < jlen - klen - 3) {
        # Look for "<key>"
        if (load8(jd + pos) == 34) {  # '"'
            if (memeq(jd + pos + 1, key, klen) == 1) {
                if (load8(jd + pos + 1 + klen) == 34) {  # closing '"'
                    # Found the key. Now find the value after ':'
                    var vpos = pos + 2 + klen;
                    # Skip whitespace and colon
                    while (vpos < jlen) {
                        var vc = load8(jd + vpos);
                        if (vc == 58) { vpos = vpos + 1; break; }  # ':'
                        if (vc == 32) { vpos = vpos + 1; continue; }
                        if (vc == 9) { vpos = vpos + 1; continue; }
                        break;
                    }
                    # Skip whitespace
                    while (vpos < jlen) {
                        var wc = load8(jd + vpos);
                        if (wc == 32) { vpos = vpos + 1; continue; }
                        if (wc == 9) { vpos = vpos + 1; continue; }
                        if (wc == 10) { vpos = vpos + 1; continue; }
                        break;
                    }
                    # Value should start with '"'
                    if (vpos < jlen) {
                        if (load8(jd + vpos) == 34) {
                            # Find closing '"'
                            var vstart = vpos + 1;
                            var vend = vstart;
                            while (vend < jlen) {
                                if (load8(jd + vend) == 34) { break; }
                                # Skip escaped characters
                                if (load8(jd + vend) == 92) { vend = vend + 1; }  # '\'
                                vend = vend + 1;
                            }
                            return str_new(jd + vstart, vend - vstart);
                        }
                    }
                }
            }
        }
        pos = pos + 1;
    }

    return 0;
}

# Parse a single JSON line from journalctl output into a JournalEntry.
# Returns Result: Ok(entry_ptr) or Err.
fn journald_parse_json(json_line) {
    var jlen = str_len(json_line);
    if (jlen == 0) {
        return err_invalid_argument("empty journal JSON line");
    }

    # Check it starts with open brace (ASCII 123)
    if (load8(str_data(json_line)) != 123) {
        return err_invalid_argument("journal JSON is not an object");
    }

    # Extract known fields
    var ts_str = journald_json_get_str(json_line, "__REALTIME_TIMESTAMP");
    var timestamp = 0;
    if (ts_str != 0) {
        timestamp = str_to_int(ts_str);
    }

    var unit = journald_json_get_str(json_line, "_SYSTEMD_UNIT");
    if (unit == 0) { unit = str_from(""); }

    var prio_str = journald_json_get_str(json_line, "PRIORITY");
    var priority = JOURNAL_INFO;  # default
    if (prio_str != 0) {
        priority = str_to_int(prio_str);
    }

    var message = journald_json_get_str(json_line, "MESSAGE");
    if (message == 0) { message = str_from(""); }

    var pid_str = journald_json_get_str(json_line, "_PID");
    var pid = 0;
    if (pid_str != 0) {
        pid = str_to_int(pid_str);
    }

    var entry = journald_entry_new(timestamp, unit, priority, message, pid);
    return Ok(entry);
}

# ================================================================
# Query journal via journalctl subprocess
# ================================================================

# Query the systemd journal using journalctl and parse JSON output.
# filter: JournalFilter pointer (from journald_filter_new).
# Returns Result: Ok(vec_of_entry_ptrs) or Err.
fn journald_query(filter) {
    var cmd_str = journald_build_args(filter);

    # Use /bin/sh -c "<cmd>" to execute the full command
    var buf = alloc(131072);  # 128KB capture buffer
    var res = run_capture("/bin/sh", "-c", str_data(cmd_str), buf, 131072);
    if (is_err_result(res) == 1) {
        return err_unknown("failed to execute journalctl");
    }

    var nbytes = payload(res);
    store8(buf + nbytes, 0);
    var output = str_new(buf, nbytes);

    # Parse each JSON line
    var entries = vec_new();
    var lines = str_split(output, 10);  # '\n'
    var idx = 0;

    while (idx < vec_len(lines)) {
        var line = str_trim(vec_get(lines, idx));
        if (str_len(line) == 0) {
            idx = idx + 1;
            continue;
        }

        var parse_res = journald_parse_json(line);
        if (is_ok(parse_res) == 1) {
            vec_push(entries, payload(parse_res));
        }
        # Skip unparseable lines silently

        idx = idx + 1;
    }

    return Ok(entries);
}

# ================================================================
# Convenience: get last N log entries for a unit
# ================================================================

# Get the last `lines` journal entries for a specific systemd unit.
# unit_name: C string (e.g. "sshd.service").
# lines: number of entries to return.
# Returns Result: Ok(vec_of_entry_ptrs) or Err.
fn journald_get_unit_logs(unit_name, lines) {
    if (unit_name == 0) {
        return err_invalid_argument("unit name cannot be null");
    }
    if (strlen(unit_name) == 0) {
        return err_invalid_argument("unit name cannot be empty");
    }

    var filter = journald_filter_new();
    journald_filter_set_unit(filter, str_from(unit_name));
    journald_filter_set_lines(filter, lines);

    return journald_query(filter);
}

# ================================================================
# Convenience: send info-level log
# ================================================================

# Send an info-level message to the journal.
# message: C string.
# Returns Result: Ok(0) or Err.
fn journald_info(message) {
    return journald_send(message, JOURNAL_INFO, "agnosys");
}

# Send a warning-level message to the journal.
fn journald_warning(message) {
    return journald_send(message, JOURNAL_WARNING, "agnosys");
}

# Send an error-level message to the journal.
fn journald_error(message) {
    return journald_send(message, JOURNAL_ERR, "agnosys");
}

# Send a debug-level message to the journal.
fn journald_debug(message) {
    return journald_send(message, JOURNAL_DEBUG, "agnosys");
}

# --- luks.cyr ---

# luks.cyr — LUKS2 encrypted volume management
# Ported from rust-old/src/luks.rs
#
# Per-agent LUKS2-encrypted loopback volumes for encrypted-at-rest sandbox
# storage. Shells out to `cryptsetup` (standard tool from the cryptsetup
# package), `fallocate`, `losetup`, `mkfs.*`, `mount`, and `umount`.
#
# Requires: lib/syscalls.cyr, lib/process.cyr, lib/string.cyr, lib/vec.cyr,
#           lib/alloc.cyr, lib/fmt.cyr, src/error.cyr

#define LINUX

# ================================================================
# Constants
# ================================================================

enum LuksFilesystem {
    LUKS_FS_EXT4 = 0;
    LUKS_FS_XFS = 1;
    LUKS_FS_BTRFS = 2;
}

enum LuksPbkdf {
    LUKS_PBKDF_ARGON2ID = 0;
    LUKS_PBKDF_PBKDF2 = 1;
}

enum LuksConst {
    LUKS_MIN_SIZE_MB = 4;
    LUKS_MAX_SIZE_MB = 1048576;
    LUKS_KEY_MAX_BYTES = 1024;
    LUKS_NAME_MAX_LEN = 128;
    LUKS_DEFAULT_SIZE_MB = 256;
    LUKS_DEFAULT_KEY_BITS = 512;
    SYS_GETRANDOM = 318;
}

# ================================================================
# LuksConfig struct
# Layout: name(+0) backing_path(+8) size_mb(+16) mount_point(+24)
#         filesystem(+32) cipher_algo(+40) cipher_mode(+48)
#         key_size_bits(+56) pbkdf(+64)
# Total: 72 bytes
# ================================================================

fn luks_config_alloc() {
    var c = alloc(72);
    memset(c, 0, 72);
    return c;
}

fn luks_config_set_core(c, name, backing_path, size_mb, mount_point, filesystem) {
    store64(c, name);
    store64(c + 8, backing_path);
    store64(c + 16, size_mb);
    store64(c + 24, mount_point);
    store64(c + 32, filesystem);
    return c;
}

fn luks_config_set_crypto(c, cipher_algo, cipher_mode, key_size_bits, pbkdf) {
    store64(c + 40, cipher_algo);
    store64(c + 48, cipher_mode);
    store64(c + 56, key_size_bits);
    store64(c + 64, pbkdf);
    return c;
}

fn luks_config_name(c) { return load64(c); }
fn luks_config_backing_path(c) { return load64(c + 8); }
fn luks_config_size_mb(c) { return load64(c + 16); }
fn luks_config_mount_point(c) { return load64(c + 24); }
fn luks_config_filesystem(c) { return load64(c + 32); }
fn luks_config_cipher_algo(c) { return load64(c + 40); }
fn luks_config_cipher_mode(c) { return load64(c + 48); }
fn luks_config_key_size_bits(c) { return load64(c + 56); }
fn luks_config_pbkdf(c) { return load64(c + 64); }

# Create a default config with sensible defaults (AES-XTS, 512-bit, Argon2id)
fn luks_config_default(name, backing_path, mount_point) {
    var c = luks_config_alloc();
    luks_config_set_core(c, name, backing_path, LUKS_DEFAULT_SIZE_MB, mount_point, LUKS_FS_EXT4);
    luks_config_set_crypto(c, "aes", "xts-plain64", LUKS_DEFAULT_KEY_BITS, LUKS_PBKDF_ARGON2ID);
    return c;
}

# ================================================================
# Filesystem string helpers
# ================================================================

fn luks_fs_as_str(fs) {
    if (fs == LUKS_FS_EXT4) { return "ext4"; }
    if (fs == LUKS_FS_XFS) { return "xfs"; }
    if (fs == LUKS_FS_BTRFS) { return "btrfs"; }
    return "ext4";
}

fn luks_fs_mkfs_cmd(fs) {
    if (fs == LUKS_FS_EXT4) { return "/usr/sbin/mkfs.ext4"; }
    if (fs == LUKS_FS_XFS) { return "/usr/sbin/mkfs.xfs"; }
    if (fs == LUKS_FS_BTRFS) { return "/usr/sbin/mkfs.btrfs"; }
    return "/usr/sbin/mkfs.ext4";
}

fn luks_pbkdf_as_str(pbkdf) {
    if (pbkdf == LUKS_PBKDF_ARGON2ID) { return "argon2id"; }
    if (pbkdf == LUKS_PBKDF_PBKDF2) { return "pbkdf2"; }
    return "argon2id";
}

# ================================================================
# Validation helpers
# ================================================================

# Check if a byte is alphanumeric, dash, or underscore
fn luks_is_name_char(ch) {
    if (ch >= 48 && ch <= 57) { return 1; }   # 0-9
    if (ch >= 65 && ch <= 90) { return 1; }   # A-Z
    if (ch >= 97 && ch <= 122) { return 1; }  # a-z
    if (ch == 45) { return 1; }                # -
    if (ch == 95) { return 1; }                # _
    return 0;
}

# Validate a LuksConfig. Returns Ok(0) or Err.
fn luks_config_validate(config) {
    var name = luks_config_name(config);
    var namelen = strlen(name);

    if (namelen == 0) {
        return err_invalid_argument("LUKS volume name cannot be empty");
    }
    if (namelen > LUKS_NAME_MAX_LEN) {
        return err_invalid_argument("LUKS volume name too long (max 128)");
    }

    # Check name characters
    var i = 0;
    while (i < namelen) {
        var ch = load8(name + i);
        if (luks_is_name_char(ch) == 0) {
            return err_invalid_argument("LUKS volume name contains invalid characters");
        }
        i = i + 1;
    }

    var size = luks_config_size_mb(config);
    if (size < LUKS_MIN_SIZE_MB) {
        return err_invalid_argument("LUKS volume must be at least 4 MB");
    }
    if (size > LUKS_MAX_SIZE_MB) {
        return err_invalid_argument("LUKS volume exceeds maximum size of 1 TB");
    }

    var key_bits = luks_config_key_size_bits(config);
    if (key_bits != 256 && key_bits != 512) {
        return err_invalid_argument("Invalid key size (must be 256 or 512)");
    }

    return Ok(0);
}

# ================================================================
# Key generation via getrandom(2)
# ================================================================

# Generate a random key of `size` bytes. Returns Ok(ptr) or Err.
# The returned pointer points to `size` bytes of random data.
fn luks_generate_key(size) {
    if (size == 0) {
        return err_invalid_argument("Key size must be > 0");
    }
    if (size > LUKS_KEY_MAX_BYTES) {
        return err_invalid_argument("Key size too large (max 1024 bytes)");
    }

    var buf = alloc(size);
    memset(buf, 0, size);

    var filled = 0;
    while (filled < size) {
        var ret = syscall(SYS_GETRANDOM, buf + filled, size - filled, 0);
        if (ret < 0) {
            return err_syscall_failed(0 - ret, "getrandom failed");
        }
        filled = filled + ret;
    }

    return Ok(buf);
}

# Zeroize key material in memory
fn luks_zeroize_key(key_ptr, size) {
    memset(key_ptr, 0, size);
    return 0;
}

# ================================================================
# Build cipher string for cryptsetup (e.g., "aes-xts-plain64")
# ================================================================

fn luks_cipher_str(config) {
    var algo = luks_config_cipher_algo(config);
    var mode = luks_config_cipher_mode(config);
    var alen = strlen(algo);
    var mlen = strlen(mode);
    var total = alen + 1 + mlen + 1;
    var buf = alloc(total);
    memcpy(buf, algo, alen);
    store8(buf + alen, 45);  # '-'
    memcpy(buf + alen + 1, mode, mlen);
    store8(buf + alen + 1 + mlen, 0);
    return buf;
}

# ================================================================
# Keyfile helpers — per-PID temp file for key material
# ================================================================

# Build a per-PID keyfile path: /tmp/.agnos-luks-<pid>
fn luks_keyfile_path() {
    var pid = sys_getpid();
    var pid_buf[24];
    var pid_len = fmt_int_buf(pid, &pid_buf);
    var prefix = "/tmp/.agnos-luks-";
    var prefix_len = strlen(prefix);
    var path = alloc(prefix_len + pid_len + 1);
    memcpy(path, prefix, prefix_len);
    memcpy(path + prefix_len, &pid_buf, pid_len);
    store8(path + prefix_len + pid_len, 0);
    return path;
}

# Write key material to a per-PID keyfile.
# Returns Ok(keyfile_path) or Err.
fn luks_write_keyfile(key_ptr, key_len) {
    var keyfile = luks_keyfile_path();
    var fd = sys_open(keyfile, O_WRONLY | O_CREAT | O_TRUNC, 384);  # 0600
    if (fd < 0) {
        return err_syscall_failed(0 - fd, "failed to create keyfile");
    }
    defer { sys_close(fd); }
    var wret = sys_write(fd, key_ptr, key_len);
    if (wret < 0) {
        return err_syscall_failed(0 - wret, "write keyfile failed");
    }
    return Ok(keyfile);
}

# ================================================================
# LUKS operations — shells out to cryptsetup, losetup, etc.
# ================================================================

# Helper: build argv vec and run with exec_capture, return Ok(bytes_read) or Err
fn luks_run_capture(args, buf, buflen) {
    var n = exec_capture(args, buf, buflen);
    if (n < 0) {
        return err_unknown("command execution failed");
    }
    return Ok(n);
}

# Helper: build argv vec and run, return Ok(exit_code) or Err
fn luks_run_checked(args) {
    var rc = exec_vec(args);
    if (rc != 0) {
        return err_unknown("command failed with non-zero exit");
    }
    return Ok(0);
}

# Format a LUKS2 encrypted volume.
# Steps: 1) fallocate backing file 2) losetup 3) cryptsetup luksFormat
# key_ptr: pointer to key bytes, key_len: key length
# Returns Ok(loop_device_str) or Err.
fn luks_format(config, key_ptr, key_len) {
    var res = luks_config_validate(config);
    if (is_err_result(res) == 1) { return res; }

    var backing = luks_config_backing_path(config);
    var size_mb = luks_config_size_mb(config);
    var size_bytes = size_mb * 1024 * 1024;

    # 1. fallocate backing file
    var size_buf[24];
    var slen = fmt_int_buf(size_bytes, &size_buf);

    var fa_args = vec_new();
    vec_push(fa_args, "/usr/bin/fallocate");
    vec_push(fa_args, "-l");
    vec_push(fa_args, &size_buf);
    vec_push(fa_args, backing);

    var fa_res = luks_run_checked(fa_args);
    if (is_err_result(fa_res) == 1) { return fa_res; }

    # 2. losetup --find --show <backing>
    var lo_args = vec_new();
    vec_push(lo_args, "/usr/sbin/losetup");
    vec_push(lo_args, "--find");
    vec_push(lo_args, "--show");
    vec_push(lo_args, backing);

    var lobuf[256];
    memset(&lobuf, 0, 256);
    var lo_res = luks_run_capture(lo_args, &lobuf, 255);
    if (is_err_result(lo_res) == 1) { return lo_res; }

    # Trim trailing newline from loop device path
    var lolen = strlen(&lobuf);
    if (lolen > 0 && load8(&lobuf + lolen - 1) == 10) {
        store8(&lobuf + lolen - 1, 0);
        lolen = lolen - 1;
    }

    # Copy loop device path to heap
    var loop_dev = alloc(lolen + 1);
    memcpy(loop_dev, &lobuf, lolen + 1);

    # 3. cryptsetup luksFormat
    var cipher = luks_cipher_str(config);
    var key_bits = luks_config_key_size_bits(config);
    var kbuf[24];
    var klen = fmt_int_buf(key_bits, &kbuf);
    var pbkdf = luks_pbkdf_as_str(luks_config_pbkdf(config));

    # Write key to a per-PID temp file for --key-file
    var kf_res = luks_write_keyfile(key_ptr, key_len);
    if (is_err_result(kf_res) == 1) { return kf_res; }
    var keyfile = payload(kf_res);
    defer { sys_unlink(keyfile); }

    var cs_args = vec_new();
    vec_push(cs_args, "/usr/sbin/cryptsetup");
    vec_push(cs_args, "luksFormat");
    vec_push(cs_args, "--type");
    vec_push(cs_args, "luks2");
    vec_push(cs_args, "--cipher");
    vec_push(cs_args, cipher);
    vec_push(cs_args, "--key-size");
    vec_push(cs_args, &kbuf);
    vec_push(cs_args, "--pbkdf");
    vec_push(cs_args, pbkdf);
    vec_push(cs_args, "--batch-mode");
    vec_push(cs_args, "--key-file");
    vec_push(cs_args, keyfile);
    vec_push(cs_args, loop_dev);

    var cs_res = luks_run_checked(cs_args);
    if (is_err_result(cs_res) == 1) {
        # Detach loop on failure
        var det_args = vec_new();
        vec_push(det_args, "/usr/sbin/losetup");
        vec_push(det_args, "-d");
        vec_push(det_args, loop_dev);
        exec_vec(det_args);
        return cs_res;
    }

    return Ok(loop_dev);
}

# Open (unlock) a LUKS volume. Maps to /dev/mapper/{name}.
# key_ptr/key_len: key material.
# Returns Ok(mapper_path_ptr) or Err.
fn luks_open(config, key_ptr, key_len) {
    var res = luks_config_validate(config);
    if (is_err_result(res) == 1) { return res; }

    var name = luks_config_name(config);
    var backing = luks_config_backing_path(config);

    # Find or attach loop device
    var lo_args = vec_new();
    vec_push(lo_args, "/usr/sbin/losetup");
    vec_push(lo_args, "--find");
    vec_push(lo_args, "--show");
    vec_push(lo_args, backing);

    var lobuf[256];
    memset(&lobuf, 0, 256);
    var lo_res = luks_run_capture(lo_args, &lobuf, 255);
    if (is_err_result(lo_res) == 1) { return lo_res; }

    var lolen = strlen(&lobuf);
    if (lolen > 0 && load8(&lobuf + lolen - 1) == 10) {
        store8(&lobuf + lolen - 1, 0);
        lolen = lolen - 1;
    }
    var loop_dev = alloc(lolen + 1);
    memcpy(loop_dev, &lobuf, lolen + 1);

    # Write key to per-PID temp file
    var kf_res = luks_write_keyfile(key_ptr, key_len);
    if (is_err_result(kf_res) == 1) { return kf_res; }
    var keyfile = payload(kf_res);
    defer { sys_unlink(keyfile); }

    # cryptsetup open --type luks2 --key-file <keyfile> <loop_dev> <name>
    var cs_args = vec_new();
    vec_push(cs_args, "/usr/sbin/cryptsetup");
    vec_push(cs_args, "open");
    vec_push(cs_args, "--type");
    vec_push(cs_args, "luks2");
    vec_push(cs_args, "--key-file");
    vec_push(cs_args, keyfile);
    vec_push(cs_args, loop_dev);
    vec_push(cs_args, name);

    var cs_res = luks_run_checked(cs_args);
    if (is_err_result(cs_res) == 1) { return cs_res; }

    # Build /dev/mapper/<name>
    var prefix = "/dev/mapper/";
    var plen = strlen(prefix);
    var nlen = strlen(name);
    var mapper = alloc(plen + nlen + 1);
    memcpy(mapper, prefix, plen);
    memcpy(mapper + plen, name, nlen);
    store8(mapper + plen + nlen, 0);

    return Ok(mapper);
}

# Close (lock) a LUKS volume. Closes the dm-crypt mapping.
# name: volume name (string pointer).
# Returns Ok(0) or Err.
fn luks_close(name) {
    if (strlen(name) == 0) {
        return err_invalid_argument("Volume name cannot be empty");
    }

    # Check if /dev/mapper/<name> exists via sys_access
    var prefix = "/dev/mapper/";
    var plen = strlen(prefix);
    var nlen = strlen(name);
    var mapper = alloc(plen + nlen + 1);
    memcpy(mapper, prefix, plen);
    memcpy(mapper + plen, name, nlen);
    store8(mapper + plen + nlen, 0);

    var acc = syscall(SYS_ACCESS, mapper, 0);
    if (acc < 0) {
        # Not open, nothing to close
        return Ok(0);
    }

    var args = vec_new();
    vec_push(args, "/usr/sbin/cryptsetup");
    vec_push(args, "close");
    vec_push(args, name);

    return luks_run_checked(args);
}

# Create a filesystem on a device.
# device: path to device (e.g., /dev/mapper/name)
# filesystem: LUKS_FS_EXT4 / LUKS_FS_XFS / LUKS_FS_BTRFS
# Returns Ok(0) or Err.
fn luks_mkfs(device, filesystem) {
    var cmd = luks_fs_mkfs_cmd(filesystem);

    var args = vec_new();
    vec_push(args, cmd);
    # -F for ext4, -f for xfs/btrfs (force)
    if (filesystem == LUKS_FS_EXT4) {
        vec_push(args, "-F");
    } else {
        vec_push(args, "-f");
    }
    vec_push(args, device);

    return luks_run_checked(args);
}

# Mount a device at a mount point.
# device: path to block device
# mount_point: path to mount directory
# filesystem: LUKS_FS_* constant
# Returns Ok(0) or Err.
fn luks_mount(device, mount_point, filesystem) {
    # Create mount point directory
    var mk_args = vec_new();
    vec_push(mk_args, "/usr/bin/mkdir");
    vec_push(mk_args, "-p");
    vec_push(mk_args, mount_point);
    exec_vec(mk_args);

    var fs_str = luks_fs_as_str(filesystem);

    var args = vec_new();
    vec_push(args, "/usr/bin/mount");
    vec_push(args, "-t");
    vec_push(args, fs_str);
    vec_push(args, device);
    vec_push(args, mount_point);

    return luks_run_checked(args);
}

# Unmount a mount point.
# Returns Ok(0) or Err.
fn luks_unmount(mount_point) {
    var args = vec_new();
    vec_push(args, "/usr/bin/umount");
    vec_push(args, mount_point);

    return luks_run_checked(args);
}

# --- dmverity.cyr ---

# dmverity.cyr — dm-verity rootfs integrity interface
# Ported from rust-old/src/dmverity.rs
#
# Userland wrappers for dm-verity — verifies read-only rootfs integrity at the
# block level. Shells out to `veritysetup` (part of the cryptsetup package).
#
# Requires: lib/syscalls.cyr, lib/process.cyr, lib/string.cyr, lib/vec.cyr,
#           lib/alloc.cyr, lib/fmt.cyr, src/error.cyr

#define LINUX

# ================================================================
# Constants
# ================================================================

enum VerityHashAlgo {
    VERITY_SHA256 = 0;
    VERITY_SHA512 = 1;
}

enum VerityConst {
    VERITY_NAME_MAX_LEN = 128;
    VERITY_SHA256_HEX_LEN = 64;
    VERITY_SHA512_HEX_LEN = 128;
}

# ================================================================
# Hash algorithm helpers
# ================================================================

fn dmverity_hash_algo_str(algo) {
    if (algo == VERITY_SHA256) { return "sha256"; }
    if (algo == VERITY_SHA512) { return "sha512"; }
    return "sha256";
}

fn dmverity_hash_hex_len(algo) {
    if (algo == VERITY_SHA256) { return VERITY_SHA256_HEX_LEN; }
    if (algo == VERITY_SHA512) { return VERITY_SHA512_HEX_LEN; }
    return VERITY_SHA256_HEX_LEN;
}

# ================================================================
# VerityConfig struct
# Layout: name(+0) data_device(+8) hash_device(+16)
#         data_block_size(+24) hash_block_size(+32)
#         hash_algorithm(+40) root_hash(+48) salt(+56)
# Total: 64 bytes. salt=0 means no salt.
# ================================================================

fn dmverity_config_alloc() {
    var c = alloc(64);
    memset(c, 0, 64);
    return c;
}

fn dmverity_config_set_devices(c, name, data_device, hash_device) {
    store64(c, name);
    store64(c + 8, data_device);
    store64(c + 16, hash_device);
    return c;
}

fn dmverity_config_set_params(c, data_bs, hash_bs, algo, root_hash, salt) {
    store64(c + 24, data_bs);
    store64(c + 32, hash_bs);
    store64(c + 40, algo);
    store64(c + 48, root_hash);
    store64(c + 56, salt);
    return c;
}

fn dmverity_config_name(c) { return load64(c); }
fn dmverity_config_data_device(c) { return load64(c + 8); }
fn dmverity_config_hash_device(c) { return load64(c + 16); }
fn dmverity_config_data_block_size(c) { return load64(c + 24); }
fn dmverity_config_hash_block_size(c) { return load64(c + 32); }
fn dmverity_config_hash_algorithm(c) { return load64(c + 40); }
fn dmverity_config_root_hash(c) { return load64(c + 48); }
fn dmverity_config_salt(c) { return load64(c + 56); }

# ================================================================
# VerityStatus struct
# Layout: name(+0) is_active(+8) is_verified(+16)
#         corruption_detected(+24) root_hash(+32)
# Total: 40 bytes
# ================================================================

fn dmverity_status_new(name, is_active, is_verified, corruption_detected, root_hash) {
    var s = alloc(40);
    store64(s, name);
    store64(s + 8, is_active);
    store64(s + 16, is_verified);
    store64(s + 24, corruption_detected);
    store64(s + 32, root_hash);
    return s;
}

fn dmverity_status_name(s) { return load64(s); }
fn dmverity_status_is_active(s) { return load64(s + 8); }
fn dmverity_status_is_verified(s) { return load64(s + 16); }
fn dmverity_status_corruption_detected(s) { return load64(s + 24); }
fn dmverity_status_root_hash(s) { return load64(s + 32); }

# ================================================================
# Validation helpers
# ================================================================

# Check if a byte is a valid hex character
fn dmverity_is_hex_char(ch) {
    if (ch >= 48 && ch <= 57) { return 1; }   # 0-9
    if (ch >= 65 && ch <= 70) { return 1; }   # A-F
    if (ch >= 97 && ch <= 102) { return 1; }  # a-f
    return 0;
}

# Validate a hex string. Returns Ok(0) or Err.
fn dmverity_validate_hex(s, label) {
    var slen = strlen(s);
    var i = 0;
    while (i < slen) {
        if (dmverity_is_hex_char(load8(s + i)) == 0) {
            return err_invalid_argument("hex string contains non-hex characters");
        }
        i = i + 1;
    }
    return Ok(0);
}

# Check if a byte is valid for a dm name (alphanum, dash, underscore)
fn dmverity_is_name_char(ch) {
    if (ch >= 48 && ch <= 57) { return 1; }
    if (ch >= 65 && ch <= 90) { return 1; }
    if (ch >= 97 && ch <= 122) { return 1; }
    if (ch == 45) { return 1; }
    if (ch == 95) { return 1; }
    return 0;
}

# Validate a root hash: correct length for algorithm, all hex.
# Returns Ok(0) or Err.
fn dmverity_validate_root_hash(hash, algorithm) {
    if (strlen(hash) == 0) {
        return err_invalid_argument("Root hash cannot be empty");
    }

    var expected_len = dmverity_hash_hex_len(algorithm);
    var actual_len = strlen(hash);

    if (actual_len != expected_len) {
        return err_invalid_argument("Root hash length does not match algorithm");
    }

    var i = 0;
    while (i < actual_len) {
        if (dmverity_is_hex_char(load8(hash + i)) == 0) {
            return err_invalid_argument("Root hash contains non-hex characters");
        }
        i = i + 1;
    }

    return Ok(0);
}

# Validate a VerityConfig. Returns Ok(0) or Err.
fn dmverity_config_validate(config) {
    var name = dmverity_config_name(config);
    var namelen = strlen(name);

    if (namelen == 0) {
        return err_invalid_argument("Verity name cannot be empty");
    }
    if (namelen > VERITY_NAME_MAX_LEN) {
        return err_invalid_argument("Verity name too long (max 128)");
    }

    var i = 0;
    while (i < namelen) {
        if (dmverity_is_name_char(load8(name + i)) == 0) {
            return err_invalid_argument("Verity name contains invalid characters");
        }
        i = i + 1;
    }

    # Block sizes must be powers of 2
    var dbs = dmverity_config_data_block_size(config);
    if (dbs == 0 || (dbs & (dbs - 1)) != 0) {
        return err_invalid_argument("Data block size must be a power of 2");
    }

    var hbs = dmverity_config_hash_block_size(config);
    if (hbs == 0 || (hbs & (hbs - 1)) != 0) {
        return err_invalid_argument("Hash block size must be a power of 2");
    }

    # Validate root hash
    var rh = dmverity_config_root_hash(config);
    var algo = dmverity_config_hash_algorithm(config);
    var res = dmverity_validate_root_hash(rh, algo);
    if (is_err_result(res) == 1) { return res; }

    # Validate salt if present
    var salt = dmverity_config_salt(config);
    if (salt != 0) {
        var salt_res = dmverity_validate_hex(salt, "salt");
        if (is_err_result(salt_res) == 1) { return salt_res; }
    }

    return Ok(0);
}

# ================================================================
# Helper: run veritysetup
# ================================================================

fn dmverity_run_capture(args, buf, buflen) {
    var n = exec_capture(args, buf, buflen);
    if (n < 0) {
        return err_unknown("veritysetup execution failed");
    }
    return Ok(n);
}

fn dmverity_run_checked(args) {
    var rc = exec_vec(args);
    if (rc != 0) {
        return err_unknown("veritysetup command failed");
    }
    return Ok(0);
}

# ================================================================
# dm-verity operations
# ================================================================

# Format a data device for dm-verity, generating the hash tree.
# Returns Ok(root_hash_ptr) — the computed root hash as a heap string.
fn dmverity_format(data_device, hash_device, algorithm, salt) {
    # Verify data device exists
    var acc = syscall(SYS_ACCESS, data_device, 0);
    if (acc < 0) {
        return err_invalid_argument("Data device not found");
    }

    var args = vec_new();
    vec_push(args, "/usr/sbin/veritysetup");
    vec_push(args, "format");
    vec_push(args, data_device);
    vec_push(args, hash_device);
    vec_push(args, "--hash");
    vec_push(args, dmverity_hash_algo_str(algorithm));

    if (salt != 0) {
        var salt_res = dmverity_validate_hex(salt, "salt");
        if (is_err_result(salt_res) == 1) { return salt_res; }
        vec_push(args, "--salt");
        vec_push(args, salt);
    }

    var outbuf[4096];
    memset(&outbuf, 0, 4096);
    var cap_res = dmverity_run_capture(args, &outbuf, 4095);
    if (is_err_result(cap_res) == 1) { return cap_res; }

    # Parse root hash from output: look for "Root hash:" line
    var pos = 0;
    var outlen = strlen(&outbuf);
    var needle = "Root hash:";
    var nlen = strlen(needle);
    var found = 0;

    while (pos < outlen && found == 0) {
        # Check if current position starts with "Root hash:"
        if (pos + nlen <= outlen) {
            if (memeq(&outbuf + pos, needle, nlen) == 1) {
                found = 1;
            } else {
                pos = pos + 1;
            }
        } else {
            pos = pos + 1;
        }
    }

    if (found == 0) {
        return err_unknown("Could not parse root hash from veritysetup output");
    }

    # Skip past "Root hash:" and whitespace
    pos = pos + nlen;
    while (pos < outlen && (load8(&outbuf + pos) == 32 || load8(&outbuf + pos) == 9)) {
        pos = pos + 1;
    }

    # Read hex characters until newline or end
    var hash_start = pos;
    while (pos < outlen && load8(&outbuf + pos) != 10 && load8(&outbuf + pos) != 0) {
        pos = pos + 1;
    }
    var hash_len = pos - hash_start;

    # Copy to heap
    var root_hash = alloc(hash_len + 1);
    memcpy(root_hash, &outbuf + hash_start, hash_len);
    store8(root_hash + hash_len, 0);

    return Ok(root_hash);
}

# Open (activate) a dm-verity volume.
# Creates a read-only device mapping at /dev/mapper/{name}.
# Returns Ok(0) or Err.
fn dmverity_open(config) {
    var res = dmverity_config_validate(config);
    if (is_err_result(res) == 1) { return res; }

    var args = vec_new();
    vec_push(args, "/usr/sbin/veritysetup");
    vec_push(args, "open");
    vec_push(args, "--hash");
    vec_push(args, dmverity_hash_algo_str(dmverity_config_hash_algorithm(config)));
    vec_push(args, dmverity_config_data_device(config));
    vec_push(args, dmverity_config_hash_device(config));
    vec_push(args, dmverity_config_name(config));
    vec_push(args, dmverity_config_root_hash(config));

    var salt = dmverity_config_salt(config);
    if (salt != 0) {
        vec_push(args, "--salt");
        vec_push(args, salt);
    }

    return dmverity_run_checked(args);
}

# Close (deactivate) a dm-verity volume.
# name: volume mapping name.
# Returns Ok(0) or Err.
fn dmverity_close(name) {
    if (strlen(name) == 0) {
        return err_invalid_argument("Verity name cannot be empty");
    }

    var args = vec_new();
    vec_push(args, "/usr/sbin/veritysetup");
    vec_push(args, "close");
    vec_push(args, name);

    return dmverity_run_checked(args);
}

# Query the status of a dm-verity volume.
# Returns Ok(verity_status_ptr) or Err.
fn dmverity_status(name) {
    if (strlen(name) == 0) {
        return err_invalid_argument("Verity name cannot be empty");
    }

    var args = vec_new();
    vec_push(args, "/usr/sbin/veritysetup");
    vec_push(args, "status");
    vec_push(args, name);

    var outbuf[4096];
    memset(&outbuf, 0, 4096);
    var n = exec_capture(args, &outbuf, 4095);

    if (n <= 0) {
        # Not active
        return Ok(dmverity_status_new(name, 0, 0, 0, ""));
    }

    var outlen = strlen(&outbuf);

    # Check if active (contains "type:")
    var is_active = 0;
    var tpos = 0;
    while (tpos < outlen) {
        if (tpos + 5 <= outlen && memeq(&outbuf + tpos, "type:", 5) == 1) {
            is_active = 1;
            tpos = outlen;  # break
        } else {
            tpos = tpos + 1;
        }
    }

    # Check for corruption
    var corruption = 0;
    var cpos = 0;
    while (cpos < outlen) {
        if (cpos + 9 <= outlen && memeq(&outbuf + cpos, "corrupted", 9) == 1) {
            corruption = 1;
            cpos = outlen;
        } else {
            cpos = cpos + 1;
        }
    }

    var is_verified = 0;
    if (is_active == 1 && corruption == 0) {
        is_verified = 1;
    }

    # Try to extract root hash from "root hash:" line
    var rhash = "";
    var rpos = 0;
    while (rpos < outlen) {
        if (rpos + 10 <= outlen && memeq(&outbuf + rpos, "root hash:", 10) == 1) {
            rpos = rpos + 10;
            while (rpos < outlen && (load8(&outbuf + rpos) == 32 || load8(&outbuf + rpos) == 9)) {
                rpos = rpos + 1;
            }
            var rstart = rpos;
            while (rpos < outlen && load8(&outbuf + rpos) != 10 && load8(&outbuf + rpos) != 0) {
                rpos = rpos + 1;
            }
            var rlen = rpos - rstart;
            rhash = alloc(rlen + 1);
            memcpy(rhash, &outbuf + rstart, rlen);
            store8(rhash + rlen, 0);
            rpos = outlen;  # break
        } else {
            rpos = rpos + 1;
        }
    }

    return Ok(dmverity_status_new(name, is_active, is_verified, corruption, rhash));
}

# Verify a dm-verity volume without activating it.
# Returns Ok(1) if valid, Ok(0) if failed.
fn dmverity_verify(data_device, hash_device, root_hash) {
    # Validate inputs
    var acc1 = syscall(SYS_ACCESS, data_device, 0);
    if (acc1 < 0) {
        return err_invalid_argument("Data device not found");
    }
    var acc2 = syscall(SYS_ACCESS, hash_device, 0);
    if (acc2 < 0) {
        return err_invalid_argument("Hash device not found");
    }
    if (strlen(root_hash) == 0) {
        return err_invalid_argument("Invalid root hash");
    }
    var rhlen = strlen(root_hash);
    var vi = 0;
    while (vi < rhlen) {
        if (dmverity_is_hex_char(load8(root_hash + vi)) == 0) {
            return err_invalid_argument("Invalid root hash");
        }
        vi = vi + 1;
    }

    var args = vec_new();
    vec_push(args, "/usr/sbin/veritysetup");
    vec_push(args, "verify");
    vec_push(args, data_device);
    vec_push(args, hash_device);
    vec_push(args, root_hash);

    var rc = exec_vec(args);
    return Ok(rc == 0);
}

# Check if dm-verity is supported on this system.
# Returns 1 if supported, 0 if not.
fn dmverity_supported() {
    # Check for kernel module
    if (syscall(SYS_ACCESS, "/sys/module/dm_verity", 0) == 0) { return 1; }

    # Check if veritysetup is available
    var args = vec_new();
    vec_push(args, "/usr/sbin/veritysetup");
    vec_push(args, "--version");
    return exec_vec(args) == 0;
}

# --- ima.cyr ---

# ima.cyr — IMA/EVM integrity measurement architecture
# Ported from rust-old/src/ima.rs
#
# Provides IMA policy rule construction, measurement parsing, status
# querying, and file integrity verification via xattr.
#
# Requires: lib/syscalls.cyr, lib/process.cyr, lib/string.cyr, lib/vec.cyr,
#           lib/alloc.cyr, lib/fmt.cyr, src/error.cyr

#define LINUX

# ================================================================
# IMA action constants
# ================================================================

enum ImaAction {
    IMA_MEASURE = 0;
    IMA_APPRAISE = 1;
    IMA_AUDIT = 2;
    IMA_HASH = 3;
    IMA_DONT_MEASURE = 4;
    IMA_DONT_APPRAISE = 5;
}

# ================================================================
# IMA target (func=) constants
# ================================================================

enum ImaTarget {
    IMA_FILE_CHECK = 0;
    IMA_BPRM_CHECK = 1;
    IMA_MMAP_CHECK = 2;
    IMA_MODULE_CHECK = 3;
    IMA_FIRMWARE_CHECK = 4;
    IMA_POLICY_CHECK = 5;
}

# ================================================================
# String representations
# ================================================================

fn ima_action_str(action) {
    if (action == IMA_MEASURE) { return "measure"; }
    if (action == IMA_APPRAISE) { return "appraise"; }
    if (action == IMA_AUDIT) { return "audit"; }
    if (action == IMA_HASH) { return "hash"; }
    if (action == IMA_DONT_MEASURE) { return "dont_measure"; }
    if (action == IMA_DONT_APPRAISE) { return "dont_appraise"; }
    return "measure";
}

fn ima_target_str(target) {
    if (target == IMA_FILE_CHECK) { return "FILE_CHECK"; }
    if (target == IMA_BPRM_CHECK) { return "BPRM_CHECK"; }
    if (target == IMA_MMAP_CHECK) { return "MMAP_CHECK"; }
    if (target == IMA_MODULE_CHECK) { return "MODULE_CHECK"; }
    if (target == IMA_FIRMWARE_CHECK) { return "FIRMWARE_CHECK"; }
    if (target == IMA_POLICY_CHECK) { return "POLICY_CHECK"; }
    return "FILE_CHECK";
}

# ================================================================
# ImaPolicyRule struct
# Layout: action(+0) target(+8) uid(+16) fowner(+24)
#         fsuuid(+32) obj_type(+40) mask(+48)
# Total: 56 bytes.
# uid/fowner: -1 means not set. fsuuid/obj_type/mask: 0 means not set.
# ================================================================

fn ima_rule_new(action, target) {
    var r = alloc(56);
    store64(r, action);
    store64(r + 8, target);
    store64(r + 16, 0 - 1);  # uid: not set
    store64(r + 24, 0 - 1);  # fowner: not set
    store64(r + 32, 0);      # fsuuid: not set
    store64(r + 40, 0);      # obj_type: not set
    store64(r + 48, 0);      # mask: not set
    return r;
}

fn ima_rule_action(r) { return load64(r); }
fn ima_rule_target(r) { return load64(r + 8); }
fn ima_rule_uid(r) { return load64(r + 16); }
fn ima_rule_fowner(r) { return load64(r + 24); }
fn ima_rule_fsuuid(r) { return load64(r + 32); }
fn ima_rule_obj_type(r) { return load64(r + 40); }
fn ima_rule_mask(r) { return load64(r + 48); }

fn ima_rule_set_uid(r, uid) { store64(r + 16, uid); return r; }
fn ima_rule_set_fowner(r, fowner) { store64(r + 24, fowner); return r; }
fn ima_rule_set_fsuuid(r, fsuuid) { store64(r + 32, fsuuid); return r; }
fn ima_rule_set_obj_type(r, obj_type) { store64(r + 40, obj_type); return r; }
fn ima_rule_set_mask(r, mask) { store64(r + 48, mask); return r; }

# ================================================================
# ImaPolicyRule validation
# ================================================================

fn ima_is_hex_char(ch) {
    if (ch >= 48 && ch <= 57) { return 1; }
    if (ch >= 65 && ch <= 70) { return 1; }
    if (ch >= 97 && ch <= 102) { return 1; }
    return 0;
}

# Validate a single rule. Returns Ok(0) or Err.
fn ima_rule_validate(rule) {
    # Validate fsuuid if set
    var fsuuid = ima_rule_fsuuid(rule);
    if (fsuuid != 0) {
        var ulen = strlen(fsuuid);
        if (ulen == 0) {
            return err_invalid_argument("fsuuid cannot be empty");
        }
        if (ulen != 32) {
            return err_invalid_argument("fsuuid must be 32 hex characters");
        }
        var i = 0;
        while (i < ulen) {
            if (ima_is_hex_char(load8(fsuuid + i)) == 0) {
                return err_invalid_argument("fsuuid contains non-hex characters");
            }
            i = i + 1;
        }
    }

    # Validate mask if set
    var mask = ima_rule_mask(rule);
    if (mask != 0) {
        if (streq(mask, "MAY_READ") != 1 &&
        streq(mask, "MAY_WRITE") != 1 &&
        streq(mask, "MAY_EXEC") != 1 &&
        streq(mask, "MAY_APPEND") != 1) {
            return err_invalid_argument(
            "Invalid mask (expected MAY_READ/MAY_WRITE/MAY_EXEC/MAY_APPEND)");
        }
    }

    return Ok(0);
}

# ================================================================
# Render a rule as a policy line
# e.g., "measure func=BPRM_CHECK uid=0 mask=MAY_EXEC"
# Returns Ok(policy_line_ptr) or Err.
# ================================================================

fn ima_rule_to_policy_line(rule) {
    var res = ima_rule_validate(rule);
    if (is_err_result(res) == 1) { return res; }

    # Build string: "<action> func=<target> [uid=N] [fowner=N] [fsuuid=X] [obj_type=X] [mask=X]"
    # Allocate generous buffer
    var buf = alloc(512);
    var pos = 0;

    # Action
    var act_str = ima_action_str(ima_rule_action(rule));
    var act_len = strlen(act_str);
    memcpy(buf + pos, act_str, act_len);
    pos = pos + act_len;

    # " func="
    memcpy(buf + pos, " func=", 6);
    pos = pos + 6;

    # Target
    var tgt_str = ima_target_str(ima_rule_target(rule));
    var tgt_len = strlen(tgt_str);
    memcpy(buf + pos, tgt_str, tgt_len);
    pos = pos + tgt_len;

    # Optional uid
    var uid = ima_rule_uid(rule);
    if (uid >= 0) {
        memcpy(buf + pos, " uid=", 5);
        pos = pos + 5;
        var ubuf[24];
        var ulen = fmt_int_buf(uid, &ubuf);
        memcpy(buf + pos, &ubuf, ulen);
        pos = pos + ulen;
    }

    # Optional fowner
    var fowner = ima_rule_fowner(rule);
    if (fowner >= 0) {
        memcpy(buf + pos, " fowner=", 8);
        pos = pos + 8;
        var fbuf[24];
        var flen = fmt_int_buf(fowner, &fbuf);
        memcpy(buf + pos, &fbuf, flen);
        pos = pos + flen;
    }

    # Optional fsuuid
    var fsuuid = ima_rule_fsuuid(rule);
    if (fsuuid != 0) {
        memcpy(buf + pos, " fsuuid=", 8);
        pos = pos + 8;
        var fslen = strlen(fsuuid);
        memcpy(buf + pos, fsuuid, fslen);
        pos = pos + fslen;
    }

    # Optional obj_type
    var obj_type = ima_rule_obj_type(rule);
    if (obj_type != 0) {
        memcpy(buf + pos, " obj_type=", 10);
        pos = pos + 10;
        var olen = strlen(obj_type);
        memcpy(buf + pos, obj_type, olen);
        pos = pos + olen;
    }

    # Optional mask
    var mask = ima_rule_mask(rule);
    if (mask != 0) {
        memcpy(buf + pos, " mask=", 6);
        pos = pos + 6;
        var mlen = strlen(mask);
        memcpy(buf + pos, mask, mlen);
        pos = pos + mlen;
    }

    store8(buf + pos, 0);
    return Ok(buf);
}

# ================================================================
# ImaStatus struct
# Layout: active(+0) measurement_count(+8) policy_loaded(+16)
# Total: 24 bytes
# ================================================================

fn ima_status_new(active, measurement_count, policy_loaded) {
    var s = alloc(24);
    store64(s, active);
    store64(s + 8, measurement_count);
    store64(s + 16, policy_loaded);
    return s;
}

fn ima_status_active(s) { return load64(s); }
fn ima_status_measurement_count(s) { return load64(s + 8); }
fn ima_status_policy_loaded(s) { return load64(s + 16); }

# ================================================================
# ImaMeasurement struct
# Layout: pcr(+0) template_hash(+8) template_name(+16)
#         filedata_hash(+24) filename(+32)
# Total: 40 bytes
# ================================================================

fn ima_measurement_new(pcr, template_hash, template_name, filedata_hash, filename) {
    var m = alloc(40);
    store64(m, pcr);
    store64(m + 8, template_hash);
    store64(m + 16, template_name);
    store64(m + 24, filedata_hash);
    store64(m + 32, filename);
    return m;
}

fn ima_measurement_pcr(m) { return load64(m); }
fn ima_measurement_template_hash(m) { return load64(m + 8); }
fn ima_measurement_template_name(m) { return load64(m + 16); }
fn ima_measurement_filedata_hash(m) { return load64(m + 24); }
fn ima_measurement_filename(m) { return load64(m + 32); }

# ================================================================
# Get IMA status
# Returns Ok(ima_status_ptr) or Err.
# ================================================================

fn ima_get_status() {
    var ima_dir = "/sys/kernel/security/ima";
    var acc = syscall(SYS_ACCESS, ima_dir, 0);

    if (acc < 0) {
        # IMA not active
        return Ok(ima_status_new(0, 0, 0));
    }

    # Count measurements by reading ascii_runtime_measurements
    var mpath = "/sys/kernel/security/ima/ascii_runtime_measurements";
    var mcount = 0;
    var mfd = sys_open(mpath, O_RDONLY, 0);
    if (mfd >= 0) {
        defer { sys_close(mfd); }
        var rbuf[4096];
        var rgo = 1;
        while (rgo == 1) {
            var n = sys_read(mfd, &rbuf, 4096);
            if (n <= 0) {
                rgo = 0;
            } else {
                # Count newlines
                var ri = 0;
                while (ri < n) {
                    if (load8(&rbuf + ri) == 10) {
                        mcount = mcount + 1;
                    }
                    ri = ri + 1;
                }
            }
        }
    }

    # Check if policy file exists
    var ppath = "/sys/kernel/security/ima/policy";
    var policy_loaded = 0;
    var pacc = syscall(SYS_ACCESS, ppath, 0);
    if (pacc == 0) { policy_loaded = 1; }

    return Ok(ima_status_new(1, mcount, policy_loaded));
}

# ================================================================
# Parse IMA measurements from a buffer
# Format per line: "PCR TEMPLATE_HASH TEMPLATE_NAME FILEDATA_HASH FILENAME"
# Returns Ok(vec_of_measurement_ptrs) or Err.
# ================================================================

fn ima_parse_measurements(content) {
    var measurements = vec_new();
    var clen = strlen(content);
    var pos = 0;

    while (pos < clen) {
        # Skip leading whitespace
        while (pos < clen && (load8(content + pos) == 32 || load8(content + pos) == 9)) {
            pos = pos + 1;
        }
        if (pos >= clen) { pos = clen; }

        # Skip empty lines
        if (pos < clen && load8(content + pos) == 10) {
            pos = pos + 1;
        } elif (pos < clen) {
            # Parse 5 space-separated fields
            # Field 1: PCR (integer)
            var pcr_start = pos;
            while (pos < clen && load8(content + pos) != 32 && load8(content + pos) != 10) {
                pos = pos + 1;
            }
            var pcr_len = pos - pcr_start;

            # Parse PCR number from digits
            var pcr = 0;
            var pi = pcr_start;
            while (pi < pcr_start + pcr_len) {
                var ch = load8(content + pi);
                if (ch >= 48 && ch <= 57) {
                    pcr = pcr * 10 + (ch - 48);
                }
                pi = pi + 1;
            }

            # Skip space
            if (pos < clen && load8(content + pos) == 32) { pos = pos + 1; }

            # Field 2: template_hash
            var th_start = pos;
            while (pos < clen && load8(content + pos) != 32 && load8(content + pos) != 10) {
                pos = pos + 1;
            }
            var th_len = pos - th_start;
            var template_hash = alloc(th_len + 1);
            memcpy(template_hash, content + th_start, th_len);
            store8(template_hash + th_len, 0);

            if (pos < clen && load8(content + pos) == 32) { pos = pos + 1; }

            # Field 3: template_name
            var tn_start = pos;
            while (pos < clen && load8(content + pos) != 32 && load8(content + pos) != 10) {
                pos = pos + 1;
            }
            var tn_len = pos - tn_start;
            var template_name = alloc(tn_len + 1);
            memcpy(template_name, content + tn_start, tn_len);
            store8(template_name + tn_len, 0);

            if (pos < clen && load8(content + pos) == 32) { pos = pos + 1; }

            # Field 4: filedata_hash
            var fh_start = pos;
            while (pos < clen && load8(content + pos) != 32 && load8(content + pos) != 10) {
                pos = pos + 1;
            }
            var fh_len = pos - fh_start;
            var filedata_hash = alloc(fh_len + 1);
            memcpy(filedata_hash, content + fh_start, fh_len);
            store8(filedata_hash + fh_len, 0);

            if (pos < clen && load8(content + pos) == 32) { pos = pos + 1; }

            # Field 5: filename (rest of line)
            var fn_start = pos;
            while (pos < clen && load8(content + pos) != 10) {
                pos = pos + 1;
            }
            var fn_len = pos - fn_start;
            var filename = alloc(fn_len + 1);
            memcpy(filename, content + fn_start, fn_len);
            store8(filename + fn_len, 0);

            # Skip newline
            if (pos < clen && load8(content + pos) == 10) { pos = pos + 1; }

            # Only add if we got all 5 fields
            if (th_len > 0 && tn_len > 0 && fh_len > 0 && fn_len > 0) {
                var m = ima_measurement_new(
                pcr, template_hash, template_name, filedata_hash, filename);
                vec_push(measurements, m);
            }
        }
    }

    return Ok(measurements);
}

# ================================================================
# Read IMA measurements from the kernel's measurement file
# Returns Ok(vec_of_measurement_ptrs) or Err.
# ================================================================

fn ima_read_measurements() {
    var path = "/sys/kernel/security/ima/ascii_runtime_measurements";
    var fd = sys_open(path, O_RDONLY, 0);
    if (fd < 0) {
        return err_io(0 - fd, "Failed to read IMA measurements");
    }
    defer { sys_close(fd); }

    # Read entire file into buffer (max 64KB)
    var bufsize = 65536;
    var buf = alloc(bufsize);
    memset(buf, 0, bufsize);
    var total = 0;
    var rgo = 1;
    while (rgo == 1) {
        var n = sys_read(fd, buf + total, bufsize - total - 1);
        if (n <= 0) { rgo = 0; }
        else {
            total = total + n;
            if (total >= bufsize - 1) { rgo = 0; }
        }
    }
    store8(buf + total, 0);

    return ima_parse_measurements(buf);
}

# ================================================================
# Write IMA policy to the kernel (append-only!)
# rules: vec of ima_rule pointers
# Returns Ok(0) or Err.
# ================================================================

fn ima_write_policy(rules) {
    var count = vec_len(rules);
    if (count == 0) {
        return err_invalid_argument("IMA policy has no rules");
    }

    # Validate all rules first
    var vi = 0;
    while (vi < count) {
        var rule = vec_get(rules, vi);
        var vres = ima_rule_validate(rule);
        if (is_err_result(vres) == 1) { return vres; }
        vi = vi + 1;
    }

    # Build the policy string
    var policy_buf = alloc(count * 512);
    var pos = 0;

    var ri = 0;
    while (ri < count) {
        var rule = vec_get(rules, ri);
        var line_res = ima_rule_to_policy_line(rule);
        if (is_err_result(line_res) == 1) { return line_res; }
        var line = payload(line_res);
        var llen = strlen(line);

        if (ri > 0) {
            store8(policy_buf + pos, 10);  # newline
            pos = pos + 1;
        }
        memcpy(policy_buf + pos, line, llen);
        pos = pos + llen;
        ri = ri + 1;
    }
    store8(policy_buf + pos, 0);

    # Write to /sys/kernel/security/ima/policy
    var ppath = "/sys/kernel/security/ima/policy";
    var pacc = syscall(SYS_ACCESS, ppath, 0);
    if (pacc < 0) {
        return err_unknown("IMA policy file not found; is IMA enabled?");
    }

    var fd = sys_open(ppath, O_WRONLY, 0);
    if (fd < 0) {
        var errno = 0 - fd;
        if (errno == EACCES || errno == EPERM) {
            return err_permission_denied("write ima policy");
        }
        return err_io(errno, "Failed to write IMA policy");
    }
    defer { sys_close(fd); }

    var wret = sys_write(fd, policy_buf, pos);
    if (wret < 0) {
        return err_io(0 - wret, "Failed to write IMA policy");
    }

    return Ok(0);
}

# ================================================================
# Verify file integrity via xattr (security.ima)
# Uses getfattr to read stored hash, computes sha256sum.
# Returns Ok(1) if matches, Ok(0) if not.
# ================================================================

fn ima_verify_file_integrity(path) {
    var acc = syscall(SYS_ACCESS, path, 0);
    if (acc < 0) {
        return err_invalid_argument("File not found");
    }

    # Read security.ima xattr via getfattr
    var attr_args = vec_new();
    vec_push(attr_args, "/usr/bin/getfattr");
    vec_push(attr_args, "-n");
    vec_push(attr_args, "security.ima");
    vec_push(attr_args, "--only-values");
    vec_push(attr_args, "--dump");
    vec_push(attr_args, path);

    var abuf[1024];
    memset(&abuf, 0, 1024);
    var an = exec_capture(attr_args, &abuf, 1023);
    if (an <= 0) {
        return err_unknown("File has no security.ima xattr or getfattr failed");
    }
    store8(&abuf + an, 0);

    # Compute sha256sum of the file
    var sha_args = vec_new();
    vec_push(sha_args, "/usr/bin/sha256sum");
    vec_push(sha_args, path);

    var sbuf[256];
    memset(&sbuf, 0, 256);
    var sn = exec_capture(sha_args, &sbuf, 255);
    if (sn <= 0) {
        return err_unknown("sha256sum failed");
    }
    store8(&sbuf + sn, 0);

    # sha256sum output: "<hex>  <filename>\n" — extract just the hex
    var sha_len = 0;
    while (sha_len < sn && load8(&sbuf + sha_len) != 32 && load8(&sbuf + sha_len) != 10) {
        sha_len = sha_len + 1;
    }

    # Compare: the xattr may be binary or hex; compare hex representation
    # For simplicity, compare the stored value trimmed against computed hex
    var stored_len = strlen(&abuf);
    # Trim trailing whitespace from stored
    while (stored_len > 0 &&
    (load8(&abuf + stored_len - 1) == 10 ||
    load8(&abuf + stored_len - 1) == 32)) {
        stored_len = stored_len - 1;
    }

    if (stored_len == sha_len && memeq(&abuf, &sbuf, sha_len) == 1) {
        return Ok(1);
    }

    return Ok(0);
}

# --- tpm.cyr ---

# tpm.cyr — TPM 2.0 integration
# Ported from rust-old/src/tpm.rs
#
# Measured boot verification, sealed secrets, PCR reading, and random
# bytes via the TPM 2.0 device. Shells out to tpm2-tools commands
# (tpm2_pcrread, tpm2_pcrextend, tpm2_create, tpm2_load, tpm2_unseal,
# tpm2_getrandom).
#
# Requires: lib/syscalls.cyr, lib/process.cyr, lib/string.cyr, lib/vec.cyr,
#           lib/alloc.cyr, lib/fmt.cyr, src/error.cyr

#define LINUX

# ================================================================
# Constants
# ================================================================

enum TpmPcrBank {
    TPM_SHA1 = 0;
    TPM_SHA256 = 1;
    TPM_SHA384 = 2;
    TPM_SHA512 = 3;
}

enum TpmConst {
    TPM_PCR_MAX = 23;
    TPM_SEAL_MAX_BYTES = 2048;
    TPM_RANDOM_MAX_BYTES = 4096;
    TPM_SHA1_HEX_LEN = 40;
    TPM_SHA256_HEX_LEN = 64;
    TPM_SHA384_HEX_LEN = 96;
    TPM_SHA512_HEX_LEN = 128;
}

# ================================================================
# PCR bank helpers
# ================================================================

fn tpm_bank_str(bank) {
    if (bank == TPM_SHA1) { return "sha1"; }
    if (bank == TPM_SHA256) { return "sha256"; }
    if (bank == TPM_SHA384) { return "sha384"; }
    if (bank == TPM_SHA512) { return "sha512"; }
    return "sha256";
}

fn tpm_bank_hex_len(bank) {
    if (bank == TPM_SHA1) { return TPM_SHA1_HEX_LEN; }
    if (bank == TPM_SHA256) { return TPM_SHA256_HEX_LEN; }
    if (bank == TPM_SHA384) { return TPM_SHA384_HEX_LEN; }
    if (bank == TPM_SHA512) { return TPM_SHA512_HEX_LEN; }
    return TPM_SHA256_HEX_LEN;
}

# ================================================================
# TpmPcrValue struct
# Layout: index(+0) bank(+8) value(+16)
# value is a pointer to a hex string
# Total: 24 bytes
# ================================================================

fn tpm_pcr_value_new(index, bank, value) {
    var v = alloc(24);
    store64(v, index);
    store64(v + 8, bank);
    store64(v + 16, value);
    return v;
}

fn tpm_pcr_value_index(v) { return load64(v); }
fn tpm_pcr_value_bank(v) { return load64(v + 8); }
fn tpm_pcr_value_value(v) { return load64(v + 16); }

# ================================================================
# SealedSecret struct
# Layout: context_path(+0) pcr_selection(+8)
# Total: 16 bytes
# ================================================================

fn tpm_sealed_new(context_path, pcr_selection) {
    var s = alloc(16);
    store64(s, context_path);
    store64(s + 8, pcr_selection);
    return s;
}

fn tpm_sealed_context(s) { return load64(s); }
fn tpm_sealed_pcr_sel(s) { return load64(s + 8); }

# ================================================================
# Helper: run tpm2-tools command
# ================================================================

fn tpm_run_capture(args, buf, buflen) {
    var n = exec_capture(args, buf, buflen);
    if (n < 0) {
        return err_unknown("tpm2 tool execution failed");
    }
    return Ok(n);
}

fn tpm_run_checked(args) {
    var rc = exec_vec(args);
    if (rc != 0) {
        return err_unknown("tpm2 tool command failed");
    }
    return Ok(0);
}

# ================================================================
# Build PCR selection string: "sha256:0,1,7"
# bank: TpmPcrBank constant
# indices: vec of PCR indices
# Returns heap-allocated null-terminated string.
# ================================================================

fn tpm_pcr_selection(bank, indices) {
    var bank_str = tpm_bank_str(bank);
    var blen = strlen(bank_str);
    var count = vec_len(indices);

    # Estimate buffer size: bank + ":" + comma-separated indices
    var buf = alloc(blen + 1 + count * 3 + 1);
    var pos = 0;

    memcpy(buf + pos, bank_str, blen);
    pos = pos + blen;
    store8(buf + pos, 58);  # ':'
    pos = pos + 1;

    var i = 0;
    while (i < count) {
        if (i > 0) {
            store8(buf + pos, 44);  # ','
            pos = pos + 1;
        }
        var idx = vec_get(indices, i);
        var ibuf[24];
        var ilen = fmt_int_buf(idx, &ibuf);
        memcpy(buf + pos, &ibuf, ilen);
        pos = pos + ilen;
        i = i + 1;
    }

    store8(buf + pos, 0);
    return buf;
}

# ================================================================
# TPM device detection
# ================================================================

# Check if a TPM 2.0 device is available.
# Returns 1 if available, 0 if not.
fn tpm_detect() {
    if (syscall(SYS_ACCESS, "/dev/tpmrm0", 0) == 0) { return 1; }
    return syscall(SYS_ACCESS, "/dev/tpm0", 0) == 0;
}

# ================================================================
# Read PCR values
# bank: TpmPcrBank constant
# indices: vec of PCR index i64s
# Returns Ok(vec_of_tpm_pcr_value_ptrs) or Err.
# ================================================================

fn tpm_read_pcr(bank, indices) {
    var count = vec_len(indices);
    if (count == 0) {
        return err_invalid_argument("Must specify at least one PCR index");
    }

    # Validate indices
    var vi = 0;
    while (vi < count) {
        var idx = vec_get(indices, vi);
        if (idx > TPM_PCR_MAX) {
            return err_invalid_argument("PCR index out of range (0-23)");
        }
        vi = vi + 1;
    }

    var selection = tpm_pcr_selection(bank, indices);

    var args = vec_new();
    vec_push(args, "/usr/bin/tpm2_pcrread");
    vec_push(args, selection);

    var outbuf = alloc(4096);
    memset(outbuf, 0, 4096);
    var cap_res = tpm_run_capture(args, outbuf, 4095);
    if (is_err_result(cap_res) == 1) { return cap_res; }

    store8(outbuf + payload(cap_res), 0);

    # Parse output — YAML-like:
    #   sha256:
    #     0 : 0xABCDEF...
    #     7 : 0x123456...
    var values = vec_new();
    var outlen = strlen(outbuf);
    var default_hex_len = tpm_bank_hex_len(bank);

    var pi = 0;
    while (pi < count) {
        var target_idx = vec_get(indices, pi);

        var idx_buf[24];
        var idx_len = fmt_int_buf(target_idx, &idx_buf);

        var found = 0;
        var hex_value = 0;
        var spos = 0;

        while (spos < outlen && found == 0) {
            var lstart = spos;
            while (lstart < outlen &&
            (load8(outbuf + lstart) == 32 ||
            load8(outbuf + lstart) == 9)) {
                lstart = lstart + 1;
            }

            if (lstart + idx_len <= outlen && memeq(outbuf + lstart, &idx_buf, idx_len) == 1) {
                var after = lstart + idx_len;
                if (after < outlen && (load8(outbuf + after) == 58 ||
                (load8(outbuf + after) == 32 &&
                after + 1 < outlen &&
                load8(outbuf + after + 1) == 58))) {
                    while (after < outlen && load8(outbuf + after) != 58) {
                        after = after + 1;
                    }
                    after = after + 1;
                    while (after < outlen &&
                    (load8(outbuf + after) == 32 ||
                    load8(outbuf + after) == 9)) {
                        after = after + 1;
                    }
                    if (after + 1 < outlen &&
                    load8(outbuf + after) == 48 &&
                    load8(outbuf + after + 1) == 120) {
                        after = after + 2;
                    }
                    var hstart = after;
                    while (after < outlen &&
                    load8(outbuf + after) != 10 &&
                    load8(outbuf + after) != 0 &&
                    load8(outbuf + after) != 32) {
                        after = after + 1;
                    }
                    var hlen = after - hstart;
                    hex_value = alloc(hlen + 1);
                    memcpy(hex_value, outbuf + hstart, hlen);
                    store8(hex_value + hlen, 0);
                    found = 1;
                }
            }

            while (spos < outlen && load8(outbuf + spos) != 10) {
                spos = spos + 1;
            }
            if (spos < outlen) { spos = spos + 1; }
        }

        # Default: zeros if not found
        if (found == 0) {
            hex_value = alloc(default_hex_len + 1);
            memset(hex_value, 48, default_hex_len);  # '0' = 48
            store8(hex_value + default_hex_len, 0);
        }

        vec_push(values, tpm_pcr_value_new(target_idx, bank, hex_value));
        pi = pi + 1;
    }

    return Ok(values);
}

# ================================================================
# Extend a PCR with a measurement hash
# bank: TpmPcrBank constant
# index: PCR index (0-23)
# hash: hex string
# Returns Ok(0) or Err.
# ================================================================

fn tpm_extend_pcr(bank, index, hash) {
    if (index > TPM_PCR_MAX) {
        return err_invalid_argument("PCR index out of range (0-23)");
    }
    if (strlen(hash) == 0) {
        return err_invalid_argument("Hash must be a non-empty hex string");
    }

    # Validate hex
    var hlen = strlen(hash);
    var hi = 0;
    while (hi < hlen) {
        var ch = load8(hash + hi);
        if (ch < 48 || (ch > 57 && ch < 65) || (ch > 70 && ch < 97) || ch > 102) {
            return err_invalid_argument("Hash contains non-hex characters");
        }
        hi = hi + 1;
    }

    # Build arg: "<index>:<bank>=<hash>"
    var bank_str = tpm_bank_str(bank);
    var bslen = strlen(bank_str);
    var ibuf[24];
    var ilen = fmt_int_buf(index, &ibuf);

    var argbuf = alloc(ilen + 1 + bslen + 1 + hlen + 1);
    var pos = 0;
    memcpy(argbuf + pos, &ibuf, ilen); pos = pos + ilen;
    store8(argbuf + pos, 58); pos = pos + 1;  # ':'
    memcpy(argbuf + pos, bank_str, bslen); pos = pos + bslen;
    store8(argbuf + pos, 61); pos = pos + 1;  # '='
    memcpy(argbuf + pos, hash, hlen); pos = pos + hlen;
    store8(argbuf + pos, 0);

    var args = vec_new();
    vec_push(args, "/usr/bin/tpm2_pcrextend");
    vec_push(args, argbuf);

    return tpm_run_checked(args);
}

# ================================================================
# Seal data to specific PCR state
# bank: TpmPcrBank
# pcr_indices: vec of PCR indices
# data_ptr: pointer to data to seal
# data_len: length of data
# output_dir: directory for output files
# Returns Ok(sealed_secret_ptr) or Err.
# ================================================================

fn tpm_seal(bank, pcr_indices, data_ptr, data_len, output_dir) {
    if (data_len == 0) {
        return err_invalid_argument("Cannot seal empty data");
    }
    if (data_len > TPM_SEAL_MAX_BYTES) {
        return err_invalid_argument("Sealed data too large (max 2048 bytes)");
    }

    var acc = syscall(SYS_ACCESS, output_dir, 0);
    if (acc < 0) {
        return err_invalid_argument("Output directory not found");
    }

    var pcr_sel = tpm_pcr_selection(bank, pcr_indices);
    var dir_len = strlen(output_dir);

    # Write data to temp file: <output_dir>/seal_input.bin
    var input_file = alloc(dir_len + 16);
    memcpy(input_file, output_dir, dir_len);
    memcpy(input_file + dir_len, "/seal_input.bin", 15);
    store8(input_file + dir_len + 15, 0);

    var ifd = sys_open(input_file, O_WRONLY | O_CREAT | O_TRUNC, 384);
    if (ifd < 0) {
        return err_syscall_failed(0 - ifd, "failed to write seal input");
    }
    defer { sys_close(ifd); }
    var wret = sys_write(ifd, data_ptr, data_len);
    if (wret < 0) {
        return err_syscall_failed(0 - wret, "write failed");
    }

    # Build output file paths
    var ctx_file = alloc(dir_len + 12);
    memcpy(ctx_file, output_dir, dir_len);
    memcpy(ctx_file + dir_len, "/sealed.ctx", 11);
    store8(ctx_file + dir_len + 11, 0);

    var pub_file = alloc(dir_len + 12);
    memcpy(pub_file, output_dir, dir_len);
    memcpy(pub_file + dir_len, "/sealed.pub", 11);
    store8(pub_file + dir_len + 11, 0);

    var priv_file = alloc(dir_len + 13);
    memcpy(priv_file, output_dir, dir_len);
    memcpy(priv_file + dir_len, "/sealed.priv", 12);
    store8(priv_file + dir_len + 12, 0);

    # tpm2_create -C owner -i <input> -u <pub> -r <priv> -L <pcr_sel>
    var cr_args = vec_new();
    vec_push(cr_args, "/usr/bin/tpm2_create");
    vec_push(cr_args, "-C");
    vec_push(cr_args, "owner");
    vec_push(cr_args, "-i");
    vec_push(cr_args, input_file);
    vec_push(cr_args, "-u");
    vec_push(cr_args, pub_file);
    vec_push(cr_args, "-r");
    vec_push(cr_args, priv_file);
    vec_push(cr_args, "-L");
    vec_push(cr_args, pcr_sel);

    var cr_res = tpm_run_checked(cr_args);
    if (is_err_result(cr_res) == 1) {
        sys_unlink(input_file);
        return cr_res;
    }

    # tpm2_load -C owner -u <pub> -r <priv> -c <ctx>
    var ld_args = vec_new();
    vec_push(ld_args, "/usr/bin/tpm2_load");
    vec_push(ld_args, "-C");
    vec_push(ld_args, "owner");
    vec_push(ld_args, "-u");
    vec_push(ld_args, pub_file);
    vec_push(ld_args, "-r");
    vec_push(ld_args, priv_file);
    vec_push(ld_args, "-c");
    vec_push(ld_args, ctx_file);

    var ld_res = tpm_run_checked(ld_args);
    sys_unlink(input_file);

    if (is_err_result(ld_res) == 1) { return ld_res; }

    return Ok(tpm_sealed_new(ctx_file, pcr_sel));
}

# ================================================================
# Unseal a secret — only succeeds if PCR values match policy
# sealed: sealed_secret_ptr from tpm_seal
# buf: output buffer for unsealed data
# buflen: buffer size
# Returns Ok(bytes_read) or Err.
# ================================================================

fn tpm_unseal(sealed, buf, buflen) {
    var ctx = tpm_sealed_context(sealed);
    var pcr_sel = tpm_sealed_pcr_sel(sealed);

    var acc = syscall(SYS_ACCESS, ctx, 0);
    if (acc < 0) {
        return err_invalid_argument("Sealed context file not found");
    }

    # Build policy arg: "pcr:<selection>"
    var psel_len = strlen(pcr_sel);
    var parg = alloc(4 + psel_len + 1);
    memcpy(parg, "pcr:", 4);
    memcpy(parg + 4, pcr_sel, psel_len);
    store8(parg + 4 + psel_len, 0);

    var args = vec_new();
    vec_push(args, "/usr/bin/tpm2_unseal");
    vec_push(args, "-c");
    vec_push(args, ctx);
    vec_push(args, "-p");
    vec_push(args, parg);

    var cap_res = tpm_run_capture(args, buf, buflen);
    return cap_res;
}

# ================================================================
# Get hardware random bytes from the TPM
# buf: output buffer
# count: number of bytes
# Returns Ok(bytes_written) or Err.
# ================================================================

fn tpm_get_random(buf, count) {
    if (count == 0) {
        return err_invalid_argument("Cannot request 0 random bytes");
    }
    if (count > TPM_RANDOM_MAX_BYTES) {
        return err_invalid_argument("Cannot request more than 4096 bytes at once");
    }

    var cbuf[24];
    var clen = fmt_int_buf(count, &cbuf);

    var args = vec_new();
    vec_push(args, "/usr/bin/tpm2_getrandom");
    vec_push(args, "--hex");
    vec_push(args, &cbuf);

    var hexbuf = alloc(8200);
    memset(hexbuf, 0, 8200);
    var cap_res = tpm_run_capture(args, hexbuf, 8199);
    if (is_err_result(cap_res) == 1) { return cap_res; }

    var hexlen = payload(cap_res);
    # Trim trailing whitespace
    while (hexlen > 0 && (load8(hexbuf + hexlen - 1) == 10 || load8(hexbuf + hexlen - 1) == 32)) {
        hexlen = hexlen - 1;
    }

    # Decode hex pairs into output buffer
    var written = 0;
    var hi = 0;
    while (hi + 1 < hexlen && written < count) {
        var h = load8(hexbuf + hi);
        var l = load8(hexbuf + hi + 1);

        # Convert hex chars to nibbles
        var hv = 0;
        if (h >= 48 && h <= 57) { hv = h - 48; }
        elif (h >= 97 && h <= 102) { hv = h - 87; }
        elif (h >= 65 && h <= 70) { hv = h - 55; }

        var lv = 0;
        if (l >= 48 && l <= 57) { lv = l - 48; }
        elif (l >= 97 && l <= 102) { lv = l - 87; }
        elif (l >= 65 && l <= 70) { lv = l - 55; }

        store8(buf + written, (hv << 4) | lv);
        written = written + 1;
        hi = hi + 2;
    }

    return Ok(written);
}

# ================================================================
# Verify measured boot against known-good baseline
# expected: vec of tpm_pcr_value_ptrs
# Returns Ok(1) if all match, Ok(0) if mismatch.
# ================================================================

fn tpm_verify_measured_boot(expected) {
    var count = vec_len(expected);
    if (count == 0) {
        return err_invalid_argument("Baseline has no expected PCR values");
    }

    # Get bank from first entry
    var first = vec_get(expected, 0);
    var bank = tpm_pcr_value_bank(first);

    # Collect indices
    var indices = vec_new();
    var ci = 0;
    while (ci < count) {
        var entry = vec_get(expected, ci);
        vec_push(indices, tpm_pcr_value_index(entry));
        ci = ci + 1;
    }

    # Read current PCR values
    var read_res = tpm_read_pcr(bank, indices);
    if (is_err_result(read_res) == 1) { return read_res; }
    var current = payload(read_res);

    # Compare each expected value against current
    var ei = 0;
    while (ei < count) {
        var exp = vec_get(expected, ei);
        var exp_idx = tpm_pcr_value_index(exp);
        var exp_val = tpm_pcr_value_value(exp);

        # Find matching current value
        var cur_count = vec_len(current);
        var found = 0;
        var fi = 0;
        while (fi < cur_count && found == 0) {
            var cur = vec_get(current, fi);
            if (tpm_pcr_value_index(cur) == exp_idx && tpm_pcr_value_bank(cur) == bank) {
                var cur_val = tpm_pcr_value_value(cur);
                if (streq(exp_val, cur_val) != 1) {
                    return Ok(0);  # Mismatch
                }
                found = 1;
            }
            fi = fi + 1;
        }

        if (found == 0) {
            return Ok(0);  # PCR not found
        }

        ei = ei + 1;
    }

    return Ok(1);
}

# --- certpin.cyr ---

# certpin.cyr — TLS certificate pinning (SPKI SHA-256)
# Ported from rust-old/src/certpin.rs
#
# Pin computation uses `openssl` subprocess. Pin format is base64-encoded
# SHA-256 of SPKI (Subject Public Key Info), compatible with HPKP (RFC 7469).
#
# Requires: src/error.cyr, lib/process.cyr, lib/syscalls.cyr

# ================================================================
# Pin verification result constants
# ================================================================

enum CertPinResult {
    CERTPIN_VALID = 0;
    CERTPIN_MISMATCH = 1;
    CERTPIN_EXPIRED = 2;
    CERTPIN_NO_PIN_CONFIGURED = 3;
    CERTPIN_ERROR = 4;
}

# ================================================================
# Pin set struct
# ================================================================

# PinnedCert: { host_ptr, pins_vec, pin_count, backup_vec, backup_count, expires }
# Layout: host at +0, pins at +8, pin_count at +16,
#         backups at +24, backup_count at +32, expires at +40
# Total: 48 bytes. expires == 0 means no expiry.

fn certpin_entry_new(host, expires) {
    var e = alloc(48);
    store64(e, host);
    store64(e + 8, 0);   # pins array ptr
    store64(e + 16, 0);  # pin count
    store64(e + 24, 0);  # backup pins array ptr
    store64(e + 32, 0);  # backup pin count
    store64(e + 40, expires);
    return e;
}

fn certpin_entry_host(e) { return load64(e); }
fn certpin_entry_pins(e) { return load64(e + 8); }
fn certpin_entry_pin_count(e) { return load64(e + 16); }
fn certpin_entry_backups(e) { return load64(e + 24); }
fn certpin_entry_backup_count(e) { return load64(e + 32); }
fn certpin_entry_expires(e) { return load64(e + 40); }

fn certpin_entry_set_pins(e, pins_ptr, count) {
    store64(e + 8, pins_ptr);
    store64(e + 16, count);
    return 0;
}

fn certpin_entry_set_backups(e, backups_ptr, count) {
    store64(e + 24, backups_ptr);
    store64(e + 32, count);
    return 0;
}

# CertPinSet: { entries_vec, entry_count, enforce }
# Layout: entries at +0, count at +8, enforce at +16
# Total: 24 bytes.

fn certpin_set_new(enforce) {
    var s = alloc(24);
    store64(s, 0);       # entries array ptr
    store64(s + 8, 0);   # entry count
    store64(s + 16, enforce);
    return s;
}

fn certpin_set_entries(s) { return load64(s); }
fn certpin_set_count(s) { return load64(s + 8); }
fn certpin_set_enforce(s) { return load64(s + 16); }

fn certpin_set_set_entries(s, entries_ptr, count) {
    store64(s, entries_ptr);
    store64(s + 8, count);
    return 0;
}

# ================================================================
# Pin format validation
# ================================================================

# Validate a base64-encoded SHA-256 pin string.
# A valid pin is 44 characters of base64 (32 bytes -> 44 chars with padding).
# Returns 1 if valid, 0 if invalid.
fn certpin_validate_pin_format(pin) {
    var len = strlen(pin);
    # SHA-256 base64: ceil(32/3)*4 = 44 chars
    if (len != 44) { return 0; }

    var i = 0;
    while (i < len) {
        var c = load8(pin + i);
        # A-Z: 65-90, a-z: 97-122, 0-9: 48-57, +: 43, /: 47, =: 61
        var valid = 0;
        if (c >= 65) { if (c <= 90) { valid = 1; } }
        if (c >= 97) { if (c <= 122) { valid = 1; } }
        if (c >= 48) { if (c <= 57) { valid = 1; } }
        if (c == 43) { valid = 1; }  # +
        if (c == 47) { valid = 1; }  # /
        if (c == 61) { valid = 1; }  # =
        if (valid == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ================================================================
# Pin verification (pure function)
# ================================================================

# Constant-time string comparison to prevent timing side-channels.
# Returns 1 if equal, 0 otherwise.
fn certpin_ct_streq(a, b) {
    var alen = strlen(a);
    var blen = strlen(b);
    if (alen != blen) { return 0; }
    var acc = 0;
    var i = 0;
    while (i < alen) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        acc = acc | (ca ^ cb);
        i = i + 1;
    }
    return acc == 0;
}

# Find the pin entry for a given host in the pin set.
# Returns entry pointer or 0 if not found.
fn certpin_find_entry(pin_set, host) {
    var entries = certpin_set_entries(pin_set);
    var count = certpin_set_count(pin_set);
    var i = 0;
    while (i < count) {
        var entry = load64(entries + i * 8);
        var entry_host = certpin_entry_host(entry);
        if (streq(entry_host, host) == 1) {
            return entry;
        }
        i = i + 1;
    }
    return 0;
}

# Verify a certificate pin against a pin set.
# actual_pin: the base64-encoded SPKI SHA-256 hash from the presented cert.
# current_time: unix timestamp (0 to skip expiry check).
# Returns a CertPinResult constant.
fn certpin_verify_pin(host, actual_pin, pin_set, current_time) {
    var entry = certpin_find_entry(pin_set, host);
    if (entry == 0) {
        return CERTPIN_NO_PIN_CONFIGURED;
    }

    # Check expiry
    var expires = certpin_entry_expires(entry);
    if (expires != 0) {
        if (current_time > expires) {
            return CERTPIN_EXPIRED;
        }
    }

    # Check primary pins (constant-time comparison)
    var pins = certpin_entry_pins(entry);
    var pin_count = certpin_entry_pin_count(entry);
    var i = 0;
    while (i < pin_count) {
        var pin = load64(pins + i * 8);
        if (certpin_ct_streq(pin, actual_pin) == 1) {
            return CERTPIN_VALID;
        }
        i = i + 1;
    }

    # Check backup pins
    var backups = certpin_entry_backups(entry);
    var backup_count = certpin_entry_backup_count(entry);
    i = 0;
    while (i < backup_count) {
        var pin = load64(backups + i * 8);
        if (certpin_ct_streq(pin, actual_pin) == 1) {
            return CERTPIN_VALID;
        }
        i = i + 1;
    }

    return CERTPIN_MISMATCH;
}

# ================================================================
# Pin computation via openssl subprocess
# ================================================================

# Compute the SPKI SHA-256 pin for a PEM certificate file on disk.
# cert_path: path to a PEM-encoded certificate file.
# Returns Result: Ok(pin_string_ptr) or Err.
#
# Pipeline: openssl x509 -in <path> -pubkey -noout |
#           openssl pkey -pubin -outform DER |
#           openssl dgst -sha256 -binary |
#           openssl enc -base64
fn certpin_compute_spki_pin(cert_path) {
    if (cert_path == 0) {
        return err_invalid_argument("cert_path is null");
    }
    if (strlen(cert_path) == 0) {
        return err_invalid_argument("cert_path is empty");
    }

    # Validate cert_path does not contain shell-injection characters
    var vlen = strlen(cert_path);
    if (vlen == 0) {
        return err_invalid_argument("cert_path is empty");
    }
    if (vlen > 896) {
        return err_invalid_argument("cert_path too long");
    }
    var vi = 0;
    while (vi < vlen) {
        var vc = load8(cert_path + vi);
        if (vc == 39) {  # single quote
            return err_invalid_argument("cert_path contains single quote");
        }
        if (vc == 10) {  # newline
            return err_invalid_argument("cert_path contains newline");
        }
        if (vc == 0) {  # null byte (shouldn't reach here, but defensive)
            return err_invalid_argument("cert_path contains null byte");
        }
        vi = vi + 1;
    }

    # Build the pipeline command as a single shell invocation
    # We use sh -c to pipe the commands together
    var cmd = "sh";
    # Construct the pipeline string
    # openssl x509 -in <path> -pubkey -noout | openssl pkey -pubin -outform DER
    # | openssl dgst -sha256 -binary | openssl enc -base64 -A
    # We'll build this as a static command with the path inserted

    # For safety, use a fixed buffer for the shell command
    var buf = alloc(1024);
    var pos = 0;

    var prefix = "openssl x509 -in '";
    var prefixlen = strlen(prefix);
    memcpy(buf + pos, prefix, prefixlen);
    pos = pos + prefixlen;

    var pathlen = strlen(cert_path);
    memcpy(buf + pos, cert_path, pathlen);
    pos = pos + pathlen;

    var s1 = "' -pubkey -noout | openssl pkey -pubin -outform DER";
    var s2 = " | openssl dgst -sha256 -binary | openssl enc -base64 -A";
    # Build suffix by concatenating s1 + s2 into buf directly
    var s1len = strlen(s1);
    memcpy(buf + pos, s1, s1len);
    pos = pos + s1len;
    var suffix = s2;
    var suffixlen = strlen(suffix);
    memcpy(buf + pos, suffix, suffixlen);
    pos = pos + suffixlen;

    store8(buf + pos, 0);  # null terminate

    # Build argv for sh -c
    var argv = alloc(24);
    store64(argv, cmd);
    var dashc = "-c";
    store64(argv + 8, dashc);
    store64(argv + 16, buf);

    var res = run_capture(cmd, argv);
    if (is_err_result(res) == 1) { return res; }

    var output = payload(res);
    if (output == 0) {
        return err_unknown("openssl pipeline returned empty output");
    }
    if (strlen(output) == 0) {
        return err_unknown("openssl pipeline returned empty output");
    }

    # Strip trailing newline if present
    var outlen = strlen(output);
    if (load8(output + outlen - 1) == 10) {
        store8(output + outlen - 1, 0);
    }

    return Ok(output);
}

# ================================================================
# Fetch server certificate info via openssl s_client
# ================================================================

# CertInfo struct: { subject, issuer, serial, not_before, not_after, sha256_fp, spki_sha256 }
# Layout: 7 string pointers, 56 bytes total.

fn certpin_info_new() {
    var c = alloc(56);
    memset(c, 0, 56);
    return c;
}

fn certpin_info_subject(c)   { return load64(c); }
fn certpin_info_issuer(c)    { return load64(c + 8); }
fn certpin_info_serial(c)    { return load64(c + 16); }
fn certpin_info_not_before(c) { return load64(c + 24); }
fn certpin_info_not_after(c) { return load64(c + 32); }
fn certpin_info_sha256_fp(c) { return load64(c + 40); }
fn certpin_info_spki_sha256(c) { return load64(c + 48); }

fn certpin_info_set_subject(c, v) { store64(c, v); return 0; }
fn certpin_info_set_issuer(c, v) { store64(c + 8, v); return 0; }
fn certpin_info_set_serial(c, v) { store64(c + 16, v); return 0; }
fn certpin_info_set_not_before(c, v) { store64(c + 24, v); return 0; }
fn certpin_info_set_not_after(c, v) { store64(c + 32, v); return 0; }
fn certpin_info_set_sha256_fp(c, v) { store64(c + 40, v); return 0; }
fn certpin_info_set_spki_sha256(c, v) { store64(c + 48, v); return 0; }

# Check pin expiry against current time.
# Returns 1 if expired, 0 if not expired or no expiry set.
fn certpin_check_pin_expiry(entry, current_time) {
    var expires = certpin_entry_expires(entry);
    if (expires == 0) { return 0; }
    return current_time > expires;
}

# --- secureboot.cyr ---

# secureboot.cyr — UEFI Secure Boot state detection and EFI variable reading
# Ported from rust-old/src/secureboot.rs
#
# Reads EFI variables from /sys/firmware/efi/efivars/ to detect
# secure boot state. Falls back to mokutil subprocess.
#
# Requires: src/error.cyr, lib/syscalls.cyr, lib/process.cyr

# ================================================================
# Secure Boot state constants
# ================================================================

enum SecureBootState {
    SB_ENABLED = 1;
    SB_DISABLED = 2;
    SB_SETUP_MODE = 3;
    SB_NOT_SUPPORTED = 4;
}

# ================================================================
# Well-known EFI variable paths
# ================================================================

# The SecureBoot variable GUID
# Full path: /sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c

# ================================================================
# EFI variable reading
# ================================================================

# Read a raw EFI variable from sysfs.
# path: full path to the EFI variable file.
# Returns Result: Ok(data_ptr) where data_ptr points to { value_byte, size }.
# EFI variables have a 4-byte attributes header followed by the payload.
#
# Layout of returned struct: { attrs (4 bytes at +0), payload_byte at +4, total_size at +8 }
fn secureboot_read_efi_variable(path) {
    if (path == 0) {
        return err_invalid_argument("efi variable path is null");
    }
    if (strlen(path) == 0) {
        return err_invalid_argument("efi variable path is empty");
    }

    # Open the file
    var fd = sys_open(path, 0, 0);  # O_RDONLY = 0
    if (fd < 0) {
        return err_io(0 - fd, "failed to open efi variable");
    }
    defer { sys_close(fd); }

    # Read up to 256 bytes (EFI variables are typically small)
    var buf = alloc(256);
    memset(buf, 0, 256);
    var nread = sys_read(fd, buf, 256);

    if (nread < 0) {
        return err_io(0 - nread, "failed to read efi variable");
    }

    if (nread < 5) {
        return err_invalid_argument("efi variable too short (need 4-byte header + payload)");
    }

    # Return the buffer with read count in a result struct
    var result = alloc(16);
    store64(result, buf);      # pointer to data
    store64(result + 8, nread); # bytes read
    return Ok(result);
}

# Get the payload byte at index (after the 4-byte attributes header).
fn secureboot_efi_var_payload_byte(data, index) {
    var buf = load64(data);
    return load8(buf + 4 + index);
}

# Get total bytes read.
fn secureboot_efi_var_size(data) {
    return load64(data + 8);
}

# ================================================================
# Secure Boot state detection
# ================================================================

# Detect the current Secure Boot state.
# Returns Result: Ok(SecureBootState) or Err.
fn secureboot_detect_state() {
    # Check if EFI is available
    var efi_dir = "/sys/firmware/efi";
    var fd = sys_open(efi_dir, 0, 0);
    if (fd < 0) {
        return Ok(SB_NOT_SUPPORTED);
    }
    sys_close(fd);

    # Try reading SecureBoot EFI variable
    var sb_path = "/sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c";
    var res = secureboot_read_efi_variable(sb_path);
    if (is_ok(res) == 1) {
        var data = payload(res);
        var size = secureboot_efi_var_size(data);
        if (size >= 5) {
            var value = secureboot_efi_var_payload_byte(data, 0);
            if (value == 1) {
                # Check SetupMode
                var sp = "/sys/firmware/efi/efivars/SetupMode-8be4df61-93ca-11d2-aa0d-00e098032b8c";
                var setup_res = secureboot_read_efi_variable(sp);
                if (is_ok(setup_res) == 1) {
                    var setup_data = payload(setup_res);
                    var setup_size = secureboot_efi_var_size(setup_data);
                    if (setup_size >= 5) {
                        var setup_val = secureboot_efi_var_payload_byte(setup_data, 0);
                        if (setup_val == 1) {
                            return Ok(SB_SETUP_MODE);
                        }
                    }
                }
                return Ok(SB_ENABLED);
            }
            else {
                return Ok(SB_DISABLED);
            }
        }
    }

    # Fallback: try mokutil --sb-state
    var mok_args = vec_new();
    vec_push(mok_args, "mokutil");
    vec_push(mok_args, "--sb-state");
    var mokbuf = alloc(4096);
    var mok_n = exec_capture(mok_args, mokbuf, 4095);
    var mok_res = wrap_syscall(mok_n);
    if (is_ok(mok_res) == 1) {
        var output = mokbuf;
        if (mok_n > 0) {
            # Substring search for known patterns using memeq
            var outlen = strlen(output);
            var i = 0;
            while (i < outlen) {
                if (i + 7 <= outlen && memeq(output + i, "enabled", 7) == 1) {
                    return Ok(SB_ENABLED);
                }
                if (i + 8 <= outlen && memeq(output + i, "disabled", 8) == 1) {
                    return Ok(SB_DISABLED);
                }
                if (i + 5 <= outlen && memeq(output + i, "setup", 5) == 1) {
                    return Ok(SB_SETUP_MODE);
                }
                i = i + 1;
            }
            return Ok(SB_DISABLED);
        }
    }

    # mokutil not available, cannot determine
    return Ok(SB_NOT_SUPPORTED);
}

# ================================================================
# Helper: check if Secure Boot is enforcing
# ================================================================

fn secureboot_is_enforcing(state) {
    return state == SB_ENABLED;
}

# State to string (returns pointer to static string)
fn secureboot_state_str(state) {
    if (state == SB_ENABLED) { return "enabled"; }
    if (state == SB_DISABLED) { return "disabled"; }
    if (state == SB_SETUP_MODE) { return "setup_mode"; }
    return "not_supported";
}

# ================================================================
# EnrolledKey struct
# ================================================================
# Layout: { subject, issuer, fingerprint, not_before, not_after }
# 5 fields * 8 = 40 bytes

fn secureboot_enrolled_key_new(subject, issuer, fingerprint, not_before, not_after) {
    var k = alloc(40);
    store64(k, subject);
    store64(k + 8, issuer);
    store64(k + 16, fingerprint);
    store64(k + 24, not_before);
    store64(k + 32, not_after);
    return k;
}

fn secureboot_key_subject(k) { return load64(k); }
fn secureboot_key_issuer(k) { return load64(k + 8); }
fn secureboot_key_fingerprint(k) { return load64(k + 16); }
fn secureboot_key_not_before(k) { return load64(k + 24); }
fn secureboot_key_not_after(k) { return load64(k + 32); }

# ================================================================
# List enrolled MOK keys
# ================================================================

# Parse mokutil --list-enrolled output into a vec of EnrolledKey structs.
# Returns vec of key pointers.
fn secureboot_parse_mokutil_list(output, outlen) {
    var keys = vec_new();
    var pos = 0;

    var cur_subject = "";
    var cur_issuer = "";
    var cur_fingerprint = "";
    var cur_not_before = "";
    var cur_not_after = "";
    var in_key = 0;

    while (pos < outlen) {
        # Find line start and end
        var linestart = pos;
        while (pos < outlen && load8(output + pos) != 10) { pos = pos + 1; }
        var linelen = pos - linestart;
        if (pos < outlen) { pos = pos + 1; }
        if (linelen == 0) { continue; }

        # Skip leading whitespace
        var lp = linestart;
        while (lp < linestart + linelen && (load8(output + lp) == 32 || load8(output + lp) == 9)) {
            lp = lp + 1;
        }
        var trimlen = (linestart + linelen) - lp;
        if (trimlen == 0) { continue; }

        # Check for "[key " marker
        if (trimlen >= 5 && memeq(output + lp, "[key ", 5) == 1) {
            # Save previous key if any
            if (in_key == 1 && strlen(cur_fingerprint) > 0) {
                vec_push(keys, secureboot_enrolled_key_new(
                    cur_subject, cur_issuer, cur_fingerprint,
                    cur_not_before, cur_not_after));
            }
            cur_subject = "";
            cur_issuer = "";
            cur_fingerprint = "";
            cur_not_before = "";
            cur_not_after = "";
            in_key = 1;
            continue;
        }

        if (in_key == 0) { continue; }

        # Parse fields
        var lend = linestart + linelen;
        if (trimlen >= 18 && memeq(output + lp, "SHA1 Fingerprint:", 17) == 1) {
            var fp_start = lp + 17;
            while (fp_start < lend && load8(output + fp_start) == 32) {
                fp_start = fp_start + 1;
            }
            var fp_len = lend - fp_start;
            var fp = alloc(fp_len + 1);
            var fi = 0;
            var fo = 0;
            while (fi < fp_len) {
                var c = load8(output + fp_start + fi);
                if (c != 58) {
                    if (c >= 65 && c <= 90) { c = c + 32; }
                    store8(fp + fo, c);
                    fo = fo + 1;
                }
                fi = fi + 1;
            }
            store8(fp + fo, 0);
            cur_fingerprint = fp;
        }
        elif (trimlen >= 8 && memeq(output + lp, "Subject:", 8) == 1) {
            var s_start = lp + 8;
            while (s_start < lend && load8(output + s_start) == 32) {
                s_start = s_start + 1;
            }
            var s_len = lend - s_start;
            cur_subject = alloc(s_len + 1);
            memcpy(cur_subject, output + s_start, s_len);
            store8(cur_subject + s_len, 0);
        }
        elif (trimlen >= 7 && memeq(output + lp, "Issuer:", 7) == 1) {
            var i_start = lp + 7;
            while (i_start < lend && load8(output + i_start) == 32) {
                i_start = i_start + 1;
            }
            var i_len = lend - i_start;
            cur_issuer = alloc(i_len + 1);
            memcpy(cur_issuer, output + i_start, i_len);
            store8(cur_issuer + i_len, 0);
        }
        elif (trimlen >= 11 && memeq(output + lp, "Valid from:", 11) == 1) {
            var vf_start = lp + 11;
            while (vf_start < lend && load8(output + vf_start) == 32) {
                vf_start = vf_start + 1;
            }
            var vf_len = lend - vf_start;
            cur_not_before = alloc(vf_len + 1);
            memcpy(cur_not_before, output + vf_start, vf_len);
            store8(cur_not_before + vf_len, 0);
        }
        elif (trimlen >= 12 && memeq(output + lp, "Valid until:", 12) == 1) {
            var vu_start = lp + 12;
            while (vu_start < lend && load8(output + vu_start) == 32) {
                vu_start = vu_start + 1;
            }
            var vu_len = lend - vu_start;
            cur_not_after = alloc(vu_len + 1);
            memcpy(cur_not_after, output + vu_start, vu_len);
            store8(cur_not_after + vu_len, 0);
        }
    }

    # Save last key
    if (in_key == 1 && strlen(cur_fingerprint) > 0) {
        vec_push(keys, secureboot_enrolled_key_new(
            cur_subject, cur_issuer, cur_fingerprint,
            cur_not_before, cur_not_after));
    }

    return keys;
}

# List enrolled MOK (Machine Owner Key) certificates.
# Returns Result: Ok(vec_of_keys) or Err.
fn secureboot_list_enrolled_keys() {
    var args = vec_new();
    vec_push(args, "mokutil");
    vec_push(args, "--list-enrolled");

    var outbuf = alloc(8192);
    var n = exec_capture(args, outbuf, 8191);
    if (n < 0) {
        return err_io(0 - n, "mokutil --list-enrolled failed");
    }
    store8(outbuf + n, 0);

    var keys = secureboot_parse_mokutil_list(outbuf, n);
    return Ok(keys);
}

# ================================================================
# MOK key enrollment
# ================================================================

# Enroll a DER-encoded certificate into the MOK list.
# A reboot is required to complete enrollment.
# Returns Result: Ok(0) or Err.
fn secureboot_enroll_key(der_path) {
    if (der_path == 0 || strlen(der_path) == 0) {
        return err_invalid_argument("certificate path is empty");
    }

    # Check file exists
    if (sys_access(der_path, 0) != 0) {
        return err_invalid_argument("certificate file not found");
    }

    # Validate extension (basic check: last chars should be .der, .cer, .crt, or .pem)
    var plen = strlen(der_path);
    if (plen < 5) {
        return err_invalid_argument("certificate path too short");
    }

    var args = vec_new();
    vec_push(args, "mokutil");
    vec_push(args, "--import");
    vec_push(args, der_path);

    var outbuf[1024];
    var n = exec_capture(args, &outbuf, 1023);
    var res = wrap_syscall(n);
    if (is_err_result(res) == 1) {
        return err_io(0, "mokutil --import failed");
    }

    return Ok(0);
}

# ================================================================
# Kernel module signing
# ================================================================

# Sign a kernel module with a private key and certificate.
# Uses kmodsign, falls back to sign-file from kernel headers.
# Returns Result: Ok(0) or Err.
fn secureboot_sign_module(module_path, private_key, certificate) {
    if (module_path == 0 || strlen(module_path) == 0) {
        return err_invalid_argument("module path is empty");
    }
    if (private_key == 0 || strlen(private_key) == 0) {
        return err_invalid_argument("private key path is empty");
    }
    if (certificate == 0 || strlen(certificate) == 0) {
        return err_invalid_argument("certificate path is empty");
    }

    # Verify files exist
    if (sys_access(module_path, 0) != 0) {
        return err_invalid_argument("module file not found");
    }
    if (sys_access(private_key, 0) != 0) {
        return err_invalid_argument("private key file not found");
    }
    if (sys_access(certificate, 0) != 0) {
        return err_invalid_argument("certificate file not found");
    }

    # Try kmodsign first
    var args = vec_new();
    vec_push(args, "kmodsign");
    vec_push(args, "sha256");
    vec_push(args, private_key);
    vec_push(args, certificate);
    vec_push(args, module_path);

    var outbuf[1024];
    var n = exec_capture(args, &outbuf, 1023);
    if (n >= 0) { return Ok(0); }

    # Fallback: sign-file from kernel headers
    var args2 = vec_new();
    vec_push(args2, "/usr/lib/modules-load.d/../linux/scripts/sign-file");
    vec_push(args2, "sha256");
    vec_push(args2, private_key);
    vec_push(args2, certificate);
    vec_push(args2, module_path);

    n = exec_capture(args2, &outbuf, 1023);
    if (n < 0) {
        return err_io(0, "kernel module signing failed (kmodsign and sign-file)");
    }

    return Ok(0);
}

# ================================================================
# Module signature verification
# ================================================================

# ModuleSignatureInfo struct
# Layout: { module_path, has_signature, signer, sig_algorithm }
# 4 fields * 8 = 32 bytes

fn secureboot_sig_info_new(module_path, has_sig, signer, algo) {
    var s = alloc(32);
    store64(s, module_path);
    store64(s + 8, has_sig);
    store64(s + 16, signer);
    store64(s + 24, algo);
    return s;
}

fn secureboot_sig_module(s) { return load64(s); }
fn secureboot_sig_has_sig(s) { return load64(s + 8); }
fn secureboot_sig_signer(s) { return load64(s + 16); }
fn secureboot_sig_algorithm(s) { return load64(s + 24); }

# Verify a kernel module's signature using modinfo.
# Returns Result: Ok(sig_info) or Err.
fn secureboot_verify_module(module_path) {
    if (module_path == 0 || strlen(module_path) == 0) {
        return err_invalid_argument("module path is empty");
    }
    if (sys_access(module_path, 0) != 0) {
        return err_invalid_argument("module file not found");
    }

    var args = vec_new();
    vec_push(args, "modinfo");
    vec_push(args, module_path);

    var outbuf = alloc(4096);
    var n = exec_capture(args, outbuf, 4095);
    if (n < 0) {
        return err_io(0, "modinfo failed");
    }
    store8(outbuf + n, 0);

    var has_sig = 0;
    var signer = "";
    var algo = "";

    # Check for sig_id: or signature:
    if (strstr(outbuf, "sig_id:") >= 0 || strstr(outbuf, "signature:") >= 0) {
        has_sig = 1;
    }

    # Extract signer
    var si = strstr(outbuf, "signer:");
    if (si >= 0) {
        var sp = si + 7;
        while (sp < n && load8(outbuf + sp) == 32) { sp = sp + 1; }
        var ss = sp;
        while (sp < n && load8(outbuf + sp) != 10) { sp = sp + 1; }
        var slen = sp - ss;
        signer = alloc(slen + 1);
        memcpy(signer, outbuf + ss, slen);
        store8(signer + slen, 0);
    }

    # Extract hash algorithm
    var ai = strstr(outbuf, "sig_hashalgo:");
    if (ai >= 0) {
        var ap = ai + 13;
        while (ap < n && load8(outbuf + ap) == 32) { ap = ap + 1; }
        var as = ap;
        while (ap < n && load8(outbuf + ap) != 10) { ap = ap + 1; }
        var alen = ap - as;
        algo = alloc(alen + 1);
        memcpy(algo, outbuf + as, alen);
        store8(algo + alen, 0);
    }

    return Ok(secureboot_sig_info_new(module_path, has_sig, signer, algo));
}

# ================================================================
# EFI variable listing
# ================================================================

# EfiVariable struct
# Layout: { name, size }
# 2 fields * 8 = 16 bytes

fn secureboot_efi_var_new(name, size) {
    var v = alloc(16);
    store64(v, name);
    store64(v + 8, size);
    return v;
}

fn secureboot_efi_var_name(v) { return load64(v); }
fn secureboot_efi_var_data_size(v) { return load64(v + 8); }

# List security-relevant EFI variables from sysfs.
# Returns Result: Ok(vec_of_efi_vars) or Err.
fn secureboot_list_efi_variables() {
    var efivars_dir = "/sys/firmware/efi/efivars";
    var fd = sys_open(efivars_dir, 0, 0);
    if (fd < 0) {
        return err_io(0 - fd, "EFI variables directory not found; is this a UEFI system?");
    }
    sys_close(fd);

    # Read directory listing via ls
    var args = vec_new();
    vec_push(args, "ls");
    vec_push(args, efivars_dir);

    var outbuf = alloc(16384);
    var n = exec_capture(args, outbuf, 16383);
    if (n < 0) {
        return err_io(0 - n, "failed to list EFI variables");
    }
    store8(outbuf + n, 0);

    var vars = vec_new();

    # Filter for security-relevant prefixes
    var pos = 0;
    while (pos < n) {
        var linestart = pos;
        while (pos < n && load8(outbuf + pos) != 10) { pos = pos + 1; }
        var linelen = pos - linestart;
        if (pos < n) { pos = pos + 1; }
        if (linelen == 0) { continue; }

        # Check if line starts with a relevant prefix
        var relevant = 0;
        if (linelen >= 10 && memeq(outbuf + linestart, "SecureBoot", 10) == 1) { relevant = 1; }
        if (linelen >= 9 && memeq(outbuf + linestart, "SetupMode", 9) == 1) { relevant = 1; }
        if (linelen >= 3 && memeq(outbuf + linestart, "PK-", 3) == 1) { relevant = 1; }
        if (linelen >= 4 && memeq(outbuf + linestart, "KEK-", 4) == 1) { relevant = 1; }
        if (linelen >= 3 && memeq(outbuf + linestart, "db-", 3) == 1) { relevant = 1; }
        if (linelen >= 4 && memeq(outbuf + linestart, "dbx-", 4) == 1) { relevant = 1; }
        if (linelen >= 7 && memeq(outbuf + linestart, "MokList", 7) == 1) { relevant = 1; }

        if (relevant == 1) {
            var name = alloc(linelen + 1);
            memcpy(name, outbuf + linestart, linelen);
            store8(name + linelen, 0);

            # Get file size via reading the variable
            var full_path = alloc(strlen(efivars_dir) + 1 + linelen + 1);
            memcpy(full_path, efivars_dir, strlen(efivars_dir));
            store8(full_path + strlen(efivars_dir), 47);  # '/'
            memcpy(full_path + strlen(efivars_dir) + 1, name, linelen + 1);

            var vres = secureboot_read_efi_variable(full_path);
            var size = 0;
            if (is_ok(vres) == 1) {
                size = secureboot_efi_var_size(payload(vres));
            }

            vec_push(vars, secureboot_efi_var_new(name, size));
        }
    }

    return Ok(vars);
}

# --- udev.cyr ---

# udev.cyr — udev device enumeration and rule validation
# Ported from rust-old/src/udev.rs
#
# Shells out to udevadm for device info. Parses output into structs.
# Rule validation rejects dangerous action keys (RUN, PROGRAM, etc).
#
# Requires: src/error.cyr, lib/syscalls.cyr, lib/process.cyr

# ================================================================
# Device subsystem constants
# ================================================================

enum DeviceSubsystem {
    SUBSYS_BLOCK = 1;
    SUBSYS_NET = 2;
    SUBSYS_INPUT = 3;
    SUBSYS_USB = 4;
    SUBSYS_PCI = 5;
    SUBSYS_TTY = 6;
    SUBSYS_GPU = 7;
    SUBSYS_SOUND = 8;
    SUBSYS_OTHER = 9;
}

# ================================================================
# DeviceInfo struct
# ================================================================

# DeviceInfo: { syspath, devpath, subsystem, devtype, driver,
    #   devnode, prop_keys, prop_vals, prop_count }
# Layout: 9 * 8 = 72 bytes
# prop_keys and prop_vals are arrays of string pointers

fn udev_devinfo_new() {
    var d = alloc(72);
    memset(d, 0, 72);
    return d;
}

fn udev_devinfo_syspath(d)    { return load64(d); }
fn udev_devinfo_devpath(d)    { return load64(d + 8); }
fn udev_devinfo_subsystem(d)  { return load64(d + 16); }
fn udev_devinfo_devtype(d)    { return load64(d + 24); }
fn udev_devinfo_driver(d)     { return load64(d + 32); }
fn udev_devinfo_devnode(d)    { return load64(d + 40); }
fn udev_devinfo_prop_keys(d)  { return load64(d + 48); }
fn udev_devinfo_prop_vals(d)  { return load64(d + 56); }
fn udev_devinfo_prop_count(d) { return load64(d + 64); }

fn udev_devinfo_set_syspath(d, v)    { store64(d, v); return 0; }
fn udev_devinfo_set_devpath(d, v)    { store64(d + 8, v); return 0; }
fn udev_devinfo_set_subsystem(d, v)  { store64(d + 16, v); return 0; }
fn udev_devinfo_set_devtype(d, v)    { store64(d + 24, v); return 0; }
fn udev_devinfo_set_driver(d, v)     { store64(d + 32, v); return 0; }
fn udev_devinfo_set_devnode(d, v)    { store64(d + 40, v); return 0; }
fn udev_devinfo_set_props(d, keys, vals, count) {
    store64(d + 48, keys);
    store64(d + 56, vals);
    store64(d + 64, count);
    return 0;
}

# ================================================================
# Parse udevadm info output for a single device
# ================================================================

# Parse a block of udevadm info output (P:/N:/S:/E: prefixed lines).
# text: null-terminated string of udevadm output.
# Returns Result: Ok(devinfo_ptr) or Err.
fn udev_parse_udevadm_info(text) {
    if (text == 0) {
        return err_invalid_argument("udevadm output is null");
    }

    var devpath = 0;
    var devnode = 0;
    # Allocate property arrays (max 128 properties)
    var max_props = 128;
    var prop_keys = alloc(max_props * 8);
    var prop_vals = alloc(max_props * 8);
    var prop_count = 0;

    # Parse line by line
    var pos = 0;
    var textlen = strlen(text);

    while (pos < textlen) {
        # Find end of line
        var linestart = pos;
        while (pos < textlen) {
            if (load8(text + pos) == 10) {
                pos = pos + 1;
                break;
            }
            pos = pos + 1;
        }
        var linelen = pos - linestart;
        if (load8(text + pos - 1) == 10) { linelen = linelen - 1; }
        if (linelen < 3) { continue; }

        # Skip leading whitespace
        var ls = linestart;
        while (ls < linestart + linelen) {
            var ch = load8(text + ls);
            if (ch != 32) { if (ch != 9) { break; } }
            ls = ls + 1;
        }
        var eff_len = linestart + linelen - ls;
        if (eff_len < 3) { continue; }

        var c0 = load8(text + ls);
        var c1 = load8(text + ls + 1);
        var c2 = load8(text + ls + 2);

        # P: devpath
        if (c0 == 80) { if (c1 == 58) { if (c2 == 32) {
                    var vlen = eff_len - 3;
                    var v = alloc(vlen + 1);
                    memcpy(v, text + ls + 3, vlen);
                    store8(v + vlen, 0);
                    devpath = v;
                    continue;
                } } }

        # N: devnode
        if (c0 == 78) { if (c1 == 58) { if (c2 == 32) {
                    var vlen = eff_len - 3;
                    # Prepend /dev/
                    var v = alloc(vlen + 6);
                    memcpy(v, "/dev/", 5);
                    memcpy(v + 5, text + ls + 3, vlen);
                    store8(v + 5 + vlen, 0);
                    devnode = v;
                    continue;
                } } }

        # E: key=value property
        if (c0 == 69) { if (c1 == 58) { if (c2 == 32) {
                    if (prop_count < max_props) {
                        var vstart = ls + 3;
                        var vlen = eff_len - 3;
                        # Find '=' separator
                        var eq_pos = 0;
                        var j = 0;
                        while (j < vlen) {
                            if (load8(text + vstart + j) == 61) {  # '='
                                eq_pos = j;
                                break;
                            }
                            j = j + 1;
                        }
                        if (eq_pos > 0) {
                            var klen = eq_pos;
                            var key = alloc(klen + 1);
                            memcpy(key, text + vstart, klen);
                            store8(key + klen, 0);

                            var val_offset = eq_pos + 1;
                            var val_len = vlen - val_offset;
                            var val = alloc(val_len + 1);
                            memcpy(val, text + vstart + val_offset, val_len);
                            store8(val + val_len, 0);

                            store64(prop_keys + prop_count * 8, key);
                            store64(prop_vals + prop_count * 8, val);
                            prop_count = prop_count + 1;
                        }
                    }
                    continue;
                } } }
    }

    if (devpath == 0) {
        return err_invalid_argument("udevadm output missing P: (devpath) line");
    }

    # Build syspath = "/sys" + devpath
    var dplen = strlen(devpath);
    var syspath = alloc(dplen + 5);
    memcpy(syspath, "/sys", 4);
    memcpy(syspath + 4, devpath, dplen);
    store8(syspath + 4 + dplen, 0);

    # Extract subsystem and other properties from the property list
    var subsystem = "";
    var devtype = 0;
    var driver = 0;
    var i = 0;
    while (i < prop_count) {
        var key = load64(prop_keys + i * 8);
        var val = load64(prop_vals + i * 8);
        if (streq(key, "SUBSYSTEM") == 1) { subsystem = val; }
        if (streq(key, "DEVTYPE") == 1) { devtype = val; }
        if (streq(key, "DRIVER") == 1) { driver = val; }
        if (devnode == 0) {
            if (streq(key, "DEVNAME") == 1) { devnode = val; }
        }
        i = i + 1;
    }

    var info = udev_devinfo_new();
    udev_devinfo_set_syspath(info, syspath);
    udev_devinfo_set_devpath(info, devpath);
    udev_devinfo_set_subsystem(info, subsystem);
    udev_devinfo_set_devtype(info, devtype);
    udev_devinfo_set_driver(info, driver);
    udev_devinfo_set_devnode(info, devnode);
    udev_devinfo_set_props(info, prop_keys, prop_vals, prop_count);

    return Ok(info);
}

# ================================================================
# List devices via udevadm info --export-db
# ================================================================

# List all devices, optionally filtered by subsystem string.
# subsystem_filter: a null-terminated string, or 0 for no filter.
# result_arr: pre-allocated array of device pointers.
# max_devices: max capacity of result_arr.
# Returns Result: Ok(count) or Err.
fn udev_list_devices(subsystem_filter, result_arr, max_devices) {
    var cmd = "udevadm";
    var argv = alloc(24);
    store64(argv, cmd);
    var arg1 = "info";
    store64(argv + 8, arg1);
    var arg2 = "--export-db";
    store64(argv + 16, arg2);

    var res = run_capture(cmd, argv);
    if (is_err_result(res) == 1) { return res; }

    var output = payload(res);
    if (output == 0) {
        return Ok(0);
    }

    # Split output into blocks separated by blank lines, parse each
    var count = 0;
    var textlen = strlen(output);
    var block_start = 0;
    var pos = 0;

    while (pos <= textlen) {
        var at_end = 0;
        if (pos == textlen) { at_end = 1; }
        elif (load8(output + pos) == 10) {
            # Check if next char is also newline (blank line)
            if (pos + 1 < textlen) {
                if (load8(output + pos + 1) == 10) { at_end = 1; }
            }
        }

        if (at_end == 1) {
            if (pos > block_start) {
                # Extract block
                var blen = pos - block_start;
                var block = alloc(blen + 1);
                memcpy(block, output + block_start, blen);
                store8(block + blen, 0);

                var dev_res = udev_parse_udevadm_info(block);
                if (is_ok(dev_res) == 1) {
                    var dev = payload(dev_res);
                    var include = 1;
                    if (subsystem_filter != 0) {
                        if (strlen(subsystem_filter) > 0) {
                            var dev_sub = udev_devinfo_subsystem(dev);
                            if (streq(dev_sub, subsystem_filter) != 1) {
                                include = 0;
                            }
                        }
                    }
                    if (include == 1) {
                        if (count < max_devices) {
                            store64(result_arr + count * 8, dev);
                            count = count + 1;
                        }
                    }
                }
            }
            # Skip blank lines
            while (pos < textlen) {
                if (load8(output + pos) == 10) { pos = pos + 1; }
                else { break; }
            }
            block_start = pos;
            continue;
        }
        pos = pos + 1;
    }

    return Ok(count);
}

# ================================================================
# Get device info for a single device by sysfs path
# ================================================================

fn udev_get_device_info(syspath) {
    if (syspath == 0) {
        return err_invalid_argument("syspath is null");
    }
    if (strlen(syspath) == 0) {
        return err_invalid_argument("syspath cannot be empty");
    }

    var cmd = "udevadm";
    # Build --path=<syspath> argument
    var prefix = "--path=";
    var plen = strlen(prefix);
    var slen = strlen(syspath);
    var patharg = alloc(plen + slen + 1);
    memcpy(patharg, prefix, plen);
    memcpy(patharg + plen, syspath, slen);
    store8(patharg + plen + slen, 0);

    var argv = alloc(24);
    store64(argv, cmd);
    var arg1 = "info";
    store64(argv + 8, arg1);
    store64(argv + 16, patharg);

    var res = run_capture(cmd, argv);
    if (is_err_result(res) == 1) { return res; }

    var output = payload(res);
    return udev_parse_udevadm_info(output);
}

# ================================================================
# Udev rule validation
# ================================================================

# Dangerous action keys that must be rejected
# RUN, PROGRAM, IMPORT{program}, IMPORT{builtin}

# Check if a string starts with a given prefix
fn udev_starts_with(str, prefix) {
    var slen = strlen(str);
    var plen = strlen(prefix);
    if (slen < plen) { return 0; }
    var i = 0;
    while (i < plen) {
        if (load8(str + i) != load8(prefix + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Validate a udev rule.
# action_keys: array of string pointers to action key names.
# action_count: number of action keys.
# Returns Result: Ok(0) if valid, Err if dangerous keys found.
fn udev_validate_rule(action_keys, action_count) {
    var i = 0;
    while (i < action_count) {
        var key = load64(action_keys + i * 8);
        # Reject dangerous action keys
        if (streq(key, "RUN") == 1) {
            return err_invalid_argument("udev rule contains dangerous key: RUN");
        }
        if (streq(key, "PROGRAM") == 1) {
            return err_invalid_argument("udev rule contains dangerous key: PROGRAM");
        }
        if (udev_starts_with(key, "IMPORT{program}") == 1) {
            return err_invalid_argument("udev rule contains dangerous key: IMPORT{program}");
        }
        if (udev_starts_with(key, "IMPORT{builtin}") == 1) {
            return err_invalid_argument("udev rule contains dangerous key: IMPORT{builtin}");
        }
        i = i + 1;
    }
    return Ok(0);
}

# Parse a subsystem string into a constant
fn udev_parse_subsystem(s) {
    if (streq(s, "block") == 1) { return SUBSYS_BLOCK; }
    if (streq(s, "net") == 1) { return SUBSYS_NET; }
    if (streq(s, "input") == 1) { return SUBSYS_INPUT; }
    if (streq(s, "usb") == 1) { return SUBSYS_USB; }
    if (streq(s, "pci") == 1) { return SUBSYS_PCI; }
    if (streq(s, "tty") == 1) { return SUBSYS_TTY; }
    if (streq(s, "drm") == 1) { return SUBSYS_GPU; }
    if (streq(s, "sound") == 1) { return SUBSYS_SOUND; }
    if (streq(s, "snd") == 1) { return SUBSYS_SOUND; }
    return SUBSYS_OTHER;
}

# --- drm.cyr ---

# drm.cyr — DRM (Direct Rendering Manager) device interface
# Ported from rust-old/src/drm.rs
#
# Enumerate GPU devices under /dev/dri/, query driver version
# and capabilities via ioctl. Uses raw syscalls for fd management
# and ioctl invocation.
#
# Requires: src/error.cyr, lib/syscalls.cyr

#define LINUX

# ================================================================
# DRM ioctl constants
# ================================================================

# DRM ioctl type byte is 'd' (0x64)
# _IOWR('d', nr, size) = (3 << 30) | (size << 16) | (0x64 << 8) | nr

# DRM_IOCTL_VERSION: _IOWR('d', 0x00, 72)  [DrmVersion is 72 bytes]
# = (3 << 30) | (72 << 16) | (0x64 << 8) | 0x00
# = 0xC0486400

# DRM_IOCTL_GET_CAP: _IOWR('d', 0x0C, 16)  [DrmGetCap is 16 bytes]
# = (3 << 30) | (16 << 16) | (0x64 << 8) | 0x0C
# = 0xC010640C

enum DrmIoctl {
    DRM_IOCTL_VERSION = 0xC0486400;
    DRM_IOCTL_GET_CAP = 0xC010640C;
}

# DRM capability IDs
enum DrmCap {
    DRM_CAP_DUMB_BUFFER = 1;
    DRM_CAP_VBLANK_HIGH_CRTC = 2;
    DRM_CAP_DUMB_PREFERRED_DEPTH = 3;
    DRM_CAP_DUMB_PREFER_SHADOW = 4;
    DRM_CAP_PRIME = 5;
    DRM_CAP_TIMESTAMP_MONOTONIC = 6;
    DRM_CAP_ASYNC_PAGE_FLIP = 7;
    DRM_CAP_CURSOR_WIDTH = 8;
    DRM_CAP_CURSOR_HEIGHT = 9;
    DRM_CAP_ADDFB2_MODIFIERS = 16;
    DRM_CAP_PAGE_FLIP_TARGET = 17;
    DRM_CAP_CRTC_IN_VBLANK_EVENT = 18;
    DRM_CAP_SYNCOBJ = 19;
    DRM_CAP_SYNCOBJ_TIMELINE = 20;
}

# Connector type constants
enum DrmConnectorType {
    DRM_CONN_UNKNOWN = 0;
    DRM_CONN_VGA = 1;
    DRM_CONN_DVII = 2;
    DRM_CONN_DVID = 3;
    DRM_CONN_DVIA = 4;
    DRM_CONN_COMPOSITE = 5;
    DRM_CONN_SVIDEO = 6;
    DRM_CONN_LVDS = 7;
    DRM_CONN_COMPONENT = 8;
    DRM_CONN_DISPLAYPORT = 10;
    DRM_CONN_HDMIA = 11;
    DRM_CONN_HDMIB = 12;
    DRM_CONN_TV = 13;
    DRM_CONN_EDP = 14;
    DRM_CONN_VIRTUAL = 15;
    DRM_CONN_DSI = 16;
    DRM_CONN_USB = 20;
}

# Connection status
enum DrmConnStatus {
    DRM_CONNECTED = 1;
    DRM_DISCONNECTED = 2;
    DRM_CONN_STATUS_UNKNOWN = 3;
}

# ================================================================
# Syscall numbers
# ================================================================

enum DrmSysNr {
    SYS_IOCTL = 16;
    SYS_GETDENTS64 = 217;
}

# ================================================================
# DRM Version struct (on-wire for ioctl)
# ================================================================

# DrmVersion layout (72 bytes):
#   +0:  version_major    (i32, 4 bytes)
#   +4:  version_minor    (i32, 4 bytes)
#   +8:  version_patchlevel (i32, 4 bytes)
#   +12: padding          (4 bytes)
#   +16: name_len         (u64)
#   +24: name_ptr         (u64)
#   +32: date_len         (u64)
#   +40: date_ptr         (u64)
#   +48: desc_len         (u64)
#   +56: desc_ptr         (u64)
# Total: 64 bytes (with packing)

enum DrmVerOff {
    DRM_VER_SIZE = 72;
    DRM_VER_MAJOR = 0;
    DRM_VER_MINOR = 4;
    DRM_VER_PATCH = 8;
    DRM_VER_NAME_LEN = 16;
    DRM_VER_NAME_PTR = 24;
    DRM_VER_DATE_LEN = 32;
    DRM_VER_DATE_PTR = 40;
    DRM_VER_DESC_LEN = 48;
    DRM_VER_DESC_PTR = 56;
}

# DrmGetCap layout (16 bytes):
#   +0: capability (u64)
#   +8: value      (u64)

# ================================================================
# Version result struct
# ================================================================

# DrmVersionInfo: { major, minor, patchlevel, name_ptr, date_ptr, desc_ptr }
# Layout: 48 bytes

fn drm_verinfo_new(major, minor, patch, name, date, desc) {
    var v = alloc(48);
    store64(v, major);
    store64(v + 8, minor);
    store64(v + 16, patch);
    store64(v + 24, name);
    store64(v + 32, date);
    store64(v + 40, desc);
    return v;
}

fn drm_verinfo_major(v) { return load64(v); }
fn drm_verinfo_minor(v) { return load64(v + 8); }
fn drm_verinfo_patch(v) { return load64(v + 16); }
fn drm_verinfo_name(v) { return load64(v + 24); }
fn drm_verinfo_date(v) { return load64(v + 32); }
fn drm_verinfo_desc(v) { return load64(v + 40); }

# ================================================================
# Device enumeration
# ================================================================

# List DRM card device paths under /dev/dri/.
# result_arr: pre-allocated array of string pointers.
# max_cards: capacity of result_arr.
# Returns Result: Ok(count) or Err.
fn drm_list_devices(result_arr, max_cards) {
    # Open /dev/dri/ directory
    var dri_path = "/dev/dri";
    # O_RDONLY | O_DIRECTORY = 0x10000
    var fd = sys_open(dri_path, 0x10000, 0);
    if (fd < 0) {
        return err_not_supported("DRM (/dev/dri not found)");
    }
    defer { sys_close(fd); }

    # Read directory entries
    var buf = alloc(4096);
    var count = 0;

    var nread = syscall(SYS_GETDENTS64, fd, buf, 4096);
    while (nread > 0) {
        var pos = 0;
        while (pos < nread) {
            # dirent64: d_ino(8), d_off(8), d_reclen(2), d_type(1), d_name(...)
            var reclen = load16(buf + pos + 16);
            var name_ptr = buf + pos + 19;

            # Check if name starts with "card"
            if (memeq(name_ptr, "card", 4) == 1) {
                if (count < max_cards) {
                    var nlen = strlen(name_ptr);
                    var path = alloc(10 + nlen);
                    memcpy(path, "/dev/dri/", 9);
                    memcpy(path + 9, name_ptr, nlen);
                    store8(path + 9 + nlen, 0);
                    store64(result_arr + count * 8, path);
                    count = count + 1;
                }
            }
            pos = pos + reclen;
        }
        nread = syscall(SYS_GETDENTS64, fd, buf, 4096);
    }

    return Ok(count);
}

# ================================================================
# Open a DRM device
# ================================================================

# Open a DRM device by path. Returns Result: Ok(fd) or Err.
fn drm_open(path) {
    if (path == 0) {
        return err_invalid_argument("drm device path is null");
    }
    # O_RDWR | O_CLOEXEC = 0x80002
    var fd = sys_open(path, 0x80002, 0);
    if (fd < 0) {
        return err_io(0 - fd, "failed to open DRM device");
    }
    return Ok(fd);
}

# Close a DRM device fd.
fn drm_close(fd) {
    sys_close(fd);
    return 0;
}

# ================================================================
# Query driver version
# ================================================================

# Get the DRM driver version for an open device fd.
# Returns Result: Ok(drm_verinfo_ptr) or Err.
fn drm_get_driver_version(fd) {
    # First call: get string lengths
    var ver = alloc(DRM_VER_SIZE);
    memset(ver, 0, DRM_VER_SIZE);

    var ret = syscall(SYS_IOCTL, fd, DRM_IOCTL_VERSION, ver);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "DRM_IOCTL_VERSION (lengths) failed");
    }

    # Read reported lengths (cap at 4096)
    var name_len = load64(ver + DRM_VER_NAME_LEN);
    var date_len = load64(ver + DRM_VER_DATE_LEN);
    var desc_len = load64(ver + DRM_VER_DESC_LEN);
    if (name_len > 4096) { name_len = 4096; }
    if (date_len > 4096) { date_len = 4096; }
    if (desc_len > 4096) { desc_len = 4096; }

    # Allocate buffers
    var name_buf = alloc(name_len + 1);
    var date_buf = alloc(date_len + 1);
    var desc_buf = alloc(desc_len + 1);
    memset(name_buf, 0, name_len + 1);
    memset(date_buf, 0, date_len + 1);
    memset(desc_buf, 0, desc_len + 1);

    # Second call: fill buffers
    store64(ver + DRM_VER_NAME_LEN, name_len);
    store64(ver + DRM_VER_NAME_PTR, name_buf);
    store64(ver + DRM_VER_DATE_LEN, date_len);
    store64(ver + DRM_VER_DATE_PTR, date_buf);
    store64(ver + DRM_VER_DESC_LEN, desc_len);
    store64(ver + DRM_VER_DESC_PTR, desc_buf);

    ret = syscall(SYS_IOCTL, fd, DRM_IOCTL_VERSION, ver);
    if (ret < 0) {
        return err_syscall_failed(0 - ret, "DRM_IOCTL_VERSION (fill) failed");
    }

    var major = load32(ver + DRM_VER_MAJOR);
    var minor = load32(ver + DRM_VER_MINOR);
    var patch = load32(ver + DRM_VER_PATCH);

    var info = drm_verinfo_new(major, minor, patch, name_buf, date_buf, desc_buf);
    return Ok(info);
}

# ================================================================
# Query capability
# ================================================================

# Query a DRM capability value for an open device fd.
# cap: one of the DRM_CAP_* constants.
# Returns Result: Ok(value) or Err.
fn drm_get_capability(fd, cap) {
    # DrmGetCap struct: { capability: u64, value: u64 } = 16 bytes
    var getcap = alloc(16);
    store64(getcap, cap);
    store64(getcap + 8, 0);

    var ret = syscall(SYS_IOCTL, fd, DRM_IOCTL_GET_CAP, getcap);
    if (ret < 0) {
        var errno = 0 - ret;
        # EINVAL means capability not supported, return 0
        if (errno == EINVAL) { return Ok(0); }
        return err_syscall_failed(errno, "DRM_IOCTL_GET_CAP failed");
    }

    var value = load64(getcap + 8);
    return Ok(value);
}

# Check if device supports dumb buffers.
# Returns Result: Ok(1) or Ok(0).
fn drm_supports_dumb_buffer(fd) {
    var res = drm_get_capability(fd, DRM_CAP_DUMB_BUFFER);
    if (is_err_result(res) == 1) { return res; }
    var val = payload(res);
    if (val != 0) { return Ok(1); }
    return Ok(0);
}

# --- netns.cyr ---

# netns.cyr — per-agent network namespace management
# Ported from rust-old/src/netns.rs
#
# Creates isolated network namespaces with veth pairs for AGNOS agents.
# Shells out to `ip` (standard practice — avoids raw netlink).
# Firewall policy rendered as nftables rulesets.
#
# Requires: src/error.cyr, lib/syscalls.cyr, lib/process.cyr

# ================================================================
# Traffic direction / protocol / action constants
# ================================================================

enum TrafficDir {
    TRAFFIC_INBOUND = 1;
    TRAFFIC_OUTBOUND = 2;
}

enum NetProtocol {
    PROTO_TCP = 1;
    PROTO_UDP = 2;
    PROTO_ANY = 3;
}

enum FwAction {
    FW_ACCEPT = 1;
    FW_DROP = 2;
}

# ================================================================
# NetNamespaceConfig struct
# ================================================================

# Layout: { name, agent_ip, host_ip, prefix_len, enable_nat, dns_arr, dns_count }
# 7 fields * 8 = 56 bytes

fn netns_config_new(name, agent_ip, host_ip, prefix_len, enable_nat) {
    var c = alloc(56);
    store64(c, name);
    store64(c + 8, agent_ip);
    store64(c + 16, host_ip);
    store64(c + 24, prefix_len);
    store64(c + 32, enable_nat);
    store64(c + 40, 0);  # dns_arr
    store64(c + 48, 0);  # dns_count
    return c;
}

fn netns_config_name(c) { return load64(c); }
fn netns_config_agent_ip(c) { return load64(c + 8); }
fn netns_config_host_ip(c) { return load64(c + 16); }
fn netns_config_prefix_len(c) { return load64(c + 24); }
fn netns_config_enable_nat(c) { return load64(c + 32); }

fn netns_config_set_dns(c, dns_arr, dns_count) {
    store64(c + 40, dns_arr);
    store64(c + 48, dns_count);
    return 0;
}

# ================================================================
# NetNamespaceHandle struct
# ================================================================

# Layout: { name, veth_host, veth_agent, netns_path }
# 4 fields * 8 = 32 bytes

fn netns_handle_new(name, veth_host, veth_agent, netns_path) {
    var h = alloc(32);
    store64(h, name);
    store64(h + 8, veth_host);
    store64(h + 16, veth_agent);
    store64(h + 24, netns_path);
    return h;
}

fn netns_handle_name(h) { return load64(h); }
fn netns_handle_veth_host(h) { return load64(h + 8); }
fn netns_handle_veth_agent(h) { return load64(h + 16); }
fn netns_handle_netns_path(h) { return load64(h + 24); }

# ================================================================
# FirewallRule struct
# ================================================================

# Layout: { direction, protocol, port, remote_addr, action, comment }
# 6 fields * 8 = 48 bytes

fn netns_fw_rule_new(direction, protocol, port, remote_addr, action, comment) {
    var r = alloc(48);
    store64(r, direction);
    store64(r + 8, protocol);
    store64(r + 16, port);
    store64(r + 24, remote_addr);
    store64(r + 32, action);
    store64(r + 40, comment);
    return r;
}

fn netns_fw_rule_direction(r) { return load64(r); }
fn netns_fw_rule_protocol(r) { return load64(r + 8); }
fn netns_fw_rule_port(r) { return load64(r + 16); }
fn netns_fw_rule_remote_addr(r) { return load64(r + 24); }
fn netns_fw_rule_action(r) { return load64(r + 32); }
fn netns_fw_rule_comment(r) { return load64(r + 40); }

# ================================================================
# FirewallPolicy struct
# ================================================================

# Layout: { default_inbound, default_outbound, rules_arr, rule_count }
# 4 fields * 8 = 32 bytes

fn netns_fw_policy_new(default_in, default_out) {
    var p = alloc(32);
    store64(p, default_in);
    store64(p + 8, default_out);
    store64(p + 16, 0);
    store64(p + 24, 0);
    return p;
}

fn netns_fw_policy_default_in(p) { return load64(p); }
fn netns_fw_policy_default_out(p) { return load64(p + 8); }
fn netns_fw_policy_rules(p) { return load64(p + 16); }
fn netns_fw_policy_rule_count(p) { return load64(p + 24); }

fn netns_fw_policy_set_rules(p, rules_arr, count) {
    store64(p + 16, rules_arr);
    store64(p + 24, count);
    return 0;
}

# ================================================================
# IP address generation from agent name hash
# ================================================================

# Simple hash function for agent name -> 10.100.x.{1,2}/30
fn netns_hash_name(name) {
    var h = 5381;
    var i = 0;
    var len = strlen(name);
    while (i < len) {
        var c = load8(name + i);
        h = h * 33 + c;
        i = i + 1;
    }
    # Make positive
    if (h < 0) { h = 0 - h; }
    return h;
}

# Generate agent IPs. Returns a struct { host_ip, agent_ip }.
fn netns_generate_agent_ips(agent_name) {
    var h = netns_hash_name(agent_name);
    var third = h % 255;

    # Build "10.100.X.1" and "10.100.X.2"
    var host_ip = alloc(16);
    var agent_ip = alloc(16);

    var prefix = "10.100.";
    memcpy(host_ip, prefix, 7);
    memcpy(agent_ip, prefix, 7);

    # Convert third octet to string
    var tbuf = alloc(4);
    var tlen = fmt_int_buf(third, tbuf);

    memcpy(host_ip + 7, tbuf, tlen);
    store8(host_ip + 7 + tlen, 46);  # '.'
    store8(host_ip + 7 + tlen + 1, 49);  # '1'
    store8(host_ip + 7 + tlen + 2, 0);

    memcpy(agent_ip + 7, tbuf, tlen);
    store8(agent_ip + 7 + tlen, 46);  # '.'
    store8(agent_ip + 7 + tlen + 1, 50);  # '2'
    store8(agent_ip + 7 + tlen + 2, 0);

    var result = alloc(16);
    store64(result, host_ip);
    store64(result + 8, agent_ip);
    return result;
}

# ================================================================
# Create convenience config for an agent
# ================================================================

fn netns_config_for_agent(name) {
    var ips = netns_generate_agent_ips(name);
    var host_ip = load64(ips);
    var agent_ip = load64(ips + 8);
    return netns_config_new(name, agent_ip, host_ip, 30, 1);
}

# ================================================================
# Validate namespace config
# ================================================================

fn netns_validate_config(config) {
    var name = netns_config_name(config);
    if (name == 0) { return err_invalid_argument("namespace name is null"); }
    if (strlen(name) == 0) { return err_invalid_argument("namespace name cannot be empty"); }
    if (strlen(name) > 64) { return err_invalid_argument("namespace name too long (max 64)"); }

    var aip = netns_config_agent_ip(config);
    var hip = netns_config_host_ip(config);
    if (aip == 0) { return err_invalid_argument("agent IP is null"); }
    if (hip == 0) { return err_invalid_argument("host IP is null"); }
    if (strlen(aip) == 0) { return err_invalid_argument("agent IP cannot be empty"); }
    if (strlen(hip) == 0) { return err_invalid_argument("host IP cannot be empty"); }

    var plen = netns_config_prefix_len(config);
    if (plen == 0) { return err_invalid_argument("invalid prefix length: 0"); }
    if (plen > 32) { return err_invalid_argument("invalid prefix length: > 32"); }

    return Ok(0);
}

# ================================================================
# Truncate veth name to 15 chars (Linux max)
# ================================================================

fn netns_truncate_veth(base) {
    var len = strlen(base);
    if (len <= 15) {
        var out = alloc(len + 1);
        memcpy(out, base, len);
        store8(out + len, 0);
        return out;
    }
    var out = alloc(16);
    memcpy(out, base, 15);
    store8(out + 15, 0);
    return out;
}

# ================================================================
# Helper: run ip command
# ================================================================

fn netns_run_ip(argv) {
    var cmd = "ip";
    var res = run_capture(cmd, argv);
    if (is_err_result(res) == 1) { return res; }
    return Ok(0);
}

# ================================================================
# Build a string by concatenating parts
# ================================================================

fn netns_concat2(a, b) {
    var alen = strlen(a);
    var blen = strlen(b);
    var out = alloc(alen + blen + 1);
    memcpy(out, a, alen);
    memcpy(out + alen, b, blen);
    store8(out + alen + blen, 0);
    return out;
}

fn netns_concat3(a, b, c) {
    var ab = netns_concat2(a, b);
    return netns_concat2(ab, c);
}

# ================================================================
# Create agent network namespace
# ================================================================

# Create a network namespace for an agent with veth pair and IP configuration.
# Returns Result: Ok(handle_ptr) or Err.
fn netns_create_agent_netns(config) {
    var vres = netns_validate_config(config);
    if (is_err_result(vres) == 1) { return vres; }

    var name = netns_config_name(config);
    var ns_name = netns_concat2("agnos-agent-", name);
    var veth_host = netns_truncate_veth(netns_concat3("veth-", name, "-h"));
    var veth_agent = netns_truncate_veth(netns_concat3("veth-", name, "-a"));

    # 1. Create namespace: ip netns add <ns_name>
    var argv1 = alloc(32);
    store64(argv1, "ip");
    store64(argv1 + 8, "netns");
    store64(argv1 + 16, "add");
    store64(argv1 + 24, ns_name);
    var res = netns_run_ip(argv1);
    if (is_err_result(res) == 1) { return res; }

    # 2. Create veth pair: ip link add <host> type veth peer name <agent>
    var argv2 = alloc(72);
    store64(argv2, "ip");
    store64(argv2 + 8, "link");
    store64(argv2 + 16, "add");
    store64(argv2 + 24, veth_host);
    store64(argv2 + 32, "type");
    store64(argv2 + 40, "veth");
    store64(argv2 + 48, "peer");
    store64(argv2 + 56, "name");
    store64(argv2 + 64, veth_agent);
    res = netns_run_ip(argv2);
    if (is_err_result(res) == 1) {
        # Cleanup namespace
        var cleanup = alloc(32);
        store64(cleanup, "ip");
        store64(cleanup + 8, "netns");
        store64(cleanup + 16, "delete");
        store64(cleanup + 24, ns_name);
        netns_run_ip(cleanup);
        return res;
    }

    # 3. Move agent veth into namespace: ip link set <agent> netns <ns>
    var argv3 = alloc(48);
    store64(argv3, "ip");
    store64(argv3 + 8, "link");
    store64(argv3 + 16, "set");
    store64(argv3 + 24, veth_agent);
    store64(argv3 + 32, "netns");
    store64(argv3 + 40, ns_name);
    res = netns_run_ip(argv3);
    if (is_err_result(res) == 1) {
        # Cleanup
        var cl1 = alloc(32);
        store64(cl1, "ip");
        store64(cl1 + 8, "link");
        store64(cl1 + 16, "delete");
        store64(cl1 + 24, veth_host);
        netns_run_ip(cl1);
        var cl2 = alloc(32);
        store64(cl2, "ip");
        store64(cl2 + 8, "netns");
        store64(cl2 + 16, "delete");
        store64(cl2 + 24, ns_name);
        netns_run_ip(cl2);
        return res;
    }

    # 4. Assign IPs
    var plen_str = alloc(4);
    var plen_slen = fmt_int_buf(netns_config_prefix_len(config), plen_str);
    store8(plen_str + plen_slen, 0);

    var host_cidr = netns_concat3(netns_config_host_ip(config), "/", plen_str);
    var agent_cidr = netns_concat3(netns_config_agent_ip(config), "/", plen_str);

    # ip addr add <host_cidr> dev <veth_host>
    var argv4 = alloc(48);
    store64(argv4, "ip");
    store64(argv4 + 8, "addr");
    store64(argv4 + 16, "add");
    store64(argv4 + 24, host_cidr);
    store64(argv4 + 32, "dev");
    store64(argv4 + 40, veth_host);
    netns_run_ip(argv4);

    # ip netns exec <ns> ip addr add <agent_cidr> dev <agent>
    var argv5 = alloc(72);
    store64(argv5, "ip");
    store64(argv5 + 8, "netns");
    store64(argv5 + 16, "exec");
    store64(argv5 + 24, ns_name);
    store64(argv5 + 32, "ip");
    store64(argv5 + 40, "addr");
    store64(argv5 + 48, "add");
    store64(argv5 + 56, agent_cidr);
    store64(argv5 + 64, "dev");
    # Need 11th element
    var argv5b = alloc(88);
    memcpy(argv5b, argv5, 72);
    store64(argv5b + 72, veth_agent);
    netns_run_ip(argv5b);

    # 5. Bring interfaces up
    var argv6 = alloc(40);
    store64(argv6, "ip");
    store64(argv6 + 8, "link");
    store64(argv6 + 16, "set");
    store64(argv6 + 24, veth_host);
    store64(argv6 + 32, "up");
    netns_run_ip(argv6);

    # Bring up agent side in namespace
    var argv7 = alloc(64);
    store64(argv7, "ip");
    store64(argv7 + 8, "netns");
    store64(argv7 + 16, "exec");
    store64(argv7 + 24, ns_name);
    store64(argv7 + 32, "ip");
    store64(argv7 + 40, "link");
    store64(argv7 + 48, "set");
    store64(argv7 + 56, veth_agent);
    var argv7b = alloc(80);
    memcpy(argv7b, argv7, 64);
    store64(argv7b + 64, "up");
    netns_run_ip(argv7b);

    # Bring up loopback in namespace
    var argv8 = alloc(72);
    store64(argv8, "ip");
    store64(argv8 + 8, "netns");
    store64(argv8 + 16, "exec");
    store64(argv8 + 24, ns_name);
    store64(argv8 + 32, "ip");
    store64(argv8 + 40, "link");
    store64(argv8 + 48, "set");
    store64(argv8 + 56, "lo");
    store64(argv8 + 64, "up");
    netns_run_ip(argv8);

    # Set default route inside namespace
    var argv9 = alloc(80);
    store64(argv9, "ip");
    store64(argv9 + 8, "netns");
    store64(argv9 + 16, "exec");
    store64(argv9 + 24, ns_name);
    store64(argv9 + 32, "ip");
    store64(argv9 + 40, "route");
    store64(argv9 + 48, "add");
    store64(argv9 + 56, "default");
    store64(argv9 + 64, "via");
    store64(argv9 + 72, netns_config_host_ip(config));
    netns_run_ip(argv9);

    # Build netns path
    var netns_path = netns_concat2("/var/run/netns/", ns_name);

    var handle = netns_handle_new(ns_name, veth_host, veth_agent, netns_path);
    return Ok(handle);
}

# ================================================================
# Destroy agent network namespace
# ================================================================

fn netns_destroy_agent_netns(handle) {
    var veth_host = netns_handle_veth_host(handle);
    var ns_name = netns_handle_name(handle);

    # Delete host-side veth (peer is auto-deleted)
    var argv1 = alloc(32);
    store64(argv1, "ip");
    store64(argv1 + 8, "link");
    store64(argv1 + 16, "delete");
    store64(argv1 + 24, veth_host);
    netns_run_ip(argv1);

    # Delete namespace
    var argv2 = alloc(32);
    store64(argv2, "ip");
    store64(argv2 + 8, "netns");
    store64(argv2 + 16, "delete");
    store64(argv2 + 24, ns_name);
    return netns_run_ip(argv2);
}

# ================================================================
# Render nftables ruleset from FirewallPolicy
# ================================================================

# Helper to append a string to a buffer, return new position.
# Checks bounds against buf_size; if exceeded, returns pos unchanged (truncation).
fn netns_nft_append(buf, pos, str) {
    var len = strlen(str);
    if (pos + len >= 16384) { return pos; }
    memcpy(buf + pos, str, len);
    return pos + len;
}

fn netns_nft_action_str(action) {
    if (action == FW_ACCEPT) { return "accept"; }
    return "drop";
}

fn netns_nft_proto_str(proto) {
    if (proto == PROTO_TCP) { return "tcp"; }
    if (proto == PROTO_UDP) { return "udp"; }
    return 0;
}

# Render a FirewallPolicy into an nftables ruleset string.
# Returns a heap-allocated null-terminated string.
fn netns_render_nftables_ruleset(policy) {
    var buf_size = 16384;
    var buf = alloc(buf_size);
    var pos = 0;

    pos = netns_nft_append(buf, pos, "table inet kavach {\n");

        # Input chain
        pos = netns_nft_append(buf, pos, "  chain input { type filter hook input priority 0; policy ");
            pos = netns_nft_append(buf, pos, netns_nft_action_str(netns_fw_policy_default_in(policy)));
            pos = netns_nft_append(buf, pos, ";\n");
            pos = netns_nft_append(buf, pos, "    ct state established,related accept\n");
            pos = netns_nft_append(buf, pos, "    iif lo accept\n");

            var rules = netns_fw_policy_rules(policy);
            var count = netns_fw_policy_rule_count(policy);
            var i = 0;
            while (i < count) {
                var rule = load64(rules + i * 8);
                if (netns_fw_rule_direction(rule) == TRAFFIC_INBOUND) {
                    var action = netns_nft_action_str(netns_fw_rule_action(rule));
                    var proto = netns_nft_proto_str(netns_fw_rule_protocol(rule));
                    var port = netns_fw_rule_port(rule);
                    if (proto != 0) {
                        if (port > 0) {
                            pos = netns_nft_append(buf, pos, "    ");
                            pos = netns_nft_append(buf, pos, proto);
                            pos = netns_nft_append(buf, pos, " dport ");
                            var pbuf = alloc(8);
                            var plen = fmt_int_buf(port, pbuf);
                            store8(pbuf + plen, 0);
                            pos = netns_nft_append(buf, pos, pbuf);
                            pos = netns_nft_append(buf, pos, " ");
                            pos = netns_nft_append(buf, pos, action);
                            pos = netns_nft_append(buf, pos, " comment \"");
                            pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                            pos = netns_nft_append(buf, pos, "\"\n");
                        }
                    }
                    var raddr = netns_fw_rule_remote_addr(rule);
                    if (raddr != 0) {
                        if (strlen(raddr) > 0) {
                            pos = netns_nft_append(buf, pos, "    ip saddr ");
                            pos = netns_nft_append(buf, pos, raddr);
                            pos = netns_nft_append(buf, pos, " ");
                            pos = netns_nft_append(buf, pos, action);
                            pos = netns_nft_append(buf, pos, " comment \"");
                            pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                            pos = netns_nft_append(buf, pos, "\"\n");
                        }
                    }
                }
                i = i + 1;
            }
            pos = netns_nft_append(buf, pos, "  }\n");

        # Output chain
        pos = netns_nft_append(buf, pos, "  chain output { type filter hook output priority 0; policy ");
            pos = netns_nft_append(buf, pos, netns_nft_action_str(netns_fw_policy_default_out(policy)));
            pos = netns_nft_append(buf, pos, ";\n");
            pos = netns_nft_append(buf, pos, "    ct state established,related accept\n");
            pos = netns_nft_append(buf, pos, "    oif lo accept\n");

            i = 0;
            while (i < count) {
                var rule = load64(rules + i * 8);
                if (netns_fw_rule_direction(rule) == TRAFFIC_OUTBOUND) {
                    var action = netns_nft_action_str(netns_fw_rule_action(rule));
                    var proto = netns_nft_proto_str(netns_fw_rule_protocol(rule));
                    var port = netns_fw_rule_port(rule);
                    if (proto != 0) {
                        if (port > 0) {
                            pos = netns_nft_append(buf, pos, "    ");
                            pos = netns_nft_append(buf, pos, proto);
                            pos = netns_nft_append(buf, pos, " dport ");
                            var pbuf = alloc(8);
                            var plen = fmt_int_buf(port, pbuf);
                            store8(pbuf + plen, 0);
                            pos = netns_nft_append(buf, pos, pbuf);
                            pos = netns_nft_append(buf, pos, " ");
                            pos = netns_nft_append(buf, pos, action);
                            pos = netns_nft_append(buf, pos, " comment \"");
                            pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                            pos = netns_nft_append(buf, pos, "\"\n");
                        }
                    }
                    var raddr = netns_fw_rule_remote_addr(rule);
                    if (raddr != 0) {
                        if (strlen(raddr) > 0) {
                            pos = netns_nft_append(buf, pos, "    ip daddr ");
                            pos = netns_nft_append(buf, pos, raddr);
                            pos = netns_nft_append(buf, pos, " ");
                            pos = netns_nft_append(buf, pos, action);
                            pos = netns_nft_append(buf, pos, " comment \"");
                            pos = netns_nft_append(buf, pos, netns_fw_rule_comment(rule));
                            pos = netns_nft_append(buf, pos, "\"\n");
                        }
                    }
                }
                i = i + 1;
            }
            pos = netns_nft_append(buf, pos, "  }\n");
        pos = netns_nft_append(buf, pos, "}\n");
    store8(buf + pos, 0);

    return buf;
}

# ================================================================
# Apply nftables ruleset to a namespace
# ================================================================

# Apply a pre-rendered nftables ruleset inside the namespace.
# ruleset: null-terminated nftables script string.
# Returns Result.
fn netns_apply_nftables_ruleset(handle, ruleset) {
    var ns_name = netns_handle_name(handle);

    # Write ruleset to per-PID temp file
    var nft_pid = sys_getpid();
    var nft_pid_buf[24];
    var nft_pid_len = fmt_int_buf(nft_pid, &nft_pid_buf);
    var nft_prefix = "/run/agnos/nft-tmp-";
    var nft_prefix_len = strlen(nft_prefix);
    var nft_suffix = ".conf";
    var nft_suffix_len = strlen(nft_suffix);
    var tmp_path = alloc(nft_prefix_len + nft_pid_len + nft_suffix_len + 1);
    memcpy(tmp_path, nft_prefix, nft_prefix_len);
    memcpy(tmp_path + nft_prefix_len, &nft_pid_buf, nft_pid_len);
    memcpy(tmp_path + nft_prefix_len + nft_pid_len, nft_suffix, nft_suffix_len);
    store8(tmp_path + nft_prefix_len + nft_pid_len + nft_suffix_len, 0);

    # Ensure directory exists (ignore errors)
    var mkdir_argv = alloc(24);
    store64(mkdir_argv, "mkdir");
    store64(mkdir_argv + 8, "-p");
    store64(mkdir_argv + 16, "/run/agnos");
    run_capture("mkdir", mkdir_argv);

    # Write ruleset to file
    var fd = sys_open(tmp_path, 0x241, 0x1A4);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if (fd < 0) {
        return err_io(0 - fd, "failed to create nft temp file");
    }
    var rlen = strlen(ruleset);
    sys_write(fd, ruleset, rlen);
    sys_close(fd);

    # Clean up temp file on any return path
    defer { syscall(87, tmp_path); }

    # ip netns exec <ns> nft -f <path>
    var argv = alloc(56);
    store64(argv, "ip");
    store64(argv + 8, "netns");
    store64(argv + 16, "exec");
    store64(argv + 24, ns_name);
    store64(argv + 32, "nft");
    store64(argv + 40, "-f");
    store64(argv + 48, tmp_path);

    return netns_run_ip(argv);
}

# --- bootloader.cyr ---

# bootloader.cyr — bootloader detection and boot entry management
# Ported from rust-old/src/bootloader.rs
#
# Supports systemd-boot and GRUB2. Auto-detects which bootloader is
# installed by probing well-known paths. Parses boot entries and
# validates kernel command-line parameters.
#
# Requires: src/error.cyr, lib/syscalls.cyr, lib/process.cyr

# ================================================================
# Bootloader type constants
# ================================================================

enum BootloaderType {
    BOOT_SYSTEMD_BOOT = 1;
    BOOT_GRUB2 = 2;
    BOOT_UNKNOWN = 3;
}

# ================================================================
# Well-known paths
# ================================================================

# Checked as static strings in the detect function:
# /boot/efi/EFI/systemd  -> systemd-boot
# /boot/grub/grub.cfg    -> GRUB2
# /boot/loader/loader.conf  -> systemd-boot loader config
# /boot/loader/entries/  -> systemd-boot entries dir

# ================================================================
# BootEntry struct
# ================================================================

# Layout: { id, title, linux_path, initrd_path, options, is_default, version }
# 7 fields * 8 = 56 bytes

fn bootloader_entry_new() {
    var e = alloc(56);
    memset(e, 0, 56);
    return e;
}

fn bootloader_entry_id(e) { return load64(e); }
fn bootloader_entry_title(e) { return load64(e + 8); }
fn bootloader_entry_linux(e) { return load64(e + 16); }
fn bootloader_entry_initrd(e) { return load64(e + 24); }
fn bootloader_entry_options(e) { return load64(e + 32); }
fn bootloader_entry_is_default(e) { return load64(e + 40); }
fn bootloader_entry_version(e) { return load64(e + 48); }

fn bootloader_entry_set_id(e, v) { store64(e, v); return 0; }
fn bootloader_entry_set_title(e, v) { store64(e + 8, v); return 0; }
fn bootloader_entry_set_linux(e, v) { store64(e + 16, v); return 0; }
fn bootloader_entry_set_initrd(e, v) { store64(e + 24, v); return 0; }
fn bootloader_entry_set_options(e, v) { store64(e + 32, v); return 0; }
fn bootloader_entry_set_is_default(e, v) { store64(e + 40, v); return 0; }
fn bootloader_entry_set_version(e, v) { store64(e + 48, v); return 0; }

# ================================================================
# BootConfig struct
# ================================================================

# Layout: { bootloader_type, timeout_secs, default_entry_id, entries_arr, entry_count }
# 5 fields * 8 = 40 bytes

fn bootloader_config_new() {
    var c = alloc(40);
    memset(c, 0, 40);
    return c;
}

fn bootloader_config_type(c) { return load64(c); }
fn bootloader_config_timeout(c) { return load64(c + 8); }
fn bootloader_config_default_id(c) { return load64(c + 16); }
fn bootloader_config_entries(c) { return load64(c + 24); }
fn bootloader_config_entry_count(c) { return load64(c + 32); }

fn bootloader_config_set_type(c, v) { store64(c, v); return 0; }
fn bootloader_config_set_timeout(c, v) { store64(c + 8, v); return 0; }
fn bootloader_config_set_default_id(c, v) { store64(c + 16, v); return 0; }
fn bootloader_config_set_entries(c, arr, count) {
    store64(c + 24, arr);
    store64(c + 32, count);
    return 0;
}

# ================================================================
# Bootloader detection
# ================================================================

# Detect the installed bootloader by probing well-known paths.
# Returns Result: Ok(BootloaderType constant).
fn bootloader_detect() {
    # Check for systemd-boot: /boot/efi/EFI/systemd
    var sd_path = "/boot/efi/EFI/systemd";
    var fd = sys_open(sd_path, 0x10000, 0);  # O_RDONLY | O_DIRECTORY
    if (fd >= 0) {
        sys_close(fd);
        return Ok(BOOT_SYSTEMD_BOOT);
    }

    # Check for GRUB2: /boot/grub/grub.cfg
    var grub_path = "/boot/grub/grub.cfg";
    fd = sys_open(grub_path, 0, 0);
    if (fd >= 0) {
        sys_close(fd);
        return Ok(BOOT_GRUB2);
    }

    return Ok(BOOT_UNKNOWN);
}

# ================================================================
# Parse loader.conf (systemd-boot)
# ================================================================

# Helper: check if line starts with prefix (skipping leading whitespace)
fn bootloader_line_starts_with(line, linelen, prefix) {
    var plen = strlen(prefix);
    # Skip leading whitespace
    var start = 0;
    while (start < linelen) {
        var ch = load8(line + start);
        if (ch != 32) { if (ch != 9) { break; } }
        start = start + 1;
    }
    if (linelen - start < plen) { return 0; }
    var i = 0;
    while (i < plen) {
        if (load8(line + start + i) != load8(prefix + i)) { return 0; }
        i = i + 1;
    }
    return start + plen;
}

# Extract the value after a key in a line (trim whitespace).
# Returns heap string pointer.
fn bootloader_extract_value(line, linelen, key_end_pos) {
    var start = key_end_pos;
    # Skip whitespace
    while (start < linelen) {
        var ch = load8(line + start);
        if (ch != 32) { if (ch != 9) { break; } }
        start = start + 1;
    }
    var vlen = linelen - start;
    if (vlen <= 0) { return 0; }
    var val = alloc(vlen + 1);
    memcpy(val, line + start, vlen);
    store8(val + vlen, 0);
    return val;
}

# Parse loader.conf file contents.
# Returns { timeout, default_id } as a 16-byte struct.
fn bootloader_parse_loader_conf(text) {
    var result = alloc(16);
    store64(result, 5);  # default timeout: 5 seconds
    store64(result + 8, 0);  # default_id: null

    if (text == 0) { return result; }

    var textlen = strlen(text);
    var pos = 0;

    while (pos < textlen) {
        var linestart = pos;
        while (pos < textlen) {
            if (load8(text + pos) == 10) { break; }
            pos = pos + 1;
        }
        var linelen = pos - linestart;
        if (pos < textlen) { pos = pos + 1; }  # skip newline

        if (linelen == 0) { continue; }

        # Skip comment lines
        var first = linestart;
        while (first < linestart + linelen) {
            var ch = load8(text + first);
            if (ch != 32) { if (ch != 9) { break; } }
            first = first + 1;
        }
        if (first < linestart + linelen) {
            if (load8(text + first) == 35) { continue; }  # '#'
        }

        var kp = bootloader_line_starts_with(text + linestart, linelen, "timeout");
        if (kp > 0) {
            var val = bootloader_extract_value(text + linestart, linelen, kp);
            if (val != 0) {
                # Parse integer
                var t = 0;
                var vi = 0;
                var vl = strlen(val);
                while (vi < vl) {
                    var ch = load8(val + vi);
                    if (ch >= 48) { if (ch <= 57) {
                            t = t * 10 + (ch - 48);
                        } }
                    vi = vi + 1;
                }
                store64(result, t);
            }
            continue;
        }

        kp = bootloader_line_starts_with(text + linestart, linelen, "default");
        if (kp > 0) {
            var val = bootloader_extract_value(text + linestart, linelen, kp);
            if (val != 0) {
                # Strip .conf suffix if present
                var vl = strlen(val);
                if (vl > 5) {
                    if (load8(val + vl - 5) == 46) {  # '.'
                        if (load8(val + vl - 4) == 99) {  # 'c'
                            if (load8(val + vl - 3) == 111) {  # 'o'
                                if (load8(val + vl - 2) == 110) {  # 'n'
                                    if (load8(val + vl - 1) == 102) {  # 'f'
                                        store8(val + vl - 5, 0);
                                    }
                                }
                            }
                        }
                    }
                }
                store64(result + 8, val);
            }
            continue;
        }
    }

    return result;
}

# ================================================================
# List boot entries (high-level)
# ================================================================

# List boot entries using bootctl or by reading loader entries.
# result_arr: pre-allocated array of BootEntry pointers.
# max_entries: capacity.
# Returns Result: Ok(count) or Err.
fn bootloader_list_boot_entries(result_arr, max_entries) {
    # Use bootctl list (systemd-boot) as it provides structured output
    var cmd = "bootctl";
    var argv = alloc(16);
    store64(argv, cmd);
    store64(argv + 8, "list");

    var res = run_capture(cmd, argv);
    if (is_ok(res) == 1) {
        var output = payload(res);
        if (output != 0) {
            return bootloader_parse_bootctl_list(output, result_arr, max_entries);
        }
    }

    # Fallback: try reading /boot/loader/entries/ directly
    # For now, return 0 entries on failure
    return Ok(0);
}

# Parse bootctl list output (simplified).
# Each entry block starts with a line containing "title:" or "id:".
fn bootloader_parse_bootctl_list(text, result_arr, max_entries) {
    var count = 0;
    var current = 0;
    var textlen = strlen(text);
    var pos = 0;

    while (pos < textlen) {
        var linestart = pos;
        while (pos < textlen) {
            if (load8(text + pos) == 10) { break; }
            pos = pos + 1;
        }
        var linelen = pos - linestart;
        if (pos < textlen) { pos = pos + 1; }
        if (linelen == 0) { continue; }

        var kp = bootloader_line_starts_with(text + linestart, linelen, "id:");
        if (kp > 0) {
            if (current != 0) {
                if (count < max_entries) {
                    store64(result_arr + count * 8, current);
                    count = count + 1;
                }
            }
            current = bootloader_entry_new();
            var val = bootloader_extract_value(text + linestart, linelen, kp);
            bootloader_entry_set_id(current, val);
            continue;
        }

        if (current != 0) {
            kp = bootloader_line_starts_with(text + linestart, linelen, "title:");
            if (kp > 0) {
                var val = bootloader_extract_value(text + linestart, linelen, kp);
                bootloader_entry_set_title(current, val);
                continue;
            }

            kp = bootloader_line_starts_with(text + linestart, linelen, "linux:");
            if (kp > 0) {
                var val = bootloader_extract_value(text + linestart, linelen, kp);
                bootloader_entry_set_linux(current, val);
                continue;
            }

            kp = bootloader_line_starts_with(text + linestart, linelen, "initrd:");
            if (kp > 0) {
                var val = bootloader_extract_value(text + linestart, linelen, kp);
                bootloader_entry_set_initrd(current, val);
                continue;
            }

            kp = bootloader_line_starts_with(text + linestart, linelen, "options:");
            if (kp > 0) {
                var val = bootloader_extract_value(text + linestart, linelen, kp);
                bootloader_entry_set_options(current, val);
                continue;
            }
        }
    }

    # Don't forget last entry
    if (current != 0) {
        if (count < max_entries) {
            store64(result_arr + count * 8, current);
            count = count + 1;
        }
    }

    return Ok(count);
}

# ================================================================
# Kernel command line validation
# ================================================================

# Dangerous command-line tokens that must be rejected.
# We check for these as substrings (case-insensitive matching via lowercase).

fn bootloader_is_dangerous_token(text, textlen, token) {
    var tlen = strlen(token);
    if (tlen > textlen) { return 0; }
    var i = 0;
    var limit = textlen - tlen;
    while (i <= limit) {
        var found = 1;
        var j = 0;
        while (j < tlen) {
            var c1 = load8(text + i + j);
            var c2 = load8(token + j);
            # Lowercase c1 if uppercase
            if (c1 >= 65) { if (c1 <= 90) { c1 = c1 + 32; } }
            if (c1 != c2) { found = 0; break; }
            j = j + 1;
        }
        if (found == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

var _bootloader_danger_map = 0;

fn bootloader_danger_reset() { _bootloader_danger_map = 0; return 0; }

fn _bootloader_danger_init() {
    if (_bootloader_danger_map != 0) { return 0; }
    _bootloader_danger_map = map_new();
    map_set(_bootloader_danger_map, "init=/bin/sh", 1);
    map_set(_bootloader_danger_map, "init=/bin/bash", 1);
    map_set(_bootloader_danger_map, "init=/bin/dash", 1);
    map_set(_bootloader_danger_map, "single", 1);
    map_set(_bootloader_danger_map, "emergency", 1);
    map_set(_bootloader_danger_map, "rd.break", 1);
    map_set(_bootloader_danger_map, "debug_shell", 1);
    map_set(_bootloader_danger_map, "systemd.debug-shell", 1);
    return 0;
}

# Validate kernel command-line parameters.
# Returns Result: Ok(0) if valid, Err if dangerous or malformed.
fn bootloader_validate_kernel_cmdline(options) {
    if (options == 0) {
        return err_invalid_argument("kernel cmdline is null");
    }

    var optlen = strlen(options);
    if (optlen > 4096) {
        return err_invalid_argument("kernel command line exceeds 4096-character limit");
    }

    # Single pass: validate chars + extract space-delimited tokens + check dangerous list.
    _bootloader_danger_init();

    var i = 0;
    var tok_start = 0;
    while (i <= optlen) {
        var c = 0;
        if (i < optlen) { c = load8(options + i); }

        # Check printable ASCII (space=32..tilde=126)
        if (i < optlen) {
            if (c < 32) {
                return err_invalid_argument("kernel cmdline contains non-printable characters");
            }
            if (c > 126) {
                return err_invalid_argument("kernel cmdline contains non-ASCII characters");
            }
        }

        # On space or end-of-string, check the token
        if (c == 32 || i == optlen) {
            var tlen = i - tok_start;
            if (tlen > 0) {
                # Extract token to null-terminated buffer
                var tok[128];
                if (tlen > 127) { tlen = 127; }
                memcpy(&tok, options + tok_start, tlen);
                store8(&tok + tlen, 0);
                # Lowercase the token for case-insensitive match
                var ti = 0;
                while (ti < tlen) {
                    var tc = load8(&tok + ti);
                    if (tc >= 65) { if (tc <= 90) { store8(&tok + ti, tc + 32); } }
                    ti = ti + 1;
                }
                if (map_has(_bootloader_danger_map, &tok) == 1) {
                    return err_invalid_argument("kernel cmdline contains dangerous parameter");
                }
            }
            tok_start = i + 1;
        }
        i = i + 1;
    }

    return Ok(0);
}

# Bootloader type to string.
fn bootloader_type_str(bt) {
    if (bt == BOOT_SYSTEMD_BOOT) { return "systemd-boot"; }
    if (bt == BOOT_GRUB2) { return "GRUB2"; }
    return "unknown";
}

# --- update.cyr ---

# update.cyr — atomic updates, version comparison, update manifest
# Ported from rust-old/src/update.rs
#
# Provides atomic file operations (write, copy, swap), CalVer version
# comparison (YYYY.M.D), and update manifest validation.
#
# Requires: src/error.cyr, lib/syscalls.cyr

# ================================================================
# Update slot constants
# ================================================================

enum UpdateSlot {
    SLOT_A = 1;
    SLOT_B = 2;
}

# ================================================================
# Update phase constants
# ================================================================

enum UpdatePhase {
    PHASE_DOWNLOADING = 1;
    PHASE_VERIFYING = 2;
    PHASE_APPLYING = 3;
    PHASE_FINALIZING = 4;
    PHASE_ROLLING_BACK = 5;
    PHASE_COMPLETE = 6;
    PHASE_FAILED = 7;
}

# ================================================================
# Version comparison result constants
# ================================================================

# Version comparison results (can't use negative in enum)
var VER_LESS = 0 - 1;
var VER_EQUAL = 0;
var VER_GREATER = 1;

# ================================================================
# Atomic file write
# ================================================================

# Atomically write data to a file path. Writes to a temp file first,
# then renames to the target path.
# path: destination file path (null-terminated).
# data: pointer to data buffer.
# data_len: number of bytes to write.
# Returns Result: Ok(0) or Err.
fn update_atomic_write(path, data, data_len) {
    if (path == 0) {
        return err_invalid_argument("atomic_write path is null");
    }
    if (data_len < 0) {
        return err_invalid_argument("atomic_write data_len is negative");
    }

    # Create temp path: path + ".tmp"
    var pathlen = strlen(path);
    var tmppath = alloc(pathlen + 5);
    memcpy(tmppath, path, pathlen);
    memcpy(tmppath + pathlen, ".tmp", 4);
    store8(tmppath + pathlen + 4, 0);

    # Write to temp file
    # O_WRONLY | O_CREAT | O_TRUNC = 0x241, mode 0644 = 0x1A4
    var fd = sys_open(tmppath, 0x241, 0x1A4);
    if (fd < 0) {
        return err_io(0 - fd, "atomic_write: failed to create temp file");
    }
    defer { sys_close(fd); }

    var written = 0;
    while (written < data_len) {
        var chunk = data_len - written;
        if (chunk > 4096) { chunk = 4096; }
        var ret = sys_write(fd, data + written, chunk);
        if (ret < 0) {
            syscall(87, tmppath);
            return err_io(0 - ret, "atomic_write: write failed");
        }
        written = written + ret;
    }

    # fsync
    var ret = syscall(74, fd);  # SYS_FSYNC
    if (ret < 0) {
        syscall(87, tmppath);
        return err_io(0 - ret, "atomic_write: fsync failed");
    }

    # Rename temp to target: syscall 82 = SYS_RENAME
    ret = syscall(82, tmppath, path);
    if (ret < 0) {
        syscall(87, tmppath);
        return err_io(0 - ret, "atomic_write: rename failed");
    }

    return Ok(0);
}

# ================================================================
# Atomic file copy
# ================================================================

# Atomically copy src to dst (via temp + rename).
# Returns Result: Ok(bytes_copied) or Err.
fn update_atomic_copy(src, dst) {
    if (src == 0) { return err_invalid_argument("atomic_copy src is null"); }
    if (dst == 0) { return err_invalid_argument("atomic_copy dst is null"); }

    # Open source
    var src_fd = sys_open(src, 0, 0);  # O_RDONLY
    if (src_fd < 0) {
        return err_io(0 - src_fd, "atomic_copy: failed to open source");
    }
    defer { sys_close(src_fd); }

    # Create temp dest
    var dstlen = strlen(dst);
    var tmppath = alloc(dstlen + 5);
    memcpy(tmppath, dst, dstlen);
    memcpy(tmppath + dstlen, ".tmp", 4);
    store8(tmppath + dstlen + 4, 0);

    var dst_fd = sys_open(tmppath, 0x241, 0x1A4);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if (dst_fd < 0) {
        return err_io(0 - dst_fd, "atomic_copy: failed to create temp dest");
    }
    defer { sys_close(dst_fd); }

    # Copy loop
    var buf = alloc(4096);
    var total = 0;
    var nread = sys_read(src_fd, buf, 4096);
    while (nread > 0) {
        var nwritten = 0;
        while (nwritten < nread) {
            var ret = sys_write(dst_fd, buf + nwritten, nread - nwritten);
            if (ret < 0) {
                syscall(87, tmppath);
                return err_io(0 - ret, "atomic_copy: write failed");
            }
            nwritten = nwritten + ret;
        }
        total = total + nread;
        nread = sys_read(src_fd, buf, 4096);
    }

    if (nread < 0) {
        syscall(87, tmppath);
        return err_io(0 - nread, "atomic_copy: read failed");
    }

    # fsync (fd closed by defer)
    syscall(74, dst_fd);

    # Rename temp to target
    var ret = syscall(82, tmppath, dst);
    if (ret < 0) {
        syscall(87, tmppath);
        return err_io(0 - ret, "atomic_copy: rename failed");
    }

    return Ok(total);
}

# ================================================================
# Version validation (CalVer YYYY.M.D)
# ================================================================

# Parse a version string into { year, month, day }.
# Returns pointer to 24-byte struct, or 0 on parse failure.
fn update_parse_version(version) {
    if (version == 0) { return 0; }
    var vlen = strlen(version);
    if (vlen == 0) { return 0; }

    # Find first dot
    var dot1 = 0;
    var i = 0;
    while (i < vlen) {
        if (load8(version + i) == 46) { dot1 = i; break; }
        i = i + 1;
    }
    if (dot1 == 0) { return 0; }

    # Find second dot
    var dot2 = 0;
    i = dot1 + 1;
    while (i < vlen) {
        if (load8(version + i) == 46) { dot2 = i; break; }
        i = i + 1;
    }
    if (dot2 == 0) { return 0; }

    # Parse year (before first dot)
    var year = 0;
    i = 0;
    while (i < dot1) {
        var c = load8(version + i);
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        year = year * 10 + (c - 48);
        i = i + 1;
    }

    # Parse month (between dots)
    var month = 0;
    i = dot1 + 1;
    while (i < dot2) {
        var c = load8(version + i);
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        month = month * 10 + (c - 48);
        i = i + 1;
    }

    # Parse day (after second dot)
    var day = 0;
    i = dot2 + 1;
    while (i < vlen) {
        var c = load8(version + i);
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        day = day * 10 + (c - 48);
        i = i + 1;
    }

    var v = alloc(24);
    store64(v, year);
    store64(v + 8, month);
    store64(v + 16, day);
    return v;
}

# Validate a CalVer version string (YYYY.M.D).
# Returns Result: Ok(0) or Err.
fn update_validate_version(version) {
    var v = update_parse_version(version);
    if (v == 0) {
        return err_invalid_argument("version must have exactly 3 parts (YYYY.M.D)");
    }
    var year = load64(v);
    var month = load64(v + 8);

    if (year < 2024) {
        return err_invalid_argument("version year out of range (2024-2100)");
    }
    if (year > 2100) {
        return err_invalid_argument("version year out of range (2024-2100)");
    }
    if (month < 1) {
        return err_invalid_argument("version month out of range (1-12)");
    }
    if (month > 12) {
        return err_invalid_argument("version month out of range (1-12)");
    }
    return Ok(0);
}

# ================================================================
# Version comparison
# ================================================================

# Compare two CalVer version strings.
# Returns VER_LESS (-1), VER_EQUAL (0), or VER_GREATER (1).
# Falls back to byte-by-byte comparison if either string is malformed.
fn update_compare_versions(a, b) {
    var va = update_parse_version(a);
    var vb = update_parse_version(b);

    if (va == 0) {
        if (vb == 0) {
            # Both malformed: lexicographic comparison
            var alen = strlen(a);
            var blen = strlen(b);
            var minlen = alen;
            if (blen < minlen) { minlen = blen; }
            var i = 0;
            while (i < minlen) {
                var ca = load8(a + i);
                var cb = load8(b + i);
                if (ca < cb) { return VER_LESS; }
                if (ca > cb) { return VER_GREATER; }
                i = i + 1;
            }
            if (alen < blen) { return VER_LESS; }
            if (alen > blen) { return VER_GREATER; }
            return VER_EQUAL;
        }
        return VER_LESS;
    }
    if (vb == 0) { return VER_GREATER; }

    # Compare year
    var ay = load64(va);
    var by = load64(vb);
    if (ay < by) { return VER_LESS; }
    if (ay > by) { return VER_GREATER; }

    # Compare month
    var am = load64(va + 8);
    var bm = load64(vb + 8);
    if (am < bm) { return VER_LESS; }
    if (am > bm) { return VER_GREATER; }

    # Compare day
    var ad = load64(va + 16);
    var bd = load64(vb + 16);
    if (ad < bd) { return VER_LESS; }
    if (ad > bd) { return VER_GREATER; }

    return VER_EQUAL;
}

# ================================================================
# Update slot helpers
# ================================================================

fn update_other_slot(slot) {
    if (slot == SLOT_A) { return SLOT_B; }
    return SLOT_A;
}

fn update_slot_suffix(slot) {
    if (slot == SLOT_A) { return "a"; }
    return "b";
}

fn update_slot_str(slot) {
    if (slot == SLOT_A) { return "A"; }
    return "B";
}

fn update_phase_str(phase) {
    if (phase == PHASE_DOWNLOADING) { return "Downloading"; }
    if (phase == PHASE_VERIFYING) { return "Verifying"; }
    if (phase == PHASE_APPLYING) { return "Applying"; }
    if (phase == PHASE_FINALIZING) { return "Finalizing"; }
    if (phase == PHASE_ROLLING_BACK) { return "Rolling back"; }
    if (phase == PHASE_COMPLETE) { return "Complete"; }
    if (phase == PHASE_FAILED) { return "Failed"; }
    return "Unknown";
}

# ================================================================
# Update channel constants
# ================================================================

enum UpdateChannel {
    CHAN_STABLE = 1;
    CHAN_BETA = 2;
    CHAN_NIGHTLY = 3;
    CHAN_CUSTOM = 4;
}

fn update_channel_str(channel) {
    if (channel == CHAN_STABLE) { return "stable"; }
    if (channel == CHAN_BETA) { return "beta"; }
    if (channel == CHAN_NIGHTLY) { return "nightly"; }
    return "custom";
}

# ================================================================
# UpdateState struct
# ================================================================
# Layout: { current_slot, current_version, pending_update, rollback_available,
#            boot_count_since_update }
# 5 fields * 8 = 40 bytes

fn update_state_new(slot, version) {
    var s = alloc(40);
    store64(s, slot);
    store64(s + 8, version);
    store64(s + 16, 0);     # pending_update (0 = none)
    store64(s + 24, 0);     # rollback_available
    store64(s + 32, 0);     # boot_count_since_update
    return s;
}

fn update_state_slot(s) { return load64(s); }
fn update_state_version(s) { return load64(s + 8); }
fn update_state_pending(s) { return load64(s + 16); }
fn update_state_rollback_available(s) { return load64(s + 24); }
fn update_state_boot_count(s) { return load64(s + 32); }

fn update_state_set_slot(s, slot) { store64(s, slot); return 0; }
fn update_state_set_pending(s, ver) { store64(s + 16, ver); return 0; }
fn update_state_set_rollback(s, val) { store64(s + 24, val); return 0; }
fn update_state_set_boot_count(s, n) { store64(s + 32, n); return 0; }

# ================================================================
# UpdateConfig struct
# ================================================================
# Layout: { update_url, slot_a_device, slot_b_device, state_file,
#            backup_dir, max_retries, verify_after_apply }
# 7 fields * 8 = 56 bytes

fn update_config_new() {
    var c = alloc(56);
    store64(c, "https://updates.agnos.org");
    store64(c + 8, "/dev/disk/by-partlabel/rootfs_a");
    store64(c + 16, "/dev/disk/by-partlabel/rootfs_b");
    store64(c + 24, "/var/lib/agnos/update-state.json");
    store64(c + 32, "/var/lib/agnos/backups");
    store64(c + 40, 3);    # max_retries
    store64(c + 48, 1);    # verify_after_apply
    return c;
}

fn update_config_url(c) { return load64(c); }
fn update_config_slot_a(c) { return load64(c + 8); }
fn update_config_slot_b(c) { return load64(c + 16); }
fn update_config_state_file(c) { return load64(c + 24); }
fn update_config_backup_dir(c) { return load64(c + 32); }
fn update_config_max_retries(c) { return load64(c + 40); }
fn update_config_verify(c) { return load64(c + 48); }

fn update_config_device_for_slot(c, slot) {
    if (slot == SLOT_A) { return load64(c + 8); }
    return load64(c + 16);
}

# ================================================================
# UpdateManifest struct
# ================================================================
# Layout: { version, channel, files_vec, release_date, min_version, changelog }
# 6 fields * 8 = 48 bytes
# Note: sha256_digest verification deferred — requires SHA-256 impl.
# For now, manifest validation checks structural integrity only.

fn update_manifest_new(version, channel, release_date) {
    var m = alloc(48);
    store64(m, version);
    store64(m + 8, channel);
    store64(m + 16, vec_new());   # files
    store64(m + 24, release_date);
    store64(m + 32, 0);           # min_version
    store64(m + 40, 0);           # changelog
    return m;
}

fn update_manifest_version(m) { return load64(m); }
fn update_manifest_channel(m) { return load64(m + 8); }
fn update_manifest_files(m) { return load64(m + 16); }
fn update_manifest_release_date(m) { return load64(m + 24); }
fn update_manifest_min_version(m) { return load64(m + 32); }
fn update_manifest_changelog(m) { return load64(m + 40); }

# ================================================================
# UpdateFile struct
# ================================================================
# Layout: { path, sha256, size_bytes, delta_from, compressed }
# 5 fields * 8 = 40 bytes

fn update_file_new(path, sha256, size_bytes) {
    var f = alloc(40);
    store64(f, path);
    store64(f + 8, sha256);
    store64(f + 16, size_bytes);
    store64(f + 24, 0);     # delta_from
    store64(f + 32, 0);     # compressed
    return f;
}

fn update_file_path(f) { return load64(f); }
fn update_file_sha256(f) { return load64(f + 8); }
fn update_file_size(f) { return load64(f + 16); }
fn update_file_delta_from(f) { return load64(f + 24); }
fn update_file_compressed(f) { return load64(f + 32); }

# ================================================================
# Slot detection
# ================================================================

# Detect current boot slot by reading /proc/cmdline for "agnos.slot=".
# Falls back to reading the state file, then defaults to slot A.
# Returns Result: Ok(slot) or Err.
fn update_get_current_slot() {
    # Read /proc/cmdline
    var cmdfd = sys_open("/proc/cmdline", 0, 0);
    if (cmdfd >= 0) {
        var cmdbuf = alloc(1024);
        var n = sys_read(cmdfd, cmdbuf, 1023);
        sys_close(cmdfd);
        if (n > 0) {
            store8(cmdbuf + n, 0);
            var pos = strstr(cmdbuf, "agnos.slot=");
            if (pos >= 0) {
                var val = load8(cmdbuf + pos + 11);
                if (val == 97 || val == 65) { return Ok(SLOT_A); }
                if (val == 98 || val == 66) { return Ok(SLOT_B); }
                return err_invalid_argument("Unknown slot in cmdline");
            }
        }
    }

    # Fallback: read state file
    var sfd = sys_open("/var/lib/agnos/update-state.json", 0, 0);
    if (sfd >= 0) {
        var sbuf = alloc(4096);
        var sn = sys_read(sfd, sbuf, 4095);
        sys_close(sfd);
        if (sn > 0) {
            store8(sbuf + sn, 0);
            var idx = strstr(sbuf, "\"current_slot\"");
            if (idx >= 0) {
                var vi = idx + 14;
                while (vi < sn && load8(sbuf + vi) != 49 && load8(sbuf + vi) != 50) { vi = vi + 1; }
                if (vi < sn) {
                    if (load8(sbuf + vi) == 49) { return Ok(SLOT_A); }
                    if (load8(sbuf + vi) == 50) { return Ok(SLOT_B); }
                }
            }
        }
    }

    # Default to slot A
    return Ok(SLOT_A);
}

# ================================================================
# State persistence
# ================================================================

# Save update state to a JSON file.
# Returns Result: Ok(0) or Err.
fn update_save_state(state, path) {
    if (state == 0) { return err_invalid_argument("state is null"); }
    if (path == 0) { return err_invalid_argument("path is null"); }

    # Build JSON manually
    var buf = alloc(512);
    var pos = 0;

    # JSON: current_slot, current_version, pending, rollback, boot_count
    var hdr = "{\"current_slot\":";
    memcpy(buf + pos, hdr, strlen(hdr));
    pos = pos + strlen(hdr);

    var slot = update_state_slot(state);
    store8(buf + pos, 48 + slot);  # '0' + slot value (1 or 2)
    pos = pos + 1;

    var cvh = ",\"current_version\":\"";
    memcpy(buf + pos, cvh, strlen(cvh));
    pos = pos + strlen(cvh);

    var ver = update_state_version(state);
    if (ver != 0) {
        var vlen = strlen(ver);
        memcpy(buf + pos, ver, vlen);
        pos = pos + vlen;
    }
    store8(buf + pos, 34); pos = pos + 1;  # '"'

    # pending_update
    var puh = ",\"pending_update\":";
    memcpy(buf + pos, puh, strlen(puh));
    pos = pos + strlen(puh);
    var pending = update_state_pending(state);
    if (pending == 0) {
        memcpy(buf + pos, "null", 4);
        pos = pos + 4;
    } else {
        store8(buf + pos, 34); pos = pos + 1;
        var plen = strlen(pending);
        memcpy(buf + pos, pending, plen);
        pos = pos + plen;
        store8(buf + pos, 34); pos = pos + 1;
    }

    # rollback_available
    var rah = ",\"rollback_available\":";
    memcpy(buf + pos, rah, strlen(rah));
    pos = pos + strlen(rah);
    if (update_state_rollback_available(state) == 1) {
        memcpy(buf + pos, "true", 4); pos = pos + 4;
    } else {
        memcpy(buf + pos, "false", 5); pos = pos + 5;
    }

    # boot_count
    var bch = ",\"boot_count\":";
    memcpy(buf + pos, bch, strlen(bch));
    pos = pos + strlen(bch);
    var bc = update_state_boot_count(state);
    var bc_buf[8];
    var bc_len = fmt_int_buf(bc, &bc_buf);
    memcpy(buf + pos, &bc_buf, bc_len);
    pos = pos + bc_len;

    store8(buf + pos, 125); pos = pos + 1;  # '}'
    store8(buf + pos, 10); pos = pos + 1;   # '\n'
    store8(buf + pos, 0);

    return update_atomic_write(path, buf, pos);
}

# Load update state from a JSON file.
# Returns Result: Ok(state_ptr) or Err.
fn update_load_state(path) {
    if (path == 0) { return err_invalid_argument("state path is null"); }

    var fd = sys_open(path, 0, 0);
    if (fd < 0) {
        return err_io(0 - fd, "failed to open update state file");
    }
    defer { sys_close(fd); }

    var buf = alloc(4096);
    var n = sys_read(fd, buf, 4095);
    if (n <= 0) {
        return err_io(0, "failed to read update state file");
    }
    store8(buf + n, 0);

    # Parse current_slot
    var slot = SLOT_A;
    var sidx = strstr(buf, "\"current_slot\"");
    if (sidx >= 0) {
        var si = sidx + 14;
        while (si < n && load8(buf + si) != 49 && load8(buf + si) != 50) { si = si + 1; }
        if (si < n && load8(buf + si) == 50) { slot = SLOT_B; }
    }

    # Parse current_version
    var version = "";
    var vidx = strstr(buf, "\"current_version\"");
    if (vidx >= 0) {
        var qi = vidx + 17;
        while (qi < n && load8(buf + qi) != 34) { qi = qi + 1; }
        qi = qi + 1;
        var vstart = qi;
        while (qi < n && load8(buf + qi) != 34) { qi = qi + 1; }
        var vlen = qi - vstart;
        if (vlen > 0) {
            version = alloc(vlen + 1);
            memcpy(version, buf + vstart, vlen);
            store8(version + vlen, 0);
        }
    }

    var state = update_state_new(slot, version);

    # Parse pending_update
    var pidx = strstr(buf, "\"pending_update\"");
    if (pidx >= 0) {
        var pi = pidx + 16;
        # Check for null
        while (pi < n && (load8(buf + pi) == 32 || load8(buf + pi) == 58)) { pi = pi + 1; }
        if (pi + 3 < n && memeq(buf + pi, "null", 4) != 1) {
            # Skip to opening quote
            while (pi < n && load8(buf + pi) != 34) { pi = pi + 1; }
            pi = pi + 1;
            var pstart = pi;
            while (pi < n && load8(buf + pi) != 34) { pi = pi + 1; }
            var plen = pi - pstart;
            if (plen > 0) {
                var pv = alloc(plen + 1);
                memcpy(pv, buf + pstart, plen);
                store8(pv + plen, 0);
                update_state_set_pending(state, pv);
            }
        }
    }

    # Parse rollback_available
    var ridx = strstr(buf, "\"rollback_available\"");
    if (ridx >= 0) {
        var ri = ridx + 20;
        # skip to 't' or 'f'
        while (ri < n && load8(buf + ri) != 116 && load8(buf + ri) != 102) {
            ri = ri + 1;
        }
        if (ri < n && load8(buf + ri) == 116) {
            update_state_set_rollback(state, 1);
        }
    }

    # Parse boot_count
    var bidx = strstr(buf, "\"boot_count\"");
    if (bidx >= 0) {
        var bi = bidx + 12;
        while (bi < n && (load8(buf + bi) < 48 || load8(buf + bi) > 57)) { bi = bi + 1; }
        var bc = 0;
        while (bi < n && load8(buf + bi) >= 48 && load8(buf + bi) <= 57) {
            bc = bc * 10 + (load8(buf + bi) - 48);
            bi = bi + 1;
        }
        update_state_set_boot_count(state, bc);
    }

    return Ok(state);
}

# ================================================================
# Manifest validation
# ================================================================

# Validate structural integrity of an update manifest.
# Returns Result: Ok(0) or Err.
# Note: SHA-256 digest verification requires a SHA-256 implementation
# which is not yet available in Cyrius stdlib. Structural checks only.
fn update_verify_manifest(manifest) {
    if (manifest == 0) { return err_invalid_argument("manifest is null"); }

    var ver = update_manifest_version(manifest);
    if (ver == 0 || strlen(ver) == 0) {
        return err_invalid_argument("manifest version must not be empty");
    }

    var files = update_manifest_files(manifest);
    if (files == 0 || vec_len(files) == 0) {
        return err_invalid_argument("manifest must contain at least one file");
    }

    var rd = update_manifest_release_date(manifest);
    if (rd == 0 || strlen(rd) == 0) {
        return err_invalid_argument("manifest release_date must not be empty");
    }

    # Validate version format
    var vres = update_validate_version(ver);
    if (is_err_result(vres) == 1) { return vres; }

    # Validate each file has a valid sha256 (64 hex chars)
    var fi = 0;
    while (fi < vec_len(files)) {
        var f = vec_get(files, fi);
        var hash = update_file_sha256(f);
        if (hash == 0 || strlen(hash) != 64) {
            return err_invalid_argument("file has invalid sha256 (expected 64 hex chars)");
        }
        # Verify all chars are hex
        var hi = 0;
        while (hi < 64) {
            var c = load8(hash + hi);
            var valid = 0;
            if (c >= 48 && c <= 57) { valid = 1; }   # 0-9
            if (c >= 97 && c <= 102) { valid = 1; }   # a-f
            if (c >= 65 && c <= 70) { valid = 1; }     # A-F
            if (valid == 0) {
                return err_invalid_argument("file sha256 contains non-hex character");
            }
            hi = hi + 1;
        }
        fi = fi + 1;
    }

    return Ok(0);
}

# ================================================================
# Update check
# ================================================================

# Check for available update by reading a local manifest file.
# url_or_path: path to manifest JSON file (file:// prefix stripped).
# current_version: installed version string.
# Returns Result: Ok(manifest_ptr) if update available, Ok(0) if up-to-date, or Err.
#
# Note: Network fetch (curl) not yet implemented in Cyrius.
# Supports local file paths and file:// URLs only.
# Future: Mac/Windows will need platform-specific fetch (NSURLSession, WinHTTP).
fn update_check(config, current_version) {
    if (config == 0) { return err_invalid_argument("config is null"); }
    if (current_version == 0) { return err_invalid_argument("current_version is null"); }

    var url = update_config_url(config);
    var path = url;

    # Strip file:// prefix if present
    if (strlen(url) > 7 && memeq(url, "file://", 7) == 1) {
        path = url + 7;
    }

    # Only support local file paths for now
    if (load8(path) != 47) {  # '/'
        return err_not_supported("network update check not yet implemented");
    }

    # Read manifest file
    var fd = sys_open(path, 0, 0);
    if (fd < 0) {
        return err_io(0 - fd, "failed to open manifest file");
    }
    defer { sys_close(fd); }

    var buf = alloc(16384);
    var total = 0;
    var nread = sys_read(fd, buf + total, 16384 - total);
    while (nread > 0) {
        total = total + nread;
        if (total >= 16384) { break; }
        nread = sys_read(fd, buf + total, 16384 - total);
    }
    store8(buf + total, 0);

    # Parse version from manifest JSON
    # Look for "version":"X.Y.Z"
    var vidx = strstr(buf, "\"version\"");
    if (vidx < 0) {
        return err_invalid_argument("manifest missing version field");
    }
    var qi = vidx + 9;
    while (qi < total && load8(buf + qi) != 34) { qi = qi + 1; }
    qi = qi + 1;  # skip opening quote
    var vstart = qi;
    while (qi < total && load8(buf + qi) != 34) { qi = qi + 1; }
    var vlen = qi - vstart;
    var manifest_version = alloc(vlen + 1);
    memcpy(manifest_version, buf + vstart, vlen);
    store8(manifest_version + vlen, 0);

    # Compare versions
    var cmp = update_compare_versions(manifest_version, current_version);
    if (cmp == VER_GREATER) {
        # Newer version available — build minimal manifest
        var manifest = update_manifest_new(manifest_version, CHAN_STABLE, "");
        return Ok(manifest);
    }

    # Up to date
    return Ok(0);
}

# ================================================================
# Apply update to inactive slot
# ================================================================

# Write update image to the inactive slot's block device.
# Returns Result: Ok(0) or Err.
fn update_apply(config, manifest) {
    if (config == 0) { return err_invalid_argument("config is null"); }
    if (manifest == 0) { return err_invalid_argument("manifest is null"); }

    var files = update_manifest_files(manifest);
    if (files == 0 || vec_len(files) == 0) {
        return err_invalid_argument("manifest contains no files to apply");
    }

    var current_res = update_get_current_slot();
    var current = SLOT_A;
    if (is_ok(current_res) == 1) { current = payload(current_res); }

    var target_slot = update_other_slot(current);
    var target_dev = update_config_device_for_slot(config, target_slot);

    var image = update_file_path(vec_get(files, 0));
    if (image == 0 || strlen(image) == 0) {
        return err_invalid_argument("update image path is empty");
    }

    # Validate image path: must be absolute, no traversal
    if (load8(image) != 47) {
        return err_invalid_argument("update image path must be absolute");
    }
    if (strstr(image, "..") >= 0) {
        return err_invalid_argument("update image path must not contain '..'");
    }

    # Validate within staging directory
    var staging = "/var/lib/agnos/updates/";
    if (memeq(image, staging, strlen(staging)) != 1) {
        return err_invalid_argument("update image must be within /var/lib/agnos/updates/");
    }

    # Write via dd
    var args = vec_new();
    vec_push(args, "dd");

    # Build if=<image>
    var if_arg = alloc(strlen(image) + 4);
    memcpy(if_arg, "if=", 3);
    memcpy(if_arg + 3, image, strlen(image) + 1);
    vec_push(args, if_arg);

    # Build of=<device>
    var of_arg = alloc(strlen(target_dev) + 4);
    memcpy(of_arg, "of=", 3);
    memcpy(of_arg + 3, target_dev, strlen(target_dev) + 1);
    vec_push(args, of_arg);

    vec_push(args, "bs=4M");
    vec_push(args, "conv=fsync");

    var dd_res = run_capture("dd", args);
    if (is_err_result(dd_res) == 1) { return dd_res; }

    # Update persistent state
    var state_file = update_config_state_file(config);
    var load_res = update_load_state(state_file);
    var state = 0;
    if (is_ok(load_res) == 1) {
        state = payload(load_res);
    } else {
        state = update_state_new(current, "");
    }
    update_state_set_pending(state, update_manifest_version(manifest));
    update_state_set_rollback(state, 1);
    update_save_state(state, state_file);

    return Ok(0);
}

# ================================================================
# Switch active slot
# ================================================================

# Mark a slot as active for the next boot.
# Writes slot marker for argonaut and optionally sets EFI boot entry.
# Returns Result: Ok(0) or Err.
fn update_switch_slot(config, slot) {
    if (config == 0) { return err_invalid_argument("config is null"); }

    # Write slot marker file
    var marker = "/var/lib/agnos/next-slot";
    var suffix = update_slot_suffix(slot);
    var slen = strlen(suffix);
    var res = update_atomic_write(marker, suffix, slen);
    if (is_err_result(res) == 1) { return res; }

    # Try efibootmgr (best effort)
    var efi_args = vec_new();
    vec_push(efi_args, "efibootmgr");
    vec_push(efi_args, "--bootnext");
    var boot_label = alloc(8);
    memcpy(boot_label, "AGNOS-", 6);
    if (slot == SLOT_A) { store8(boot_label + 6, 65); }  # 'A'
    else { store8(boot_label + 6, 66); }                   # 'B'
    store8(boot_label + 7, 0);
    vec_push(efi_args, boot_label);
    run_capture("efibootmgr", efi_args);  # ignore failure

    # Update persistent state
    var state_file = update_config_state_file(config);
    var load_res = update_load_state(state_file);
    var state = 0;
    if (is_ok(load_res) == 1) {
        state = payload(load_res);
    } else {
        state = update_state_new(update_other_slot(slot), "");
    }
    update_state_set_slot(state, slot);
    update_state_set_boot_count(state, 0);
    update_save_state(state, state_file);

    return Ok(0);
}

# ================================================================
# Rollback
# ================================================================

# Roll back to the previous slot.
# Returns Result: Ok(0) or Err.
fn update_rollback(config) {
    if (config == 0) { return err_invalid_argument("config is null"); }

    var state_file = update_config_state_file(config);
    var load_res = update_load_state(state_file);
    if (is_err_result(load_res) == 1) { return load_res; }
    var state = payload(load_res);

    if (update_state_rollback_available(state) == 0) {
        return err_invalid_argument("no rollback image available");
    }

    var previous = update_other_slot(update_state_slot(state));

    # Stop services before switching (best effort)
    var stop_args = vec_new();
    vec_push(stop_args, "argonaut");
    vec_push(stop_args, "stop");
    vec_push(stop_args, "daimon");
    run_capture("argonaut", stop_args);  # ignore failure

    var switch_res = update_switch_slot(config, previous);
    if (is_err_result(switch_res) == 1) { return switch_res; }

    # Clear pending state
    update_state_set_pending(state, 0);
    update_state_set_rollback(state, 0);
    update_save_state(state, state_file);

    return Ok(0);
}

# ================================================================
# Boot confirmation
# ================================================================

# Mark the current boot as successful.
# Increments boot counter, clears pending update flag.
# Returns Result: Ok(0) or Err.
fn update_mark_boot_successful(config) {
    if (config == 0) { return err_invalid_argument("config is null"); }

    var state_file = update_config_state_file(config);
    var load_res = update_load_state(state_file);
    if (is_err_result(load_res) == 1) { return load_res; }
    var state = payload(load_res);

    var bc = update_state_boot_count(state) + 1;
    update_state_set_boot_count(state, bc);

    if (update_state_pending(state) != 0) {
        update_state_set_pending(state, 0);
    }

    return update_save_state(state, state_file);
}

# Pure function: returns 1 if boot count exceeds max_attempts
# and there is a pending update (indicating automatic rollback needed).
fn update_needs_rollback(state, max_boot_attempts) {
    if (update_state_pending(state) == 0) { return 0; }
    return update_state_boot_count(state) >= max_boot_attempts;
}

# --- fuse.cyr ---

# fuse.cyr — FUSE filesystem mount management
# New module (no Rust source)
#
# Parses /proc/mounts for FUSE mounts, provides mount/unmount
# via fusermount subprocess.
#
# Requires: src/error.cyr, lib/syscalls.cyr, lib/process.cyr

# ================================================================
# FuseMount struct
# ================================================================

# Layout: { device, mountpoint, fstype, options }
# 4 fields * 8 = 32 bytes

fn fuse_mount_new(device, mountpoint, fstype, options) {
    var m = alloc(32);
    store64(m, device);
    store64(m + 8, mountpoint);
    store64(m + 16, fstype);
    store64(m + 24, options);
    return m;
}

fn fuse_mount_device(m) { return load64(m); }
fn fuse_mount_mountpoint(m) { return load64(m + 8); }
fn fuse_mount_fstype(m) { return load64(m + 16); }
fn fuse_mount_options(m) { return load64(m + 24); }

# ================================================================
# Parse /proc/mounts
# ================================================================

# Check if a string starts with a prefix.
fn fuse_starts_with(str, prefix) {
    var slen = strlen(str);
    var plen = strlen(prefix);
    if (slen < plen) { return 0; }
    var i = 0;
    while (i < plen) {
        if (load8(str + i) != load8(prefix + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Extract a whitespace-delimited field from a line.
# field_idx: 0-based field index.
# Returns heap-allocated string or 0.
fn fuse_extract_field(line, linelen, field_idx) {
    var pos = 0;
    var field = 0;

    while (field < field_idx) {
        # Skip to next whitespace
        while (pos < linelen) {
            var c = load8(line + pos);
            if (c == 32) { break; }
            if (c == 9) { break; }
            pos = pos + 1;
        }
        # Skip whitespace
        while (pos < linelen) {
            var c = load8(line + pos);
            if (c != 32) { if (c != 9) { break; } }
            pos = pos + 1;
        }
        field = field + 1;
    }

    if (pos >= linelen) { return 0; }

    var start = pos;
    while (pos < linelen) {
        var c = load8(line + pos);
        if (c == 32) { break; }
        if (c == 9) { break; }
        pos = pos + 1;
    }

    var flen = pos - start;
    if (flen == 0) { return 0; }

    var out = alloc(flen + 1);
    memcpy(out, line + start, flen);
    store8(out + flen, 0);
    return out;
}

# Parse /proc/mounts and return FUSE mounts.
# result_arr: pre-allocated array of FuseMount pointers.
# max_mounts: capacity.
# fuse_only: 1 to return only fuse.* mounts, 0 for all.
# Returns Result: Ok(count) or Err.
fn fuse_parse_proc_mounts(result_arr, max_mounts, fuse_only) {
    # Read /proc/mounts
    var fd = sys_open("/proc/mounts", 0, 0);  # O_RDONLY
    if (fd < 0) {
        return err_io(0 - fd, "failed to open /proc/mounts");
    }
    defer { sys_close(fd); }

    var buf = alloc(8192);
    var total_read = 0;
    var nread = sys_read(fd, buf + total_read, 8192 - total_read);
    while (nread > 0) {
        total_read = total_read + nread;
        if (total_read >= 8192) { break; }
        nread = sys_read(fd, buf + total_read, 8192 - total_read);
    }
    store8(buf + total_read, 0);

    # Parse line by line
    # Format: device mountpoint fstype options dump pass
    var count = 0;
    var pos = 0;

    while (pos < total_read) {
        var linestart = pos;
        while (pos < total_read) {
            if (load8(buf + pos) == 10) { break; }
            pos = pos + 1;
        }
        var linelen = pos - linestart;
        if (pos < total_read) { pos = pos + 1; }
        if (linelen == 0) { continue; }

        # Extract fstype (field 2)
        var fstype = fuse_extract_field(buf + linestart, linelen, 2);
        if (fstype == 0) { continue; }

        var include = 1;
        if (fuse_only == 1) {
            if (fuse_starts_with(fstype, "fuse") != 1) {
                include = 0;
            }
        }

        if (include == 1) {
            if (count < max_mounts) {
                var device = fuse_extract_field(buf + linestart, linelen, 0);
                var mpoint = fuse_extract_field(buf + linestart, linelen, 1);
                var opts = fuse_extract_field(buf + linestart, linelen, 3);

                var mount = fuse_mount_new(device, mpoint, fstype, opts);
                store64(result_arr + count * 8, mount);
                count = count + 1;
            }
        }
    }

    return Ok(count);
}

# ================================================================
# Mount FUSE filesystem
# ================================================================

# Mount a FUSE filesystem.
# device: the FUSE filesystem source (e.g., sshfs#user@host:path).
# mountpoint: target directory.
# fuse_type: the specific FUSE fs type command (e.g., "sshfs", "ntfs-3g").
# extra_opts: additional mount options string, or 0 for none.
# Returns Result: Ok(0) or Err.
fn fuse_mount(device, mountpoint, fuse_type, extra_opts) {
    if (device == 0) { return err_invalid_argument("fuse device is null"); }
    if (mountpoint == 0) { return err_invalid_argument("fuse mountpoint is null"); }
    if (fuse_type == 0) { return err_invalid_argument("fuse type is null"); }

    if (strlen(device) == 0) { return err_invalid_argument("fuse device is empty"); }
    if (strlen(mountpoint) == 0) { return err_invalid_argument("fuse mountpoint is empty"); }

    # Use the fuse type command directly (e.g., sshfs, ntfs-3g)
    # Or fusermount for generic mounts
    var argv_size = 32;
    if (extra_opts != 0) { argv_size = 48; }
    var argv = alloc(argv_size);

    store64(argv, fuse_type);
    store64(argv + 8, device);
    store64(argv + 16, mountpoint);

    var argc = 3;
    if (extra_opts != 0) {
        if (strlen(extra_opts) > 0) {
            store64(argv + 24, "-o");
            store64(argv + 32, extra_opts);
            argc = 5;
        }
    }

    var res = run_capture(fuse_type, argv);
    if (is_err_result(res) == 1) { return res; }
    return Ok(0);
}

# ================================================================
# Unmount FUSE filesystem
# ================================================================

# Unmount a FUSE filesystem at the given mountpoint.
# Returns Result: Ok(0) or Err.
fn fuse_unmount(mountpoint) {
    if (mountpoint == 0) { return err_invalid_argument("unmount mountpoint is null"); }
    if (strlen(mountpoint) == 0) { return err_invalid_argument("unmount mountpoint is empty"); }

    var cmd = "fusermount";
    var argv = alloc(24);
    store64(argv, cmd);
    store64(argv + 8, "-u");
    store64(argv + 16, mountpoint);

    var res = run_capture(cmd, argv);
    if (is_err_result(res) == 1) { return res; }
    return Ok(0);
}

# ================================================================
# Lazy unmount (fallback)
# ================================================================

# Lazy unmount via fusermount -uz (for busy mounts).
fn fuse_unmount_lazy(mountpoint) {
    if (mountpoint == 0) { return err_invalid_argument("unmount mountpoint is null"); }

    var cmd = "fusermount";
    var argv = alloc(24);
    store64(argv, cmd);
    store64(argv + 8, "-uz");
    store64(argv + 16, mountpoint);

    var res = run_capture(cmd, argv);
    if (is_err_result(res) == 1) { return res; }
    return Ok(0);
}

# ================================================================
# FUSE availability check
# ================================================================

# Check whether FUSE is available on this system (/dev/fuse exists).
# Returns 1 if available, 0 otherwise.
fn fuse_is_available() {
    return sys_access("/dev/fuse", 0) == 0;
}

# ================================================================
# Mountpoint validation
# ================================================================

# Validate that a path is suitable as a FUSE mountpoint.
# Checks: not null, not root, exists, is a directory.
# Returns Result: Ok(0) or Err.
fn fuse_validate_mountpoint(path) {
    if (path == 0 || strlen(path) == 0) {
        return err_invalid_argument("mountpoint path is empty");
    }

    # Must not be filesystem root
    if (strlen(path) == 1 && load8(path) == 47) {
        return err_invalid_argument("cannot use filesystem root as mountpoint");
    }

    # Check path exists and is a directory
    # stat64 struct: 144 bytes, mode at offset 24
    var statbuf = alloc(144);
    var ret = syscall(4, path, statbuf);  # SYS_STAT
    if (ret < 0) {
        return err_invalid_argument("mountpoint does not exist");
    }

    var mode = load32(statbuf + 24);
    # S_IFDIR = 0x4000 = 16384
    if ((mode & 0xF000) != 0x4000) {
        return err_invalid_argument("mountpoint is not a directory");
    }

    return Ok(0);
}

# ================================================================
# List FUSE mounts (convenience wrapper)
# ================================================================

# List all currently mounted FUSE filesystems.
# Returns Result: Ok(vec_of_mounts) or Err.
fn fuse_list_mounts() {
    var arr = alloc(1024);  # up to 128 mount pointers
    var res = fuse_parse_proc_mounts(arr, 128, 1);
    if (is_err_result(res) == 1) { return res; }
    var count = payload(res);

    var mounts = vec_new();
    var i = 0;
    while (i < count) {
        vec_push(mounts, load64(arr + i * 8));
        i = i + 1;
    }
    return Ok(mounts);
}

# ================================================================
# FUSE mount status
# ================================================================

# FuseStatus constants
enum FuseStatus {
    FUSE_MOUNTED = 1;
    FUSE_NOT_MOUNTED = 2;
    FUSE_ERROR = 3;
}

# Get the status of a FUSE mount at the given mountpoint.
# Returns Result: Ok(FuseStatus) or Err.
fn fuse_get_status(mountpoint) {
    if (mountpoint == 0 || strlen(mountpoint) == 0) {
        return err_invalid_argument("mountpoint is empty");
    }

    var arr = alloc(1024);
    var res = fuse_parse_proc_mounts(arr, 128, 1);
    if (is_err_result(res) == 1) { return Ok(FUSE_ERROR); }
    var count = payload(res);

    var mplen = strlen(mountpoint);
    var i = 0;
    while (i < count) {
        var m = load64(arr + i * 8);
        var mp = fuse_mount_mountpoint(m);
        if (mp != 0 && strlen(mp) == mplen && memeq(mp, mountpoint, mplen) == 1) {
            return Ok(FUSE_MOUNTED);
        }
        i = i + 1;
    }

    return Ok(FUSE_NOT_MOUNTED);
}
