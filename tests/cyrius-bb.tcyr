    world_step(wd);
    assert_eq(world_lives(wd), 2, "life lost");
    assert_eq(world_state(wd), WS_BALL_LOST, "ball lost state");
    return 0;
}

fn test_world_clear() {
    test_group("world clear");
    var b = ball_new(fixed_from_int(50), fixed_from_int(48), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(45), fixed_from_int(45), fixed_from_int(10), fixed_from_int(10), 0, 0, 100);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(bricks_alive_count(g), 0, "last brick gone");
    assert_eq(world_state(wd), WS_LEVEL_CLEAR, "level clear");
    assert_eq(world_score(wd), 100, "score for last brick");
    return 0;
}

fn test_framebuf() {
    test_group("framebuf");
    var f = fb_new(8, 4);
    assert_eq(fb_w(f), 8, "width");
    assert_eq(fb_h(f), 4, "height");
    fb_clear(f, 0, 0, 0);
    assert_eq(fb_get(f, 0, 0, 0), 0, "clear -> 0");
    # fill rect x[2,5) y[1,3)
    fb_fill_rect(f, 2, 1, 3, 2, 100, 150, 200);
    assert_eq(fb_get(f, 2, 1, 0), 100, "rect R");
    assert_eq(fb_get(f, 2, 1, 1), 150, "rect G");
    assert_eq(fb_get(f, 4, 2, 2), 200, "rect B interior");
    assert_eq(fb_get(f, 0, 0, 0), 0, "outside rect stays bg");
    assert_eq(fb_get(f, 5, 1, 0), 0, "right edge exclusive");
    # clipping: rect runs past the right/bottom edges, must not crash
    fb_fill_rect(f, 6, 0, 10, 10, 255, 255, 255);
    assert_eq(fb_get(f, 7, 3, 0), 255, "clipped rect fills in-bounds");
    # out-of-bounds set is a no-op
    assert_eq(fb_set(f, 100, 100, 1, 2, 3), 0, "oob set no-op");
    return 0;
}

fn test_render() {
    test_group("render");
    var f = fb_new(40, 30);
    var b = ball_new(fixed_from_int(20), fixed_from_int(15), 0, 0, fixed_from_int(2));
    var p = paddle_new(fixed_from_int(10), fixed_from_int(26), fixed_from_int(12), fixed_from_int(2));
    var g = bricks_new(2, 1, fixed_from_int(4), fixed_from_int(4), fixed_from_int(8), fixed_from_int(4), fixed_from_int(2), 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(40), fixed_from_int(30), 3, fixed_from_int(4));
    render_world(f, wd);
    # brick face is the tier-1 colour (full RGB), not a flat red
    assert_eq(fb_get(f, 4, 4, 0), rgb_r(tier_rgb(1)), "brick face R = tier 1");
    assert_eq(fb_get(f, 4, 4, 1), rgb_g(tier_rgb(1)), "brick face G = tier 1");
    assert_eq(fb_get(f, 4, 4, 2), rgb_b(tier_rgb(1)), "brick face B = tier 1");
    # 2px extrusion shadow shows past the face's bottom-right edge
    assert_eq(fb_get(f, 12, 8, 0), 10, "brick extrusion shadow");
    assert_eq(fb_get(f, 11, 26, 1), 200, "paddle pixel is green");
    assert_eq(fb_get(f, 20, 15, 0), 240, "ball pixel is white");
    # destroyed brick no longer paints its tier colour
    brick_destroy(g, 0);
    render_world(f, wd);
    assert_eq(fb_get(f, 4, 4, 0) != rgb_r(tier_rgb(1)), 1, "destroyed brick -> not tier colour");
    return 0;
}

fn test_colors() {
    test_group("colors");
    assert_eq(rgb_r(tier_rgb(1)), 80, "tier 1 R");
    assert_eq(rgb_g(tier_rgb(1)), 180, "tier 1 G");
    assert_eq(rgb_b(tier_rgb(1)), 240, "tier 1 B");
    assert_eq(rgb_r(tier_rgb(9)), 210, "tier 9 R");
    assert_eq(tier_rgb(0), 0, "empty tier -> black");
    assert_eq(tier_rgb(1) != tier_rgb(9), 1, "tiers differ in colour");
    return 0;
}

fn test_bg() {
    test_group("bg");
    var f = fb_new(60, 30);
    var b = ball_new(fixed_from_int(0), fixed_from_int(15), 0, 0, fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(28), fixed_from_int(10), fixed_from_int(2));
    var g = bricks_new(1, 1, fixed_from_int(4), fixed_from_int(4), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(60), fixed_from_int(30), 3, fixed_from_int(4));
    render_bg(f, wd);
    var v0 = fb_get(f, 2, 20, 0);
    ball_set_x(b, fixed_from_int(80));
    render_bg(f, wd);
    var v1 = fb_get(f, 2, 20, 0);
    assert_eq(v0 != v1, 1, "parallax bg shifts with ball x");
    return 0;
}

fn test_fx() {
    test_group("fx");
    var fx = fx_new(8);
    assert_eq(fx_active(fx), 0, "pool starts empty");
    fx_debris(fx, 50, 50, 200, 100, 50);
    assert_eq(fx_active(fx), 5, "debris burst = 5 shards");
    fx_collapse(fx, 50, 50, 18, 200, 100, 50);
    assert_eq(fx_active(fx), 6, "collapse adds 1");
    fx_debris(fx, 10, 10, 1, 2, 3);
    assert_eq(fx_active(fx), 8, "spawns capped at capacity");
    # one known particle: integration + gravity + ageing
    var fx2 = fx_new(4);
    fx_spawn(fx2, 30, 40, fixed_from_int(2), 0 - fixed_from_int(3), 10, 3, 9, 9, 9);
    assert_eq(fx_p_x(fx2, 0), fixed_from_int(30), "spawn x");
    assert_eq(fx_p_life(fx2, 0), 10, "spawn life");
    fx_step(fx2);
    assert_eq(fx_p_x(fx2, 0), fixed_from_int(32), "x += vx");
    assert_eq(fx_p_y(fx2, 0), fixed_from_int(40) - fixed_from_int(3), "y += vy");
    assert_eq(fx_p_vy(fx2, 0), (0 - fixed_from_int(3)) + asr(FIXED_ONE, 2), "vy += gravity");
    assert_eq(fx_p_life(fx2, 0), 9, "life decremented");
    var k = 0;
    while (k < 10) { fx_step(fx2); k += 1; }
    assert_eq(fx_active(fx2), 0, "particles expire to free slots");
    return 0;
}

fn test_hud() {
    test_group("hud");
    hud_init();
    var f = fb_new(20, 10);
    fb_clear(f, 0, 0, 0);
    # digit '1' at (0,0) scale 1: rows 010/110/010/010/111
    hud_draw_digit(f, 0, 0, 1, 1, 255, 255, 255);
    assert_eq(fb_get(f, 1, 0, 0), 255, "'1' top-middle on");
    assert_eq(fb_get(f, 0, 0, 0), 0, "'1' top-left off");
    assert_eq(fb_get(f, 0, 4, 0), 255, "'1' bottom row on");
    assert_eq(fb_get(f, 2, 4, 0), 255, "'1' bottom-right on");
    # digit '0': row1 = 101 -> centre hole
    fb_clear(f, 0, 0, 0);
    hud_draw_number(f, 0, 0, 0, 1, 255, 255, 255);
    assert_eq(fb_get(f, 0, 0, 0), 255, "'0' top-left on");
    assert_eq(fb_get(f, 1, 0, 0), 255, "'0' top-middle on");
    assert_eq(fb_get(f, 1, 1, 0), 0, "'0' centre hole");
    assert_eq(fb_get(f, 2, 1, 0), 255, "'0' right side on");
    # out-of-range digit is ignored (no crash, nothing drawn)
    fb_clear(f, 0, 0, 0);
    hud_draw_digit(f, 0, 0, 42, 1, 255, 255, 255);
    assert_eq(fb_get(f, 0, 0, 0), 0, "bad digit draws nothing");
    return 0;
}

fn test_input() {
    test_group("input");
    assert_eq(bb_key_action(97), ACT_LEFT, "'a' -> LEFT");
    assert_eq(bb_key_action(100), ACT_RIGHT, "'d' -> RIGHT");
    assert_eq(bb_key_action(32), ACT_LAUNCH, "space -> LAUNCH");
    assert_eq(bb_key_action(113), ACT_QUIT, "'q' -> QUIT");
    assert_eq(bb_key_action(27), ACT_QUIT, "ESC -> QUIT");
    assert_eq(bb_key_action(109), ACT_MUTE, "'m' -> MUTE");
    assert_eq(bb_key_action(120), 0, "'x' -> no action");
    return 0;
}

fn test_world_serve() {
    test_group("world serve");
    var b = ball_new(fixed_from_int(100), fixed_from_int(204), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(10), fixed_from_int(10), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(world_state(wd), WS_BALL_LOST, "ball lost first");
    world_serve(wd, fixed_from_int(100), fixed_from_int(100), fixed_from_int(1), 0 - fixed_from_int(3));
    assert_eq(world_state(wd), WS_PLAYING, "serve resumes play");
    assert_eq(ball_y(world_ball(wd)), fixed_from_int(100), "ball repositioned");
    assert_eq(ball_vy(world_ball(wd)), 0 - fixed_from_int(3), "ball re-served velocity");
    return 0;
}

fn test_level() {
    test_group("level");
    # cell char -> tier mapping
    assert_eq(cell_tier(49), 1, "'1' -> tier 1");
    assert_eq(cell_tier(57), 9, "'9' -> tier 9");
    assert_eq(cell_tier(35), 1, "'#' -> tier 1");
    assert_eq(cell_tier(46), 0, "'.' -> empty");
    assert_eq(cell_tier(32), 0, "space -> empty");
    # parser on an ad-hoc layout with a gap and a short line
    assert_eq(layout_cols(".1.\n22.\n"), 3, "cols = longest line");
    assert_eq(layout_rows(".1.\n22.\n"), 2, "rows = line count");
    assert_eq(layout_count(".1.\n22.\n"), 3, "count = live cells");
    # shipped layouts: 5 levels, increasing brick count
    assert_eq(level_count(), 5, "five levels");
    assert_eq(layout_count(level_layout(0)), 18, "L1 brick count");
    assert_eq(layout_count(level_layout(1)), 25, "L2 brick count");
    assert_eq(layout_count(level_layout(2)), 34, "L3 brick count");
    assert_eq(layout_count(level_layout(3)), 40, "L4 brick count");
    assert_eq(layout_count(level_layout(4)), 49, "L5 brick count");
    # built grid: total = cols*rows, alive = live cells (L4 has gaps)
    var g1 = level_make_bricks(0, 200);
    assert_eq(bricks_total(g1), 18, "L1 grid 9x2");
    assert_eq(bricks_alive_count(g1), 18, "L1 all cells live");
    assert_eq(brick_tier(g1, 0), 3, "L1 top row tier 3");
    assert_eq(brick_tier(g1, 9), 1, "L1 bottom row tier 1");
    assert_eq(brick_destroy(g1, 0), 30, "tier 3 brick = 30 pts");
    assert_eq(brick_destroy(g1, 9), 10, "tier 1 brick = 10 pts");
    var g4 = level_make_bricks(3, 200);
    assert_eq(bricks_total(g4), 45, "L4 grid 9x5");
    assert_eq(bricks_alive_count(g4), 40, "L4 has 5 gap cells");
    # speed curve rises (and stays <= brick height for collision safety)
    assert_eq(level_serve_vx(0), fixed_from_int(3), "L1 serve vx");
    assert_eq(level_serve_vy(0), 0 - fixed_from_int(4), "L1 serve vy");
    assert_eq(level_serve_vy(4), 0 - fixed_from_int(6), "L5 serve vy faster");
    assert_eq(fixed_abs(level_serve_vy(4)) > fixed_abs(level_serve_vy(0)), 1, "speed climbs across levels");
    return 0;
}

fn test_level_progress() {
    test_group("level progress");
    # mid-game world: 1-brick level, score in flight, 2 lives left
    var b = ball_new(fixed_from_int(50), fixed_from_int(48), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(45), fixed_from_int(45), fixed_from_int(10), fixed_from_int(10), 0, 0, 100);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 2, fixed_from_int(4));
    world_step(wd);
    assert_eq(world_state(wd), WS_LEVEL_CLEAR, "single brick cleared");
    assert_eq(world_score(wd), 100, "score before advancing");
    # advance into level 1 (the 25-brick cascade)
    level_load(wd, 1, 200, fixed_from_int(100), fixed_from_int(110));
    assert_eq(world_state(wd), WS_PLAYING, "level_load resumes play");
    assert_eq(world_score(wd), 100, "score carries across levels");
    assert_eq(world_lives(wd), 2, "lives carry across levels");
    assert_eq(bricks_alive_count(world_bricks(wd)), 25, "next level's bricks loaded");
    assert_eq(ball_vy(world_ball(wd)), level_serve_vy(1), "ball re-served at level speed");
    assert_eq(ball_y(world_ball(wd)), fixed_from_int(110), "ball repositioned to serve y");
    return 0;
}

fn test_audio() {
    test_group("audio");
    audio_init();
    var buf = alloc(64);
    # square wave at 441 Hz -> half-period = 11025/(2*441) = 12 samples, amp 50
    synth_tone(buf, 0, 64, 441, 441, 50, 50);
    assert_eq(load8(buf + 0), 178, "square hi = 128 + amp");
    assert_eq(load8(buf + 11), 178, "still hi through first half-period");
    assert_eq(load8(buf + 12), 78, "flips to lo = 128 - amp");
    assert_eq(load8(buf + 23), 78, "still lo through second half-period");
    assert_eq(load8(buf + 24), 178, "flips back to hi");
    # amp 0 -> centre (silence) regardless of phase
    synth_tone(buf, 0, 64, 441, 441, 0, 0);
    assert_eq(load8(buf + 0), 128, "amp 0 -> centre");
    assert_eq(load8(buf + 40), 128, "amp 0 -> centre later");
    # amplitude envelope: first sample carries a0
    synth_tone(buf, 0, 64, 441, 441, 80, 0);
    assert_eq(load8(buf + 0), 208, "amp envelope starts at a0");
    # SFX registry built
    assert_eq(sfx_len(SFX_PADDLE) > 0, 1, "paddle SFX built");
    assert_eq(sfx_buf(SFX_BRICK) != 0, 1, "brick SFX buffer allocated");
    assert_eq(sfx_len(SFX_FANFARE), ms_samples(90) * 4, "fanfare = 4 segments");
    # mute toggle
    audio_set_mute(0);
    assert_eq(audio_muted(), 0, "starts unmuted");
    assert_eq(audio_toggle_mute(), 1, "toggle -> muted");
    assert_eq(audio_muted(), 1, "muted");
    audio_toggle_mute();
    assert_eq(audio_muted(), 0, "toggle -> unmuted");
    return 0;
}

fn main() {
    alloc_init();
    test_smoke();
    test_fixed();
    test_geom();
    test_ball();
    test_paddle();
    test_bricks();
    test_world_wall();
    test_world_top();
    test_world_paddle();
    test_world_brick();
    test_world_lost();
    test_world_clear();
    test_framebuf();
    test_render();
    test_hud();
    test_input();
    test_world_serve();
    test_level();
    test_level_progress();
    test_colors();
    test_bg();
    test_fx();
    test_audio();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
