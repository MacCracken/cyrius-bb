fn test_smoke() {
    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");
    return 0;
}

fn test_fixed() {
    test_group("fixed");
    assert_eq(fixed_from_int(5), 5 * FIXED_ONE, "from_int(5)");
    assert_eq(fixed_to_int(fixed_from_int(7)), 7, "roundtrip 7");
    assert_eq(fixed_mul(fixed_from_int(2), fixed_from_int(3)), fixed_from_int(6), "mul 2*3 = 6");
    assert_eq(fixed_div(fixed_from_int(6), fixed_from_int(2)), fixed_from_int(3), "div 6/2 = 3");
    assert_eq(asr(0 - 16, 2), 0 - 4, "asr floors -16>>2 = -4");
    assert_eq(asr(16, 2), 4, "asr 16>>2 = 4");
    assert_eq(fixed_abs(0 - fixed_from_int(3)), fixed_from_int(3), "abs(-3) = 3");
    assert_eq(fixed_clamp(fixed_from_int(10), 0, fixed_from_int(5)), fixed_from_int(5), "clamp hi");
    assert_eq(fixed_div(FIXED_ONE, 0), FIXED_MAX, "div by zero -> MAX");
    return 0;
}

fn test_geom() {
    test_group("geom");
    assert_eq(aabb_overlap(0, 0, fixed_from_int(4), fixed_from_int(4), fixed_from_int(2), fixed_from_int(2), fixed_from_int(4), fixed_from_int(4)), 1, "overlap yes");
    assert_eq(aabb_overlap(0, 0, fixed_from_int(2), fixed_from_int(2), fixed_from_int(10), 0, fixed_from_int(2), fixed_from_int(2)), 0, "overlap no");
    assert_eq(reflect(fixed_from_int(3)), 0 - fixed_from_int(3), "reflect + -> -");
    assert_eq(reflect(0 - fixed_from_int(3)), fixed_from_int(3), "reflect - -> +");
    var cx = fixed_from_int(100);
    var half = fixed_from_int(20);
    assert_eq(paddle_english(cx, cx, half), 0, "english centre = 0");
    assert_eq(paddle_english(cx + half, cx, half), FIXED_ONE, "english right edge = +1");
    assert_eq(paddle_english(cx - half, cx, half), 0 - FIXED_ONE, "english left edge = -1");
    assert_eq(paddle_english(cx + half + half, cx, half), FIXED_ONE, "english beyond clamps to +1");
    return 0;
}

fn test_ball() {
    test_group("ball");
    var b = ball_new(fixed_from_int(10), fixed_from_int(20), fixed_from_int(3), fixed_from_int(5), fixed_from_int(2));
    assert_eq(ball_x(b), fixed_from_int(10), "ball x");
    assert_eq(ball_vx(b), fixed_from_int(3), "ball vx");
    assert_eq(ball_r(b), fixed_from_int(2), "ball r");
    ball_integrate(b);
    assert_eq(ball_x(b), fixed_from_int(13), "integrate x += vx");
    assert_eq(ball_y(b), fixed_from_int(25), "integrate y += vy");
    ball_set_vx(b, 0 - fixed_from_int(1));
    assert_eq(ball_vx(b), 0 - fixed_from_int(1), "set vx negative");
    return 0;
}

fn test_paddle() {
    test_group("paddle");
    var p = paddle_new(fixed_from_int(50), fixed_from_int(190), fixed_from_int(20), fixed_from_int(4));
    assert_eq(paddle_cx(p), fixed_from_int(60), "centre = x + w/2");
    paddle_move(p, fixed_from_int(5), 0, fixed_from_int(200));
    assert_eq(paddle_x(p), fixed_from_int(55), "move right by 5");
    paddle_move(p, fixed_from_int(1000), 0, fixed_from_int(200));
    assert_eq(paddle_x(p), fixed_from_int(180), "clamp right edge to 200");
    paddle_move(p, 0 - fixed_from_int(1000), 0, fixed_from_int(200));
    assert_eq(paddle_x(p), 0, "clamp left to 0");
    return 0;
}

fn test_bricks() {
    test_group("bricks");
    var g = bricks_new(3, 2, fixed_from_int(4), fixed_from_int(4), fixed_from_int(10), fixed_from_int(5), fixed_from_int(2), fixed_from_int(2), 50);
    assert_eq(bricks_total(g), 6, "total bricks");
    assert_eq(bricks_alive_count(g), 6, "all alive");
    assert_eq(brick_x(g, 1), fixed_from_int(16), "brick 1 x (col 1)");
    assert_eq(brick_y(g, 1), fixed_from_int(4), "brick 1 y (row 0)");
    assert_eq(brick_x(g, 3), fixed_from_int(4), "brick 3 x (col 0)");
    assert_eq(brick_y(g, 3), fixed_from_int(11), "brick 3 y (row 1)");
    assert_eq(brick_destroy(g, 0), 50, "destroy returns value");
    assert_eq(brick_alive(g, 0), 0, "brick 0 dead");
    assert_eq(bricks_alive_count(g), 5, "count decremented");
    assert_eq(brick_destroy(g, 0), 0, "re-destroy returns 0");
    assert_eq(bricks_alive_count(g), 5, "count unchanged on re-destroy");
    return 0;
}

fn test_world_wall() {
    test_group("world wall");
    var b = ball_new(fixed_from_int(197), fixed_from_int(100), fixed_from_int(5), 0, fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(10), fixed_from_int(10), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(ball_vx(b), 0 - fixed_from_int(5), "right wall reflects vx");
    assert_eq(ball_x(b), fixed_from_int(198), "right wall clamps x to w-r");
    assert_eq(world_state(wd), WS_PLAYING, "still playing");
    assert_eq((world_events(wd) & EV_WALL) != 0, 1, "wall bounce raises EV_WALL");
    return 0;
}

fn test_world_top() {
    test_group("world top");
    var b = ball_new(fixed_from_int(100), fixed_from_int(3), 0, 0 - fixed_from_int(5), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(150), fixed_from_int(150), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(ball_vy(b), fixed_from_int(5), "top wall reflects vy");
    assert_eq(ball_y(b), fixed_from_int(2), "top clamps y to r");
    return 0;
}

fn test_world_paddle() {
    test_group("world paddle");
    var b = ball_new(fixed_from_int(100), fixed_from_int(187), 0, fixed_from_int(5), fixed_from_int(2));
    var p = paddle_new(fixed_from_int(90), fixed_from_int(190), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(10), fixed_from_int(10), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(ball_vy(b), 0 - fixed_from_int(5), "paddle reflects vy up");
    assert_eq(ball_vx(b), 0, "centre hit -> no english");
    assert_eq(ball_y(b), fixed_from_int(188), "ball nudged above paddle");
    assert_eq(world_state(wd), WS_PLAYING, "still playing after paddle");
    assert_eq((world_events(wd) & EV_PADDLE) != 0, 1, "paddle bounce raises EV_PADDLE");
    return 0;
}

fn test_world_brick() {
    test_group("world brick");
    var b = ball_new(fixed_from_int(50), fixed_from_int(48), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(2, 1, fixed_from_int(45), fixed_from_int(45), fixed_from_int(10), fixed_from_int(10), fixed_from_int(20), 0, 100);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(world_score(wd), 100, "brick destroyed -> score += value");
    assert_eq(bricks_alive_count(g), 1, "one brick left");
    assert_eq(brick_alive(g, 0), 0, "brick 0 destroyed");
    assert_eq(ball_vy(b), 0 - fixed_from_int(2), "brick reflects vy");
    assert_eq(world_state(wd), WS_PLAYING, "playing, bricks remain");
    assert_eq((world_events(wd) & EV_BRICK) != 0, 1, "brick hit raises EV_BRICK");
    return 0;
}

fn test_world_lost() {
    test_group("world lost");
    var b = ball_new(fixed_from_int(100), fixed_from_int(204), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
