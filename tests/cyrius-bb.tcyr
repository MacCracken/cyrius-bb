fn test_smoke() {
    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");
    return 0;
}

# |a - b| < tol, for fixed-point approx checks (rounding in unit vectors).
fn near(a, b, tol): i64 {
    if (fixed_abs(a - b) < tol) { return 1; }
    return 0;
}

fn test_fixed() {
    test_group("fixed");
    assert_eq(fixed_from_int(5), 5 * FIXED_ONE, "from_int(5)");
    assert_eq(fixed_to_int(fixed_from_int(7)), 7, "roundtrip 7");
    assert_eq(fixed_mul(fixed_from_int(2), fixed_from_int(3)), fixed_from_int(6), "mul 2*3 = 6");
    assert_eq(fixed_div(fixed_from_int(6), fixed_from_int(2)), fixed_from_int(3), "div 6/2 = 3");
    assert_eq(asr(0 - 16, 2), 0 - 4, "asr floors -16>>2 = -4");
    assert_eq(asr(16, 2), 4, "asr 16>>2 = 4");
    assert_eq(fixed_abs(0 - fixed_from_int(3)), fixed_from_int(3), "abs(-3) = 3");
    assert_eq(fixed_clamp(fixed_from_int(10), 0, fixed_from_int(5)), fixed_from_int(5), "clamp hi");
    assert_eq(fixed_div(FIXED_ONE, 0), FIXED_MAX, "div by zero -> MAX");
    return 0;
}

fn test_geom() {
    test_group("geom");
    assert_eq(aabb_overlap(0, 0, fixed_from_int(4), fixed_from_int(4), fixed_from_int(2), fixed_from_int(2), fixed_from_int(4), fixed_from_int(4)), 1, "overlap yes");
    assert_eq(aabb_overlap(0, 0, fixed_from_int(2), fixed_from_int(2), fixed_from_int(10), 0, fixed_from_int(2), fixed_from_int(2)), 0, "overlap no");
    assert_eq(reflect(fixed_from_int(3)), 0 - fixed_from_int(3), "reflect + -> -");
    assert_eq(reflect(0 - fixed_from_int(3)), fixed_from_int(3), "reflect - -> +");
    var cx = fixed_from_int(100);
    var half = fixed_from_int(20);
    assert_eq(paddle_english(cx, cx, half), 0, "english centre = 0");
    assert_eq(paddle_english(cx + half, cx, half), FIXED_ONE, "english right edge = +1");
    assert_eq(paddle_english(cx - half, cx, half), 0 - FIXED_ONE, "english left edge = -1");
    assert_eq(paddle_english(cx + half + half, cx, half), FIXED_ONE, "english beyond clamps to +1");
    return 0;
}

fn test_ball() {
    test_group("ball");
    var b = ball_new(fixed_from_int(10), fixed_from_int(20), fixed_from_int(3), fixed_from_int(5), fixed_from_int(2));
    assert_eq(ball_x(b), fixed_from_int(10), "ball x");
    assert_eq(ball_vx(b), fixed_from_int(3), "ball vx");
    assert_eq(ball_r(b), fixed_from_int(2), "ball r");
    ball_integrate(b);
    assert_eq(ball_x(b), fixed_from_int(13), "integrate x += vx");
    assert_eq(ball_y(b), fixed_from_int(25), "integrate y += vy");
    ball_set_vx(b, 0 - fixed_from_int(1));
    assert_eq(ball_vx(b), 0 - fixed_from_int(1), "set vx negative");
    return 0;
}

fn test_paddle() {
    test_group("paddle");
    var p = paddle_new(fixed_from_int(50), fixed_from_int(190), fixed_from_int(20), fixed_from_int(4));
    assert_eq(paddle_cx(p), fixed_from_int(60), "centre = x + w/2");
    paddle_move(p, fixed_from_int(5), 0, fixed_from_int(200));
    assert_eq(paddle_x(p), fixed_from_int(55), "move right by 5");
    paddle_move(p, fixed_from_int(1000), 0, fixed_from_int(200));
    assert_eq(paddle_x(p), fixed_from_int(180), "clamp right edge to 200");
    paddle_move(p, 0 - fixed_from_int(1000), 0, fixed_from_int(200));
    assert_eq(paddle_x(p), 0, "clamp left to 0");
    return 0;
}

fn test_bricks() {
    test_group("bricks");
    var g = bricks_new(3, 2, fixed_from_int(4), fixed_from_int(4), fixed_from_int(10), fixed_from_int(5), fixed_from_int(2), fixed_from_int(2), 50);
    assert_eq(bricks_total(g), 6, "total bricks");
    assert_eq(bricks_alive_count(g), 6, "all alive");
    assert_eq(brick_x(g, 1), fixed_from_int(16), "brick 1 x (col 1)");
    assert_eq(brick_y(g, 1), fixed_from_int(4), "brick 1 y (row 0)");
    assert_eq(brick_x(g, 3), fixed_from_int(4), "brick 3 x (col 0)");
    assert_eq(brick_y(g, 3), fixed_from_int(11), "brick 3 y (row 1)");
    assert_eq(brick_destroy(g, 0), 50, "destroy returns value");
    assert_eq(brick_alive(g, 0), 0, "brick 0 dead");
    assert_eq(bricks_alive_count(g), 5, "count decremented");
    assert_eq(brick_destroy(g, 0), 0, "re-destroy returns 0");
    assert_eq(bricks_alive_count(g), 5, "count unchanged on re-destroy");
    return 0;
}

fn test_world_wall() {
    test_group("world wall");
    var b = ball_new(fixed_from_int(197), fixed_from_int(100), fixed_from_int(5), 0, fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(10), fixed_from_int(10), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(ball_vx(b), 0 - fixed_from_int(5), "right wall reflects vx");
    assert_eq(ball_x(b), fixed_from_int(198), "right wall clamps x to w-r");
    assert_eq(world_state(wd), WS_PLAYING, "still playing");
    assert_eq((world_events(wd) & EV_WALL) != 0, 1, "wall bounce raises EV_WALL");
    return 0;
}

fn test_world_top() {
    test_group("world top");
    var b = ball_new(fixed_from_int(100), fixed_from_int(3), 0, 0 - fixed_from_int(5), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(150), fixed_from_int(150), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(ball_vy(b), fixed_from_int(5), "top wall reflects vy");
    assert_eq(ball_y(b), fixed_from_int(2), "top clamps y to r");
    return 0;
}

fn test_world_paddle() {
    test_group("world paddle");
    var b = ball_new(fixed_from_int(100), fixed_from_int(187), 0, fixed_from_int(5), fixed_from_int(2));
    var p = paddle_new(fixed_from_int(90), fixed_from_int(190), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(10), fixed_from_int(10), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    # speed-conserving rebound: a centre hit leaves straight up at the
    # world's target speed (4 here), independent of the incoming vy (5).
    assert_eq(ball_vy(b), 0 - fixed_from_int(4), "centre hit -> up at target speed");
    assert_eq(ball_vx(b), 0, "centre hit -> no english");
    assert_eq(ball_y(b), fixed_from_int(188), "ball nudged above paddle");
    assert_eq(world_state(wd), WS_PLAYING, "still playing after paddle");
    assert_eq((world_events(wd) & EV_PADDLE) != 0, 1, "paddle bounce raises EV_PADDLE");
    return 0;
}

fn test_world_brick() {
    test_group("world brick");
    var b = ball_new(fixed_from_int(50), fixed_from_int(48), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(2, 1, fixed_from_int(45), fixed_from_int(45), fixed_from_int(10), fixed_from_int(10), fixed_from_int(20), 0, 100);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(world_score(wd), 100, "brick destroyed -> score += value");
    assert_eq(bricks_alive_count(g), 1, "one brick left");
    assert_eq(brick_alive(g, 0), 0, "brick 0 destroyed");
    assert_eq(ball_vy(b), 0 - fixed_from_int(2), "brick reflects vy");
    assert_eq(world_state(wd), WS_PLAYING, "playing, bricks remain");
    assert_eq((world_events(wd) & EV_BRICK) != 0, 1, "brick hit raises EV_BRICK");
    return 0;
}

fn test_world_lost() {
    test_group("world lost");
    var b = ball_new(fixed_from_int(100), fixed_from_int(204), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(10), fixed_from_int(10), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(world_lives(wd), 2, "life lost");
    assert_eq(world_state(wd), WS_BALL_LOST, "ball lost state");
    return 0;
}

fn test_world_clear() {
    test_group("world clear");
    var b = ball_new(fixed_from_int(50), fixed_from_int(48), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(45), fixed_from_int(45), fixed_from_int(10), fixed_from_int(10), 0, 0, 100);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(bricks_alive_count(g), 0, "last brick gone");
    assert_eq(world_state(wd), WS_LEVEL_CLEAR, "level clear");
    assert_eq(world_score(wd), 100, "score for last brick");
    return 0;
}

fn test_framebuf() {
    test_group("framebuf");
    var f = fb_new(8, 4);
    assert_eq(fb_w(f), 8, "width");
    assert_eq(fb_h(f), 4, "height");
    fb_clear(f, 0, 0, 0);
    assert_eq(fb_get(f, 0, 0, 0), 0, "clear -> 0");
    # fill rect x[2,5) y[1,3)
    fb_fill_rect(f, 2, 1, 3, 2, 100, 150, 200);
    assert_eq(fb_get(f, 2, 1, 0), 100, "rect R");
    assert_eq(fb_get(f, 2, 1, 1), 150, "rect G");
    assert_eq(fb_get(f, 4, 2, 2), 200, "rect B interior");
    assert_eq(fb_get(f, 0, 0, 0), 0, "outside rect stays bg");
    assert_eq(fb_get(f, 5, 1, 0), 0, "right edge exclusive");
    # clipping: rect runs past the right/bottom edges, must not crash
    fb_fill_rect(f, 6, 0, 10, 10, 255, 255, 255);
    assert_eq(fb_get(f, 7, 3, 0), 255, "clipped rect fills in-bounds");
    # out-of-bounds set is a no-op
    assert_eq(fb_set(f, 100, 100, 1, 2, 3), 0, "oob set no-op");
    return 0;
}

fn test_render() {
    test_group("render");
    var f = fb_new(40, 30);
    var b = ball_new(fixed_from_int(20), fixed_from_int(15), 0, 0, fixed_from_int(2));
    var p = paddle_new(fixed_from_int(10), fixed_from_int(26), fixed_from_int(12), fixed_from_int(2));
    var g = bricks_new(2, 1, fixed_from_int(4), fixed_from_int(4), fixed_from_int(8), fixed_from_int(4), fixed_from_int(2), 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(40), fixed_from_int(30), 3, fixed_from_int(4));
    render_world(f, wd);
    # beveled brick: lit top-left edge over a tier-coloured interior face
    assert_eq(fb_get(f, 4, 4, 0), lighten(rgb_r(tier_rgb(1)), 70), "brick top-left bevel highlight");
    assert_eq(fb_get(f, 6, 5, 0), rgb_r(tier_rgb(1)), "brick interior face R = tier 1");
    assert_eq(fb_get(f, 6, 5, 1), rgb_g(tier_rgb(1)), "brick interior face G = tier 1");
    assert_eq(fb_get(f, 6, 5, 2), rgb_b(tier_rgb(1)), "brick interior face B = tier 1");
    # 2px extrusion shadow shows past the face's bottom-right edge
    assert_eq(fb_get(f, 12, 8, 0), 10, "brick extrusion shadow");
    # paddle: lit top edge over a green body
    assert_eq(fb_get(f, 11, 26, 1), 240, "paddle lit top edge");
    assert_eq(fb_get(f, 11, 27, 1), 168, "paddle body green");
    # ball: rounded body + bright highlight
    assert_eq(fb_get(f, 20, 16, 0), 235, "ball body");
    assert_eq(fb_get(f, 19, 14, 0), 255, "ball highlight");
    # destroyed brick no longer paints its tier colour
    brick_destroy(g, 0);
    render_world(f, wd);
    assert_eq(fb_get(f, 6, 5, 0) != rgb_r(tier_rgb(1)), 1, "destroyed brick interior -> not tier");
    return 0;
}

fn test_colors() {
    test_group("colors");
    assert_eq(rgb_r(tier_rgb(1)), 80, "tier 1 R");
    assert_eq(rgb_g(tier_rgb(1)), 180, "tier 1 G");
    assert_eq(rgb_b(tier_rgb(1)), 240, "tier 1 B");
    assert_eq(rgb_r(tier_rgb(9)), 210, "tier 9 R");
    assert_eq(tier_rgb(0), 0, "empty tier -> black");
    assert_eq(tier_rgb(1) != tier_rgb(9), 1, "tiers differ in colour");
    return 0;
}

fn test_bg() {
    test_group("bg");
    var f = fb_new(60, 30);
    var b = ball_new(fixed_from_int(0), fixed_from_int(15), 0, 0, fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(28), fixed_from_int(10), fixed_from_int(2));
    var g = bricks_new(1, 1, fixed_from_int(4), fixed_from_int(4), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(60), fixed_from_int(30), 3, fixed_from_int(4));
    render_bg(f, wd);
    var v0 = fb_get(f, 2, 20, 0);
    ball_set_x(b, fixed_from_int(80));
    render_bg(f, wd);
    var v1 = fb_get(f, 2, 20, 0);
    assert_eq(v0 != v1, 1, "parallax bg shifts with ball x");
    return 0;
}

fn test_fx() {
    test_group("fx");
    var fx = fx_new(8);
    assert_eq(fx_active(fx), 0, "pool starts empty");
    fx_debris(fx, 50, 50, 200, 100, 50);
    assert_eq(fx_active(fx), 5, "debris burst = 5 shards");
    fx_collapse(fx, 50, 50, 18, 200, 100, 50);
    assert_eq(fx_active(fx), 6, "collapse adds 1");
    fx_debris(fx, 10, 10, 1, 2, 3);
    assert_eq(fx_active(fx), 8, "spawns capped at capacity");
    # one known particle: integration + gravity + ageing
    var fx2 = fx_new(4);
    fx_spawn(fx2, 30, 40, fixed_from_int(2), 0 - fixed_from_int(3), 10, 3, 9, 9, 9);
    assert_eq(fx_p_x(fx2, 0), fixed_from_int(30), "spawn x");
    assert_eq(fx_p_life(fx2, 0), 10, "spawn life");
    fx_step(fx2);
    assert_eq(fx_p_x(fx2, 0), fixed_from_int(32), "x += vx");
    assert_eq(fx_p_y(fx2, 0), fixed_from_int(40) - fixed_from_int(3), "y += vy");
    assert_eq(fx_p_vy(fx2, 0), (0 - fixed_from_int(3)) + asr(FIXED_ONE, 2), "vy += gravity");
    assert_eq(fx_p_life(fx2, 0), 9, "life decremented");
    var k = 0;
    while (k < 10) { fx_step(fx2); k += 1; }
    assert_eq(fx_active(fx2), 0, "particles expire to free slots");
    return 0;
}

fn test_hud() {
    test_group("hud");
    hud_init();
    var f = fb_new(20, 10);
    fb_clear(f, 0, 0, 0);
    # digit '1' at (0,0) scale 1: rows 010/110/010/010/111
    hud_draw_digit(f, 0, 0, 1, 1, 255, 255, 255);
    assert_eq(fb_get(f, 1, 0, 0), 255, "'1' top-middle on");
    assert_eq(fb_get(f, 0, 0, 0), 0, "'1' top-left off");
    assert_eq(fb_get(f, 0, 4, 0), 255, "'1' bottom row on");
    assert_eq(fb_get(f, 2, 4, 0), 255, "'1' bottom-right on");
    # digit '0': row1 = 101 -> centre hole
    fb_clear(f, 0, 0, 0);
    hud_draw_number(f, 0, 0, 0, 1, 255, 255, 255);
    assert_eq(fb_get(f, 0, 0, 0), 255, "'0' top-left on");
    assert_eq(fb_get(f, 1, 0, 0), 255, "'0' top-middle on");
    assert_eq(fb_get(f, 1, 1, 0), 0, "'0' centre hole");
    assert_eq(fb_get(f, 2, 1, 0), 255, "'0' right side on");
    # out-of-range digit is ignored (no crash, nothing drawn)
    fb_clear(f, 0, 0, 0);
    hud_draw_digit(f, 0, 0, 42, 1, 255, 255, 255);
    assert_eq(fb_get(f, 0, 0, 0), 0, "bad digit draws nothing");
    # letter 'A' (idx 0) = rows 010/101/111/101/101
    fb_clear(f, 0, 0, 0);
    hud_draw_letter(f, 0, 0, 0, 1, 255, 255, 255);
    assert_eq(fb_get(f, 1, 0, 0), 255, "'A' top-middle on");
    assert_eq(fb_get(f, 0, 0, 0), 0, "'A' top-left off");
    assert_eq(fb_get(f, 0, 2, 0), 255, "'A' crossbar row left on");
    # hud_draw_char maps ASCII 'Z' (90) -> letter 25
    fb_clear(f, 0, 0, 0);
    hud_draw_char(f, 0, 0, 90, 1, 255, 255, 255);
    assert_eq(fb_get(f, 0, 0, 0), 255, "'Z' top-left on");
    assert_eq(fb_get(f, 0, 4, 0), 255, "'Z' bottom-left on");
    hud_draw_char(f, 10, 0, 64, 1, 255, 255, 255);
    assert_eq(fb_get(f, 10, 0, 0), 0, "'@' (non-letter) draws nothing");
    return 0;
}

fn test_input() {
    test_group("input");
    assert_eq(bb_key_action(97), ACT_LEFT, "'a' -> LEFT");
    assert_eq(bb_key_action(100), ACT_RIGHT, "'d' -> RIGHT");
    assert_eq(bb_key_action(32), ACT_LAUNCH, "space -> LAUNCH");
    assert_eq(bb_key_action(113), ACT_QUIT, "'q' -> QUIT");
    assert_eq(bb_key_action(27), ACT_QUIT, "ESC -> QUIT");
    assert_eq(bb_key_action(109), ACT_MUTE, "'m' -> MUTE");
    assert_eq(bb_key_action(120), 0, "'x' -> no action");
    # key-held latch: arming re-loads to PADDLE_HOLD_FRAMES, idle decays to 0
    assert_eq(input_hold_step(0, 1), PADDLE_HOLD_FRAMES, "armed -> full latch");
    assert_eq(input_hold_step(PADDLE_HOLD_FRAMES, 0), PADDLE_HOLD_FRAMES - 1, "idle decays by 1");
    assert_eq(input_hold_step(1, 0), 0, "decays to 0");
    assert_eq(input_hold_step(0, 0), 0, "stays at 0 when idle");
    assert_eq(input_hold_step(2, ACT_LEFT), PADDLE_HOLD_FRAMES, "action bit re-arms latch");
    return 0;
}

fn test_world_serve() {
    test_group("world serve");
    var b = ball_new(fixed_from_int(100), fixed_from_int(204), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(10), fixed_from_int(10), fixed_from_int(8), fixed_from_int(4), 0, 0, 10);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 3, fixed_from_int(4));
    world_step(wd);
    assert_eq(world_state(wd), WS_BALL_LOST, "ball lost first");
    world_serve(wd, fixed_from_int(100), fixed_from_int(100), fixed_from_int(1), 0 - fixed_from_int(3));
    assert_eq(world_state(wd), WS_PLAYING, "serve resumes play");
    assert_eq(ball_y(world_ball(wd)), fixed_from_int(100), "ball repositioned");
    assert_eq(ball_vy(world_ball(wd)), 0 - fixed_from_int(3), "ball re-served velocity");
    return 0;
}

fn test_level() {
    test_group("level");
    # cell char -> tier mapping
    assert_eq(cell_tier(49), 1, "'1' -> tier 1");
    assert_eq(cell_tier(57), 9, "'9' -> tier 9");
    assert_eq(cell_tier(35), 1, "'#' -> tier 1");
    assert_eq(cell_tier(46), 0, "'.' -> empty");
    assert_eq(cell_tier(32), 0, "space -> empty");
    # parser on an ad-hoc layout with a gap and a short line
    assert_eq(layout_cols(".1.\n22.\n"), 3, "cols = longest line");
    assert_eq(layout_rows(".1.\n22.\n"), 2, "rows = line count");
    assert_eq(layout_count(".1.\n22.\n"), 3, "count = live cells");
    # shipped layouts: 5 levels, increasing brick count
    assert_eq(level_count(), 5, "five levels");
    assert_eq(layout_count(level_layout(0)), 18, "L1 brick count");
    assert_eq(layout_count(level_layout(1)), 25, "L2 brick count");
    assert_eq(layout_count(level_layout(2)), 34, "L3 brick count");
    assert_eq(layout_count(level_layout(3)), 40, "L4 brick count");
    assert_eq(layout_count(level_layout(4)), 49, "L5 brick count");
    # built grid: total = cols*rows, alive = live cells (L4 has gaps)
    var g1 = level_make_bricks(0, 200);
    assert_eq(bricks_total(g1), 18, "L1 grid 9x2");
    assert_eq(bricks_alive_count(g1), 18, "L1 all cells live");
    assert_eq(brick_tier(g1, 0), 3, "L1 top row tier 3");
    assert_eq(brick_tier(g1, 9), 1, "L1 bottom row tier 1");
    assert_eq(brick_destroy(g1, 0), 30, "tier 3 brick = 30 pts");
    assert_eq(brick_destroy(g1, 9), 10, "tier 1 brick = 10 pts");
    var g4 = level_make_bricks(3, 200);
    assert_eq(bricks_total(g4), 45, "L4 grid 9x5");
    assert_eq(bricks_alive_count(g4), 40, "L4 has 5 gap cells");
    # target speed climbs gently across levels (the difficulty knob)
    assert_eq(level_speed(0), fixed_from_int(5), "L1 target speed = 5");
    assert_eq(level_speed(4), fixed_from_int(7), "L5 target speed = 7");
    assert_eq(level_speed(4) > level_speed(0), 1, "target speed climbs");
    # serve velocity ~ (3, -4) at L1 along the 3-4-5 line, faster at L5
    assert_eq(near(level_serve_vx(0), fixed_from_int(3), 64), 1, "L1 serve vx ~ 3");
    assert_eq(near(level_serve_vy(0), 0 - fixed_from_int(4), 64), 1, "L1 serve vy ~ -4");
    assert_eq(fixed_abs(level_serve_vy(4)) > fixed_abs(level_serve_vy(0)), 1, "serve faster at L5");
    # serve magnitude == target speed (speed-conserving, no edge-hit drift)
    assert_eq(near(fixed_mul(level_serve_vx(0), level_serve_vx(0)) + fixed_mul(level_serve_vy(0), level_serve_vy(0)), fixed_mul(level_speed(0), level_speed(0)), fixed_from_int(1)), 1, "L1 serve |v| = target speed");
    # vy magnitude stays < brick height (8) so the ball can't tunnel a row
    assert_eq(fixed_abs(level_serve_vy(4)) < fixed_from_int(8), 1, "L5 serve vy < brick height");
    return 0;
}

fn test_rebound() {
    test_group("rebound");
    var s = fixed_from_int(5);
    # centre hit -> straight up at full speed (vx 0, vy = -speed)
    assert_eq(paddle_rebound_vx(0, s), 0, "centre rebound vx = 0");
    assert_eq(paddle_rebound_vy(0, s), 0 - fixed_from_int(5), "centre rebound vy = -speed");
    # english sign sets the vx direction; vy is always upward
    assert_eq(paddle_rebound_vx(FIXED_ONE, s) > 0, 1, "right english -> vx > 0");
    assert_eq(paddle_rebound_vx(0 - FIXED_ONE, s) < 0, 1, "left english -> vx < 0");
    assert_eq(paddle_rebound_vy(FIXED_ONE, s) < 0, 1, "edge rebound still upward");
    # speed conserved across the whole english range (unit-vector zones):
    # |v|^2 stays ~ speed^2 regardless of where the ball strikes
    var s2 = fixed_mul(s, s);
    var e = 0 - FIXED_ONE;
    while (e <= FIXED_ONE) {
        var vx = paddle_rebound_vx(e, s);
        var vy = paddle_rebound_vy(e, s);
        assert_eq(near(fixed_mul(vx, vx) + fixed_mul(vy, vy), s2, fixed_from_int(1)), 1, "rebound conserves speed");
        e = e + asr(FIXED_ONE, 2);
    }
    return 0;
}

fn test_level_progress() {
    test_group("level progress");
    # mid-game world: 1-brick level, score in flight, 2 lives left
    var b = ball_new(fixed_from_int(50), fixed_from_int(48), 0, fixed_from_int(2), fixed_from_int(2));
    var p = paddle_new(0, fixed_from_int(195), fixed_from_int(20), fixed_from_int(4));
    var g = bricks_new(1, 1, fixed_from_int(45), fixed_from_int(45), fixed_from_int(10), fixed_from_int(10), 0, 0, 100);
    var wd = world_new(b, p, g, fixed_from_int(200), fixed_from_int(200), 2, fixed_from_int(4));
    world_step(wd);
    assert_eq(world_state(wd), WS_LEVEL_CLEAR, "single brick cleared");
    assert_eq(world_score(wd), 100, "score before advancing");
    # advance into level 1 (the 25-brick cascade)
    level_load(wd, 1, 200, fixed_from_int(100), fixed_from_int(110));
    assert_eq(world_state(wd), WS_PLAYING, "level_load resumes play");
    assert_eq(world_score(wd), 100, "score carries across levels");
    assert_eq(world_lives(wd), 2, "lives carry across levels");
    assert_eq(bricks_alive_count(world_bricks(wd)), 25, "next level's bricks loaded");
    assert_eq(ball_vy(world_ball(wd)), level_serve_vy(1), "ball re-served at level speed");
    assert_eq(ball_y(world_ball(wd)), fixed_from_int(110), "ball repositioned to serve y");
    return 0;
}

fn test_audio() {
    test_group("audio");
    audio_init();
    var buf = alloc(64);
    # square wave at 441 Hz -> half-period = 11025/(2*441) = 12 samples, amp 50
    synth_tone(buf, 0, 64, 441, 441, 50, 50);
    assert_eq(load8(buf + 0), 178, "square hi = 128 + amp");
    assert_eq(load8(buf + 11), 178, "still hi through first half-period");
    assert_eq(load8(buf + 12), 78, "flips to lo = 128 - amp");
    assert_eq(load8(buf + 23), 78, "still lo through second half-period");
    assert_eq(load8(buf + 24), 178, "flips back to hi");
    # amp 0 -> centre (silence) regardless of phase
    synth_tone(buf, 0, 64, 441, 441, 0, 0);
    assert_eq(load8(buf + 0), 128, "amp 0 -> centre");
    assert_eq(load8(buf + 40), 128, "amp 0 -> centre later");
    # amplitude envelope: first sample carries a0
    synth_tone(buf, 0, 64, 441, 441, 80, 0);
    assert_eq(load8(buf + 0), 208, "amp envelope starts at a0");
    # SFX registry built
    assert_eq(sfx_len(SFX_PADDLE) > 0, 1, "paddle SFX built");
    assert_eq(sfx_buf(SFX_BRICK) != 0, 1, "brick SFX buffer allocated");
    assert_eq(sfx_len(SFX_FANFARE), ms_samples(90) * 4, "fanfare = 4 segments");
    # mute toggle
    audio_set_mute(0);
    assert_eq(audio_muted(), 0, "starts unmuted");
    assert_eq(audio_toggle_mute(), 1, "toggle -> muted");
    assert_eq(audio_muted(), 1, "muted");
    audio_toggle_mute();
    assert_eq(audio_muted(), 0, "toggle -> unmuted");
    return 0;
}

fn test_scores() {
    test_group("scores");
    var t = hs_new();
    assert_eq(hs_count(t), 0, "empty table");
    assert_eq(hs_qualifies(t, 100), 1, "positive qualifies when empty");
    assert_eq(hs_qualifies(t, 0), 0, "zero never qualifies");
    # insert (A=65, B=66, C=67); kept sorted descending
    assert_eq(hs_insert(t, 65, 65, 65, 100), 0, "first insert -> rank 0");
    assert_eq(hs_insert(t, 66, 66, 66, 300), 0, "higher score -> rank 0");
    assert_eq(hs_insert(t, 67, 67, 67, 200), 1, "middle score -> rank 1");
    assert_eq(hs_count(t), 3, "three entries");
    assert_eq(hs_score(t, 0), 300, "top = 300");
    assert_eq(hs_score(t, 1), 200, "middle = 200");
    assert_eq(hs_score(t, 2), 100, "bottom = 100");
    assert_eq(hs_initial(t, 0, 0), 66, "top initials = B");
    # overflow: fill past 10, cap holds and the lowest drops
    var i = 0;
    while (i < 10) {
        hs_insert(t, 90, 90, 90, 1000 + i * 10);
        i += 1;
    }
    assert_eq(hs_count(t), 10, "capped at 10");
    assert_eq(hs_qualifies(t, 50), 0, "below lowest -> no");
    assert_eq(hs_qualifies(t, 100000), 1, "above top -> yes");
    # serialize round-trip
    var sbuf[256];
    var slen = hs_serialize(t, &sbuf);
    var t2 = hs_new();
    assert_eq(hs_deserialize(t2, &sbuf, slen), 0, "deserialize ok");
    assert_eq(hs_count(t2), hs_count(t), "count round-trips");
    assert_eq(hs_score(t2, 0), hs_score(t, 0), "top score round-trips");
    # encode/decode round-trip (sankoch zlib + sigil hmac)
    var ebuf[256];
    var elen = hs_encode(t, &ebuf, 256);
    assert_eq(elen > 40, 1, "encoded length past header");
    var t3 = hs_new();
    assert_eq(hs_decode(t3, &ebuf, elen), 0, "decode ok");
    assert_eq(hs_score(t3, 0), hs_score(t, 0), "decoded top score matches");
    assert_eq(hs_initial(t3, 0, 0), hs_initial(t, 0, 0), "decoded initials match");
    # tamper: flip an HMAC byte -> rejected (-2), table left untouched
    store8(&ebuf + 10, load8(&ebuf + 10) ^ 255);
    var t4 = hs_new();
    assert_eq(hs_decode(t4, &ebuf, elen), 0 - 2, "tampered HMAC -> -2");
    assert_eq(hs_count(t4), 0, "table untouched on tamper");
    # bad magic -> malformed
    var junk[64];
    var j = 0;
    while (j < 64) {
        store8(&junk + j, j);
        j += 1;
    }
    assert_eq(hs_decode(hs_new(), &junk, 64), 0 - 1, "bad magic -> -1");
    return 0;
}

